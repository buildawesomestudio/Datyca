# Deny all web access to this directory.
# Used for server-side config files (e.g. contact-config.php) that must be
# readable by PHP includes but never served to HTTP clients.

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Extra hardening: even if server config changed and .htaccess were ignored,
# explicitly block direct access to .php files inside this folder.
<FilesMatch "\.(php|php5|phtml|inc|env|ini|log|bak|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
