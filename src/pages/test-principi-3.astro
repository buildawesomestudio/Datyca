---
import '../styles/global.css';
---

<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Test Principi — Datyca</title>
</head>
<body>
  <div id="smooth-wrapper"><div id="smooth-content">
  <main>
    <section id="test-principi">
      <div class="tp-inner">
        <div class="tp-header">
          <h2 class="text-section-title">I nostri principi</h2>
          <p class="text-body">I valori che guidano la nostra idea di innovazione responsabile</p>
        </div>

        <div class="tp-states">
          <div class="tp-state" data-state="0">
            <div class="tp-placeholder">
              <span class="text-regular" style="opacity: 0.3;">Animazione 1</span>
            </div>
            <h3 class="text-hero tp-state__title">
              Facilitiamo il <em>cambiamento</em>
            </h3>
            <p class="text-body tp-state__desc">Siamo al fianco delle persone e delle organizzazioni nei momenti di transizione tecnologica. Trasformiamo la complessità in scelte concrete, rendendo l'adozione dell'intelligenza artificiale un percorso sostenibile, comprensibile e umano.</p>
          </div>

          <div class="tp-state" data-state="1">
            <div class="tp-placeholder">
              <span class="text-regular" style="opacity: 0.3;">Animazione 2</span>
            </div>
            <h3 class="text-hero tp-state__title">
              Semplifichiamo la <em>complessità</em>
            </h3>
            <p class="text-body tp-state__desc">Applichiamo metodologie tipiche del Legal Design per rendere la compliance accessibile. Traduciamo la complessità normativa e i processi tecnologici in esperienze chiare e inclusive, capaci di generare la fiducia degli stakeholder.</p>
          </div>

          <div class="tp-state" data-state="2">
            <div class="tp-placeholder">
              <span class="text-regular" style="opacity: 0.3;">Animazione 3</span>
            </div>
            <h3 class="text-hero tp-state__title">
              Progettiamo la <em>fiducia</em>
            </h3>
            <p class="text-body tp-state__desc">Rendiamo la fiducia un elemento concreto di governance e di design. La integriamo nei modelli organizzativi e nelle interfacce dei sistemi di intelligenza artificiale per creare interazioni trasparenti, sicure e responsabili tra persone e tecnologia.</p>
          </div>

          <div class="tp-state" data-state="3">
            <div class="tp-placeholder">
              <span class="text-regular" style="opacity: 0.3;">Animazione 4</span>
            </div>
            <h3 class="text-hero tp-state__title">
              Mescoliamo <em>competenze</em>
            </h3>
            <p class="text-body tp-state__desc">Integriamo diritto, strategia e tecnologia in un linguaggio comune. Creiamo soluzioni che siano insieme conformi alla cornice normativa di riferimento, etiche e orientate al futuro.</p>
          </div>
        </div>
      </div>
    </section>

    <section style="height: 100vh; background: var(--color-white-snow);"></section>
  </main>
  </div></div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollSmoother } from 'gsap/ScrollSmoother';

    gsap.registerPlugin(ScrollTrigger, ScrollSmoother);
    gsap.config({ nullTargetWarn: false });
    ScrollTrigger.config({ ignoreMobileResize: true });

    ScrollSmoother.create({
      smooth: 1,
      effects: true,
      normalizeScroll: true,
      smoothTouch: false,
    });

    requestAnimationFrame(() => {
      const queue: Array<() => void> = (window as any).__initQueue ?? [];
      for (const fn of queue) { try { fn(); } catch(e) { console.error(e); } }
      (window as any).__initQueue = null;
      requestAnimationFrame(() => ScrollTrigger.refresh());
    });
  </script>
</body>
</html>

<style>
  #test-principi {
    height: 100vh;
    height: 100dvh;
    position: relative;
    overflow: hidden;
    background: var(--color-white-snow);
    color: var(--color-black-almost-900);
  }

  .tp-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 70px) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .tp-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--section-gap);
  }

  .tp-states {
    display: grid;
    grid-template-columns: 1fr;
    align-content: center;
    flex: 1;
    margin-top: clamp(20px, 2vw, 40px);
    width: 100%;
    text-align: center;
  }

  .tp-state {
    grid-row: 1 / -1;
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(24px, 3vw, 40px);
  }

  .tp-placeholder {
    width: 500px;
    max-width: 100%;
    height: 140px;
    border: 2px dashed var(--color-grey-300);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tp-state__title {
    color: var(--color-black-almost-900);
  }

  .tp-state__title em {
    font-style: italic;
    color: var(--color-red);
  }

  .tp-state__desc {
    max-width: 540px;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initTestPrincipi() {
    const section = document.getElementById('test-principi');
    if (!section) return;

    let ctx: gsap.Context | null = null;
    let principiTl: gsap.core.Timeline | null = null;

    // Track which accents have been revealed — survives ctx.revert()
    // State 0 starts already revealed (red in markup)
    const accentRevealed = [true, false, false, false];

    build();
    window.addEventListener('app-rebuild', build);

    window.addEventListener('resize', () => {
      const spacer = section.parentElement;
      if (spacer?.classList.contains('pin-spacer')) {
        const w = window.innerWidth + 'px';
        spacer.style.width = w;
        spacer.style.maxWidth = w;
        section.style.width = w;
        section.style.maxWidth = w;
      }
      if (principiTl) {
        principiTl.invalidate();
        principiTl.progress(principiTl.progress());
      }
    });

    function build() {
      if (ctx) ctx.revert();

      ctx = gsap.context(() => {
        const states = section.querySelectorAll<HTMLElement>('.tp-state');

        // Initial: first visible, rest hidden
        gsap.set(states[0], { autoAlpha: 1,  });
        gsap.set(Array.from(states).slice(1), { autoAlpha: 0, yPercent: 8,  });

        // Set initial state for stagger children
        states.forEach(state => {
          const children = state.querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
          gsap.set(children, { y: 0 });
        });

        const tl = principiTl = gsap.timeline({
          scrollTrigger: {
            id: 'test-principi-anim',
            trigger: section,
            start: 'top top',
            end: '+=400%',
            pin: true,
            scrub: 0.5,
            anticipatePin: 1,
            invalidateOnRefresh: true,
            snap: {
              snapTo: 'labels',
              duration: { min: 0.2, max: 0.6 },
              delay: 0.1,
              ease: 'power1.inOut',
            },
            onRefresh: (self) => {
              const t = self.getTween();
              if (t) t.progress(self.progress);
            },
          },
        });

        // Label for first state
        tl.addLabel('state0', 0);

        states.forEach((state, i) => {
          if (i < states.length - 1) {
            // Phase 1: Children stagger OUT (desc → title → placeholder)
            // Use relative y so they exit from their current parallax position
            const currChildren = state.querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
            const reversed = Array.from(currChildren).reverse();
            reversed.forEach((child, ci) => {
              tl.to(child, {
                y: '-=20', autoAlpha: 0,
                ease: 'none', duration: 0.12,
              }, i + 0.15 + ci * 0.05);
            });

            // Hide the whole state after children are gone
            tl.set(state, { autoAlpha: 0 }, i + 0.15 + reversed.length * 0.05 + 0.12);

            // Phase 2: Next state — container fades in
            tl.fromTo(states[i + 1],
              { autoAlpha: 0 },
              { autoAlpha: 1, ease: 'none', duration: 0.1 },
              i + 0.5,
            );

            // Phase 3: Children stagger in from below (uniform distance)
            // Accent starts in dark color unless already revealed
            const nextAccent = states[i + 1].querySelector('em') as HTMLElement;
            if (nextAccent) {
              gsap.set(nextAccent, { color: accentRevealed[i + 1] ? '#F21763' : '#0D0826' });
            }

            const nextChildren = states[i + 1].querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
            nextChildren.forEach((child, ci) => {
              tl.fromTo(child,
                { y: 20, autoAlpha: 0 },
                { y: 0, autoAlpha: 1, ease: 'none', duration: 0.15 },
                i + 0.52 + ci * 0.06,
              );
            });

            // Phase 4: Color reveal — per-character wave (autonomous, once only)
            if (nextAccent) {
              tl.call(() => {
                if (tl.scrollTrigger!.direction < 0) return;
                if (accentRevealed[i + 1]) return; // already revealed, skip

                accentRevealed[i + 1] = true;

                const split = SplitText.create(nextAccent, { type: 'chars', aria: 'none' });
                gsap.set(split.chars, { color: '#0D0826' });

                gsap.to(split.chars, {
                  color: '#F21763',
                  duration: 0.2,
                  stagger: { each: 0.035, from: 'start' },
                  ease: 'power2.out',
                  onComplete: () => {
                    nextAccent.style.color = '#F21763';
                    split.revert();
                  },
                });
              }, [], i + 0.58);
            }

            // Label at the resting point
            tl.addLabel(`state${i + 1}`, i + 1);
          }
        });

        // Final dwell so last state has hold time
        tl.to({}, { duration: 0.5 });
      });
    }
  }

  ((window as any).__initQueue ??= []).push(initTestPrincipi);
</script>
