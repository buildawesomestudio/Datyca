---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ServiceIntro from '../../components/ServiceIntro.astro';
import CosaFacciamoCards from '../../components/CosaFacciamoCards.astro';
import ServiziCorrelati from '../../components/ServiziCorrelati.astro';
import Contatti from '../../components/Contatti.astro';

const serviziServices = [
  {
    slug: 'cybersecurity',
    title: 'Cybersecurity',
    description: 'Sistemi di intelligenza artificiale affidabili, trasparenti e centrati sull\u2019uomo',
    href: '/servizi/cybersecurity',
  },
  {
    slug: 'legal-desk',
    title: 'Legal Desk',
    description: 'Sistemi di intelligenza artificiale affidabili, trasparenti e centrati sull\u2019uomo',
    href: '/servizi/legal-desk',
  },
  {
    slug: 'data-protection',
    title: 'Data Protection',
    description: 'Sistemi di intelligenza artificiale affidabili, trasparenti e centrati sull\u2019uomo',
    href: '/servizi/data-protection',
  },
];

const cosaFacciamoItems = [
  {
    title: 'Assistenza contrattuale',
    body: 'Supportiamo la negoziazione, la redazione e la revisione dei contratti nel ciclo attivo e passivo, assicurando coerenza con gli obiettivi di business e con il quadro normativo applicabile.',
  },
  {
    title: 'Compliance e supporto al\nmanagement',
    body: 'Affianchiamo il management negli adempimenti in materia di compliance aziendale, con particolare attenzione agli obblighi derivanti dalla normativa su protezione dei dati, sicurezza delle informazioni e intelligenza artificiale.',
  },
  {
    title: 'Proprietà intellettuale e\ninnovazione',
    body: 'Assistiamo l\u2019organizzazione nella tutela degli asset immateriali: marchi, brevetti, diritto d\u2019autore, segreti commerciali e know-how aziendale.',
  },
  {
    title: 'Marketing e comunicazione',
    body: 'Forniamo consulenza legale sulle iniziative di marketing, comunicazione commerciale e presenza digitale, con attenzione alla conformità normativa e alla tutela del brand.',
  },
  {
    title: 'Strumenti digitali e\ntecnologie',
    body: 'Assistiamo nell\u2019adozione e nell\u2019utilizzo conforme delle strumentazioni informatiche e telematiche, dalla redazione delle policy interne alla gestione dei profili legali connessi all\u2019uso delle tecnologie.',
  },
  {
    title: 'Pareri e risposte operative',
    body: 'Garantiamo risposte tempestive a quesiti legali e commerciali attraverso un sistema strutturato di help desk, con un legale di contatto dedicato che assicura continuità, conoscenza del contesto e personalizzazione crescente del servizio.',
  },
];
---

<Layout
  title="Legal Desk — Datyca"
  description="Affianchiamo le organizzazioni come partner legale di riferimento nella gestione quotidiana delle questioni giuridiche legate al business."
>
  <main>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Servizi' },
        { label: 'Legal Desk' },
      ]}
    />
    <div class="ld-page__dark">
      <ServiceIntro
        title="Legal Desk"
        subtitle="Assistenza legale continuativa per il business"
        bodyHtml={[
          'Affianchiamo le organizzazioni come partner legale di riferimento nella gestione quotidiana delle questioni giuridiche legate al business. Un <strong>pool di professionisti</strong> organizzati per aree di specializzazione garantisce interventi rapidi, multidisciplinari e costantemente aggiornati.',
          'Il modello è pensato per le PMI che necessitano di un presidio legale strutturato e per le organizzazioni più complesse che intendono integrare il proprio ufficio legale interno.',
        ]}
        obiettivoText="Disporre di un presidio legale costante, flessibile e personalizzato, che cresce con l'organizzazione e trasforma la gestione delle questioni giuridiche da costo imprevisto a investimento nella qualità dei processi."
      />
      <CosaFacciamoCards items={cosaFacciamoItems} />
      <ServiziCorrelati services={serviziServices} current="legal-desk" />
    </div>
    <Contatti />
  </main>
</Layout>

<style>
  .ld-page__dark {
    position: relative;
  }
</style>
