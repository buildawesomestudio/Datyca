---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Contatti from '../components/Contatti.astro';

const sections = [
  { id: 'chi-siamo',       label: 'Chi siamo' },
  { id: 'dati',            label: 'Quali dati raccogliamo e perché' },
  { id: 'destinatari',     label: 'A chi comunichiamo i tuoi dati' },
  { id: 'conservazione',   label: 'Per quanto tempo li conserviamo' },
  { id: 'sicurezza',       label: 'Come proteggiamo i tuoi dati' },
  { id: 'esterni',         label: 'Link verso siti esterni' },
  { id: 'diritti',         label: 'I tuoi diritti' },
  { id: 'trasferimenti',   label: 'Trasferimenti fuori dall\u2019UE' },
  { id: 'cookie',          label: 'Cookie' },
  { id: 'aggiornamenti',   label: 'Aggiornamenti' },
];

const summaryRows = [
  { attivita: 'Navigazione',     dati: 'IP, browser, pagine visitate', perche: 'Funzionamento e sicurezza',   base: 'Legittimo interesse',     conservazione: 'Durata sessione' },
  { attivita: 'Form contatti',   dati: 'Nome, e-mail, oggetto, messaggio', perche: 'Rispondere alle tue richieste', base: 'Misure precontrattuali', conservazione: '12 mesi' },
  { attivita: 'Download guida',  dati: 'E-mail, nome e cognome', perche: 'Inviarti il documento', base: 'Misure precontrattuali', conservazione: '12 mesi' },
  { attivita: 'Newsletter',      dati: 'E-mail', perche: 'Aggiornamenti e novità', base: 'Consenso', conservazione: 'Fino a revoca' },
];

const retentionItems = [
  { label: 'Dati di navigazione', duration: 'Durata della sessione' },
  { label: 'Form contatti',       duration: '12 mesi dall\u2019ultimo contatto' },
  { label: 'Download guida',      duration: '12 mesi dal download' },
  { label: 'Newsletter',          duration: 'Fino a revoca del consenso' },
];

const extLinks = [
  { name: 'GovIA',         desc: 'Piattaforma per il self-assessment dei sistemi di IA' },
  { name: 'AI Learn Hub',  desc: 'Piattaforma di AI Literacy' },
  { name: 'TAIG Lab',      desc: 'Centro Studi sulla Technical AI Governance' },
];
---

<Layout
  title="Privacy Policy — Datyca"
  description="Informativa privacy ai sensi dell'art. 13 Regolamento (UE) 2016/679 (GDPR). Come DATYCA Legal Design Lab S.r.l. tratta i dati personali."
>
  <main>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Privacy Policy' },
      ]}
    />

    {/* DARK HERO — title in brand magenta (#F21763), white subtitle. */}
    <section class="pp-hero">
      <h1 class="text-hero pp-hero__title">Privacy Policy</h1>
      <p class="pp-hero__ref">ai sensi dell&rsquo;art. 13 Regolamento (UE) 2016/679</p>
    </section>

    {/* LIGHT CONTENT AREA — legal document style */}
    <div class="pp-light">
      <div class="pp-content">

        <p class="pp-intro">
          Questa pagina descrive come trattiamo i tuoi dati personali quando visiti il nostro sito e utilizzi i servizi disponibili. Abbiamo scritto questa informativa per essere chiari e trasparenti, in conformità al Regolamento (UE) 2016/679 (GDPR).
        </p>

        {/* INDEX */}
        <nav class="pp-anchor-nav" aria-label="Indice">
          <h2 class="pp-anchor-nav__title">Indice</h2>
          <ol class="pp-anchor-nav__list">
            {sections.map(({ id, label }) => (
              <li class="pp-anchor-nav__item"><a href={`#${id}`}>{label}</a></li>
            ))}
          </ol>
        </nav>

        {/* SUMMARY TABLE */}
        <div class="pp-summary">
          <h2 class="pp-summary__title">In sintesi</h2>
          <div class="pp-table-scroll">
            <table class="pp-table">
              <thead>
                <tr>
                  <th>Attività</th>
                  <th>Dati raccolti</th>
                  <th>Perché</th>
                  <th>Base giuridica</th>
                  <th>Conservazione</th>
                </tr>
              </thead>
              <tbody>
                {summaryRows.map(r => (
                  <tr>
                    <td>{r.attivita}</td>
                    <td>{r.dati}</td>
                    <td>{r.perche}</td>
                    <td>{r.base}</td>
                    <td>{r.conservazione}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="pp-summary__note">Il dettaglio di ciascun trattamento è descritto nelle sezioni che seguono.</p>
        </div>

        <hr class="pp-divider" />

        {/* 1. CHI SIAMO */}
        <section class="pp-section" id="chi-siamo">
          <p class="pp-section__num">Sezione 1</p>
          <h2 class="pp-section__title">Chi siamo</h2>
          <p>Il Titolare del trattamento è <strong>DATYCA Legal Design Lab S.r.l.</strong>, con sede legale in Via Principe di Belmonte n. 101, 90139 &ndash; Palermo, P.IVA 06954020829 (&ldquo;DATYCA&rdquo;).</p>
          <div class="pp-contact-box">
            <p>Per qualsiasi domanda relativa al trattamento dei tuoi dati personali:</p>
            <p><a href="mailto:info@datyca.com">info@datyca.com</a></p>
          </div>
        </section>

        <hr class="pp-divider" />

        {/* 2. QUALI DATI */}
        <section class="pp-section" id="dati">
          <p class="pp-section__num">Sezione 2</p>
          <h2 class="pp-section__title">Quali dati raccogliamo e perché</h2>

          <div class="pp-treatment">
            <h3 class="pp-treatment__title"><span class="pp-treatment__dot" aria-hidden="true"></span>Dati di navigazione</h3>
            <p>Quando visiti il sito, i nostri sistemi raccolgono automaticamente alcuni dati tecnici: indirizzo IP, tipo di browser, sistema operativo, pagine visitate e orari di accesso. Sono necessari per il corretto funzionamento del sito e per garantirne la sicurezza.</p>
            <p>Non li utilizziamo per identificarti.</p>
            <p class="pp-treatment__legal">Base giuridica: legittimo interesse al funzionamento e alla protezione del sito (art. 6, par. 1, lett. f) GDPR).</p>
          </div>

          <div class="pp-treatment">
            <h3 class="pp-treatment__title"><span class="pp-treatment__dot" aria-hidden="true"></span>Form contatti</h3>
            <p>Se ci scrivi tramite il form presente nel sito, raccogliamo i dati che inserisci: nome, e-mail, oggetto della richiesta e il testo del messaggio. Li utilizziamo esclusivamente per rispondere alla tua richiesta e per un eventuale successivo contatto legato alla richiesta ricevuta.</p>
            <p>Il conferimento dei dati è volontario, ma necessario per poterti rispondere.</p>
            <p class="pp-treatment__legal">Base giuridica: esecuzione di misure precontrattuali adottate su tua richiesta (art. 6, par. 1, lett. b) GDPR).</p>
          </div>

          <div class="pp-treatment">
            <h3 class="pp-treatment__title"><span class="pp-treatment__dot" aria-hidden="true"></span>Download della guida operativa</h3>
            <p>Quando scarichi una delle nostre guide, ti chiediamo l&rsquo;indirizzo e-mail per inviarti il documento richiesto. In fase di download puoi anche esprimere il tuo consenso a ricevere la nostra newsletter.</p>
            <p class="pp-treatment__legal">Base giuridica: esecuzione della tua richiesta (art. 6, par. 1, lett. b) GDPR) per l&rsquo;invio della guida. Per la newsletter, il tuo consenso (art. 6, par. 1, lett. a) GDPR), revocabile in qualsiasi momento.</p>
          </div>

          <div class="pp-treatment">
            <h3 class="pp-treatment__title"><span class="pp-treatment__dot" aria-hidden="true"></span>Newsletter e comunicazioni</h3>
            <p>Se scegli di iscriverti alla nostra newsletter, utilizziamo il tuo indirizzo e-mail per inviarti aggiornamenti, approfondimenti e novità in materia di AI Governance e sugli altri temi di nostra competenza.</p>
            <p>Puoi revocare il consenso in qualsiasi momento cliccando sul link di disiscrizione presente in ogni comunicazione oppure scrivendoci a <a href="mailto:info@datyca.com">info@datyca.com</a>.</p>
            <p class="pp-treatment__legal">Base giuridica: il tuo consenso (art. 6, par. 1, lett. a) GDPR).</p>
          </div>
        </section>

        <hr class="pp-divider" />

        {/* 3. DESTINATARI */}
        <section class="pp-section" id="destinatari">
          <p class="pp-section__num">Sezione 3</p>
          <h2 class="pp-section__title">A chi comunichiamo i tuoi dati</h2>
          <p>I tuoi dati personali sono trattati dal personale di DATYCA espressamente autorizzato e da soggetti terzi che svolgono attività per nostro conto, nominati responsabili del trattamento ai sensi dell&rsquo;art. 28 GDPR.</p>
          <p>Non trasferiamo o condividiamo i tuoi dati con terzi per finalità diverse da quelle descritte in questa policy. L&rsquo;elenco aggiornato dei responsabili del trattamento è disponibile su richiesta scrivendo a <a href="mailto:info@datyca.com">info@datyca.com</a>.</p>
        </section>

        <hr class="pp-divider" />

        {/* 4. CONSERVAZIONE */}
        <section class="pp-section" id="conservazione">
          <p class="pp-section__num">Sezione 4</p>
          <h2 class="pp-section__title">Per quanto tempo conserviamo i tuoi dati</h2>
          <p>Conserviamo i tuoi dati solo per il tempo necessario alle finalità per cui li abbiamo raccolti.</p>
          <ul class="pp-retention">
            {retentionItems.map(({ label, duration }) => (
              <li class="pp-retention__item">
                <span class="pp-retention__label">{label}</span>
                <span class="pp-retention__duration">{duration}</span>
              </li>
            ))}
          </ul>
          <p class="pp-retention__note">I dati di navigazione possono essere conservati oltre la sessione in caso di necessità di accertamento di reati informatici. I dati del form contatti sono conservati per un periodo superiore qualora il rapporto si trasformi in un incarico professionale, nel qual caso si applica l&rsquo;informativa specifica. Dopo la disiscrizione dalla newsletter, conserviamo la prova del consenso e della revoca per il tempo necessario a dimostrare la conformità normativa.</p>
        </section>

        <hr class="pp-divider" />

        {/* 5. SICUREZZA */}
        <section class="pp-section" id="sicurezza">
          <p class="pp-section__num">Sezione 5</p>
          <h2 class="pp-section__title">Come proteggiamo i tuoi dati</h2>
          <p>Adottiamo misure tecniche e organizzative adeguate per proteggere i tuoi dati da accessi non autorizzati, perdite o alterazioni. La scelta delle misure di sicurezza riflette la natura dei dati trattati e il livello di rischio associato.</p>
          <p>DATYCA opera nell&rsquo;ambito di un sistema di gestione certificato <strong>ISO/IEC 42001</strong>, che garantisce standard elevati di governance, sicurezza e controllo anche nell&rsquo;utilizzo di tecnologie digitali a supporto delle proprie attività.</p>
        </section>

        <hr class="pp-divider" />

        {/* 6. LINK ESTERNI */}
        <section class="pp-section" id="esterni">
          <p class="pp-section__num">Sezione 6</p>
          <h2 class="pp-section__title">Link verso siti e piattaforme esterne</h2>
          <p>Il sito contiene link verso piattaforme e servizi esterni gestiti da DATYCA o da terzi. Quando accedi a questi servizi, esci dal presente sito e si applicano le rispettive informative privacy. In particolare:</p>
          <div class="pp-extlinks">
            {extLinks.map(({ name, desc }) => (
              <div class="pp-extlinks__card">
                <div class="pp-extlinks__name">{name}</div>
                <div class="pp-extlinks__desc">{desc}</div>
              </div>
            ))}
          </div>
          <p class="pp-extlinks__note">Ti invitiamo a consultare le rispettive informative prima di fornire i tuoi dati.</p>
        </section>

        <hr class="pp-divider" />

        {/* 7. DIRITTI */}
        <section class="pp-section" id="diritti">
          <p class="pp-section__num">Sezione 7</p>
          <h2 class="pp-section__title">I tuoi diritti</h2>
          <p>Potrai esercitare in qualsiasi momento i tuoi diritti previsti dagli artt. 15 e ss. del Regolamento, ed in particolare: ottenere la conferma dell&rsquo;esistenza o meno dei dati da parte del Titolare e conoscerne il contenuto e l&rsquo;origine, verificarne l&rsquo;esattezza o chiederne l&rsquo;integrazione o l&rsquo;aggiornamento, oppure la rettificazione; gli utenti avranno altresì il diritto di chiedere la cancellazione, la trasformazione in forma anonima o il blocco dei dati trattati in violazione di legge, nonché di opporsi in ogni caso al loro trattamento.</p>
          <div class="pp-contact-box">
            <p>Per esercitare i tuoi diritti, potrai rivolgerti al Titolare alla casella di posta elettronica:</p>
            <p><a href="mailto:info@datyca.com">info@datyca.com</a></p>
          </div>
          <p>In ogni caso, qualora tu ritenga che il trattamento dei dati personali sia contrario alla normativa privacy, avrai sempre diritto di proporre reclamo all&rsquo;autorità di controllo competente (<a href="https://www.garanteprivacy.it" target="_blank" rel="noopener noreferrer">Garante per la protezione dei dati personali</a>) ai sensi dell&rsquo;art. 77 GDPR.</p>
        </section>

        <hr class="pp-divider" />

        {/* 8. TRASFERIMENTI */}
        <section class="pp-section" id="trasferimenti">
          <p class="pp-section__num">Sezione 8</p>
          <h2 class="pp-section__title">Trasferimenti fuori dall&rsquo;Unione Europea</h2>
          <p>I tuoi dati personali sono trattati all&rsquo;interno dell&rsquo;Unione Europea. Ad ogni modo, le comunicazioni via internet quali e-mail o webmail potrebbero transitare attraverso differenti nazioni, prima di essere recapitate ai destinatari. DATYCA non può farsi carico della responsabilità di qualsiasi accesso non autorizzato né dello smarrimento delle informazioni personali al di fuori del proprio controllo.</p>
          <p>Qualora si rendessero necessari trasferimenti verso altri Paesi terzi, adotteremo le garanzie previste dal capo V del GDPR. Puoi richiedere maggiori informazioni scrivendo a <a href="mailto:info@datyca.com">info@datyca.com</a>.</p>
        </section>

        <hr class="pp-divider" />

        {/* 9. COOKIE */}
        <section class="pp-section" id="cookie">
          <p class="pp-section__num">Sezione 9</p>
          <h2 class="pp-section__title">Cookie</h2>
          <p>Per informazioni sui cookie utilizzati dal sito e su come gestire le tue preferenze, consulta la nostra <strong>Cookie Policy</strong>.</p>
        </section>

        <hr class="pp-divider" />

        {/* 10. AGGIORNAMENTI */}
        <section class="pp-section" id="aggiornamenti">
          <p class="pp-section__num">Sezione 10</p>
          <h2 class="pp-section__title">Aggiornamenti</h2>
          <p>Questa privacy policy può essere aggiornata per riflettere modifiche nelle nostre attività o nel quadro normativo. In caso di modifiche rilevanti, ti informeremo attraverso il sito.</p>
        </section>

      </div>
    </div>

    <Contatti />
  </main>
</Layout>

<style>
  /* ── Local light-theme palette (legal document readability) ──
     This page intentionally departs from the site-wide dark theme: long-form
     legal text reads better on a light background. The Datyca dark Header
     stays on top (its bg is #0D0826), then a dark hero with the title, then
     the light content area, then the white Contatti footer at the bottom. */
  .pp-hero,
  .pp-light,
  .pp-content,
  .pp-section,
  .pp-section :global(p),
  .pp-anchor-nav,
  .pp-summary,
  .pp-treatment,
  .pp-contact-box,
  .pp-extlinks {
    --pp-text:        #2A2A2A;
    --pp-text-light:  #555555;
    --pp-light-gray:  #E1E1E1;
    --pp-row-stripe:  #F8F8FC;
    --pp-blue-tint:   #F0F0FF;
    --pp-bg:          var(--color-white-snow);
    --pp-white:       #FFFFFF;
  }

  /* ── DARK HERO ──────────────────────────────────────────────── */
  .pp-hero {
    text-align: center;
    padding: clamp(40px, 6vw, 64px) var(--section-padding-x) clamp(48px, 7vw, 72px);
    background: var(--color-bg);
  }
  /* Per client direction: title in brand magenta (#F21763), subtitle white.
     Letter-spacing -0.04em to match the rest of the site's serif copy. */
  .pp-hero__title {
    color: var(--color-red);
    margin-bottom: 12px;
  }
  .pp-hero__ref {
    font-family: var(--font-serif);
    color: var(--color-white-almost);
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.4;
    letter-spacing: -0.04em;
  }

  /* ── LIGHT WRAP ─────────────────────────────────────────────── */
  .pp-light {
    background: var(--pp-bg);
    color: var(--pp-text);
  }
  .pp-content {
    max-width: 820px;
    margin-inline: auto;
    padding: clamp(48px, 6vw, 80px) clamp(20px, 4vw, 40px) clamp(64px, 8vw, 100px);
  }

  .pp-intro {
    font-size: clamp(15px, 1.2vw, 17px);
    color: var(--pp-text-light);
    line-height: 1.8;
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  /* ── ANCHOR NAV ─────────────────────────────────────────────── */
  .pp-anchor-nav {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-radius: 12px;
    padding: clamp(24px, 3vw, 36px);
    margin-bottom: clamp(40px, 5vw, 56px);
  }
  .pp-anchor-nav__title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-grey-400);
    margin-bottom: 16px;
  }
  .pp-anchor-nav__list {
    list-style: none;
    counter-reset: pp-nav;
    columns: 2;
    column-gap: 40px;
    padding: 0;
    margin: 0;
  }
  .pp-anchor-nav__item {
    counter-increment: pp-nav;
    margin-bottom: 8px;
    break-inside: avoid;
  }
  .pp-anchor-nav__item a {
    color: var(--pp-text);
    text-decoration: none;
    font-size: 15px;
    display: block;
    padding: 4px 0;
    transition: color 0.2s var(--ease-signature);
  }
  .pp-anchor-nav__item a::before {
    content: counter(pp-nav) ". ";
    color: var(--color-purple-500);
    font-weight: 600;
    margin-right: 4px;
  }
  .pp-anchor-nav__item a:hover {
    color: var(--color-purple-500);
  }

  /* ── SUMMARY TABLE ──────────────────────────────────────────── */
  .pp-summary {
    margin-bottom: clamp(40px, 5vw, 56px);
  }
  .pp-summary__title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-purple-500);
    margin-bottom: 20px;
  }
  .pp-table-scroll {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--pp-light-gray);
  }
  .pp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 14px;
    background: var(--pp-white);
  }
  .pp-table thead th {
    background: var(--color-black-almost-900);
    color: var(--color-white-almost);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 14px 16px;
    text-align: center;
  }
  .pp-table tbody td {
    padding: 14px 16px;
    border-bottom: 1px solid #F0F0F0;
    vertical-align: middle;
    color: var(--pp-text-light);
    line-height: 1.5;
    text-align: center;
  }
  .pp-table tbody tr:last-child td { border-bottom: none; }
  .pp-table tbody tr:nth-child(even) td { background: var(--pp-row-stripe); }
  .pp-table tbody td:first-child {
    font-weight: 500;
    color: var(--pp-text);
  }
  .pp-summary__note {
    font-size: 15px;
    color: var(--pp-text-light);
    margin-top: 16px;
    line-height: 1.7;
  }

  /* ── DIVIDER ───────────────────────────────────────────────── */
  .pp-divider {
    border: none;
    border-top: 1px solid var(--pp-light-gray);
    margin: 0 0 clamp(40px, 5vw, 52px);
  }

  /* ── SECTIONS ──────────────────────────────────────────────── */
  .pp-section {
    margin-bottom: clamp(40px, 5vw, 52px);
    /* Header is fixed (~120px desktop / 80px mobile) — push anchor jumps below it */
    scroll-margin-top: 140px;
  }
  .pp-section__num {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-purple-500);
    margin-bottom: 8px;
  }
  .pp-section__title {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 26px);
    font-weight: 600;
    color: var(--color-black-almost-900);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .pp-section p {
    font-size: clamp(15px, 1.1vw, 16px);
    color: var(--pp-text-light);
    margin-bottom: 14px;
    line-height: 1.75;
  }
  .pp-section p strong {
    color: var(--pp-text);
    font-weight: 600;
  }
  .pp-section a {
    color: var(--color-purple-500);
    text-decoration: none;
    font-weight: 500;
  }
  .pp-section a:hover { text-decoration: underline; }

  /* ── CONTACT BOX ───────────────────────────────────────────── */
  .pp-contact-box {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-left: 4px solid var(--color-purple-500);
    border-radius: 0 8px 8px 0;
    padding: 20px 24px;
    margin: 16px 0 20px;
  }
  .pp-contact-box p {
    margin-bottom: 4px;
    font-size: 15px;
  }
  .pp-contact-box p:last-child { margin-bottom: 0; }

  /* ── TREATMENT BLOCKS ──────────────────────────────────────── */
  .pp-treatment {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-radius: 12px;
    padding: clamp(20px, 2.5vw, 28px) clamp(20px, 3vw, 32px);
    margin: 20px 0;
  }
  .pp-treatment__title {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-black-almost-900);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pp-treatment__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-purple-500);
    flex-shrink: 0;
  }
  .pp-treatment p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--pp-text-light);
    margin-bottom: 10px;
  }
  .pp-treatment p:last-child { margin-bottom: 0; }
  .pp-treatment__legal {
    font-size: 13px !important;
    color: var(--color-grey-400) !important;
    font-style: italic;
    margin-top: 8px;
    margin-bottom: 0 !important;
  }

  /* ── RETENTION LIST ────────────────────────────────────────── */
  .pp-retention {
