---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ImpactIntro from '../components/ImpactIntro.astro';
import Contatti from '../components/Contatti.astro';
---

<Layout
  title="Risorse — Datyca"
  description="Risorse, guide e strumenti per l'adozione responsabile dell'intelligenza artificiale."
>
  <main>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: 'Risorse' },
      ]}
    />
    <div class="ris-page__dark">
      <ImpactIntro
        title="Risorse"
        hideVisual={true}
      />
      <section class="ris-cards">
        <div class="ris-cards__inner">
          <article class="ris-card">
            <div class="ris-card__image">
              <img src="/images/risorse/guida-ai-10-step.webp" alt="Copertina della guida Governare l'intelligenza artificiale in 10 step" loading="lazy" />
            </div>
            <div class="ris-card__content">
              <h2 class="ris-card__title">Governare l'IA in 10 step</h2>
              <p class="text-body ris-card__desc">Una guida pratica per orientare la tua organizzazione nell'adozione responsabile e conforme dell'intelligenza artificiale.</p>
              <button type="button" class="text-cta ris-card__cta" data-leadmagnet-trigger>
                <span>SCARICA LA GUIDA</span>
                <svg width="18" height="18" aria-hidden="true"><use href="#icon-diagonal-down-thick" /></svg>
              </button>
            </div>
          </article>
        </div>
      </section>
      <div class="ris-gradient" aria-hidden="true"></div>
    </div>
    <Contatti />
  </main>

<style>
  .ris-page__dark {
    position: relative;
  }

  /* Gap between intro body text and the card: 40px desktop, scaled down on
     mobile. Zero out ImpactIntro's default section padding-bottom, keep only
     the content margin-bottom so the total gap is exactly this single value. */
  .ris-page__dark :global(.ii__content) {
    margin-bottom: clamp(50px, 6vw, 80px);
  }
  .ris-page__dark :global(.ii) {
    padding-bottom: 0;
  }

  /* ── Resource cards section ── */
  .ris-cards__inner {
    max-width: 1440px;
    margin-inline: auto;
    padding: 0 clamp(40px, 10.9vw, 157px);
  }

  .ris-card {
    display: flex;
    align-items: center;
    gap: clamp(24px, 3vw, 40px);
    padding: clamp(24px, 3vw, 40px);
    border: 1px solid var(--color-purple-500);
  }

  .ris-card__image {
    flex-shrink: 0;
    width: clamp(140px, 14vw, 200px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
  }

  .ris-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ris-card__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ris-card__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(24px, 2.5vw, 30px);
    line-height: 1.3;
    color: var(--color-white-almost);
    letter-spacing: -0.02em;
  }

  .ris-card__desc {
    color: var(--color-white-almost);
  }

  .ris-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    align-self: flex-start;
    background: transparent;
    cursor: pointer;
    font: inherit;
    letter-spacing: inherit;
  }

  /* FOUC gate — card hidden until reveal plays (chained to ImpactIntro).
     opacity (not visibility) to avoid inheritance quirks with autoAlpha. */
  .ris-card {
    opacity: 0;
  }

  /* ── Gradient area ── */
  /* ── NOTE — gradient sizing unit choice ──────────────────────────────
     Other dark "outro" sections on the site (e.g. .pa-promo, .taig-promo)
     use the same radial-gradient with percentage-based ellipse dimensions
     (ellipse 80% 120% at -5% 110%). That works there because those sections
     are ~400–600px tall, so the ellipse ends up big enough to read well.
     On this page the section is deliberately short (just title + 1 card),
     so a %-based ellipse would shrink with the container and the gradient
     would visibly thin out.
     Fix: use absolute units (vw for width, px for height) so the ellipse's
     visual mass stays constant regardless of min-height. The section still
     anchors the gradient at bottom-left and simply reveals more or less of
     it depending on how tall it is. If in the future we shorten any other
     outro section below ~400px, apply the same pattern there. */
  .ris-gradient {
    min-height: clamp(230px, 30vw, 440px);
    background: radial-gradient(
      ellipse 80vw 600px at -5vw 100%,
      var(--color-red) 0%,
      var(--color-blue-deep-800) 30%,
      var(--color-black-almost-900) 55%
    );
    background-repeat: no-repeat;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .ris-cards__inner {
      padding: 0 var(--section-padding-x);
    }

    .ris-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .ris-card__cta {
      align-self: stretch;
      justify-content: space-between;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  function initRisorse() {
    const card = document.querySelector<HTMLElement>('.ris-card');
    if (!card) return;
    const cta = card.querySelector<HTMLButtonElement>('[data-leadmagnet-trigger]');

    // Page-load reveal sequenced after the "Risorse" title (single word,
    // ends ~0.7s). Card starts at 0.45s so it arrives while the title is
    // settling — natural continuation, independent of scroll.
    gsap.set(card, { opacity: 0, y: 30 });
    gsap.to(card, {
      opacity: 1, y: 0,
      duration: 0.7, delay: 0.45, ease: 'power2.out',
    });

    /* ── CTA: open lead-magnet modal ── */
    cta?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('datyca:leadmagnet:open', {
        detail: { source: 'risorse' },
      }));
    });

    /* ── CTA hover (desktop pointer only) ── */
    if (window.matchMedia('(pointer: fine)').matches && cta) {
      const root = getComputedStyle(document.documentElement);
      const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      cta.addEventListener('mouseenter', () => {
        gsap.to(cta, { borderColor: colorPurple600, color: colorPurple600, duration: 0.25, overwrite: 'auto' });
      });
      cta.addEventListener('mouseleave', () => {
        gsap.to(cta, { borderColor: colorText, color: colorText, duration: 0.25, overwrite: 'auto' });
      });
    }
  }

  ((window as any).__initQueue ??= []).push(initRisorse);
</script>

</Layout>
