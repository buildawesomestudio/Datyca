---
import Layout from './Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ServiceIntro from '../components/ServiceIntro.astro';
import CosaFacciamoCards from '../components/CosaFacciamoCards.astro';
import ServiziCorrelati from '../components/ServiziCorrelati.astro';
import Contatti from '../components/Contatti.astro';

interface Service {
  slug: string;
  title: string;
  description: string;
  href: string;
}

interface CosaFacciamoItem {
  title: string;
  body: string;
}

interface Props {
  pageTitle: string;
  pageDescription: string;
  breadcrumbParent: string;
  breadcrumbCurrent: string;
  currentSlug: string;
  services: Service[];
  intro: {
    title: string;
    subtitle: string;
    bodyHtml: string[];
    obiettivoText: string;
  };
  cosaFacciamoItems: CosaFacciamoItem[];
}

const {
  pageTitle,
  pageDescription,
  breadcrumbParent,
  breadcrumbCurrent,
  currentSlug,
  services,
  intro,
  cosaFacciamoItems,
} = Astro.props;
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: breadcrumbParent },
        { label: breadcrumbCurrent },
      ]}
    />
    <div class="service-page__dark">
      <ServiceIntro
        title={intro.title}
        subtitle={intro.subtitle}
        bodyHtml={intro.bodyHtml}
        obiettivoText={intro.obiettivoText}
      />
      <CosaFacciamoCards items={cosaFacciamoItems} />
      <ServiziCorrelati services={services} current={currentSlug} />
    </div>
    <Contatti />
  </main>
</Layout>

<style>
  .service-page__dark {
    position: relative;
  }
</style>
