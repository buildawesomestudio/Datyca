---
import '../styles/global.css';
import Header from '../components/Header.astro';
import HeaderCompact from '../components/HeaderCompact.astro';
import Megamenu from '../components/Megamenu.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Datyca', description = '' } = Astro.props;
---

<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {description && <meta name="description" content={description} />}
  <link rel="preload" href="/src/fonts/Optik/Optik-DemiBold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/src/fonts/Optik/Optik-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>

  <Header />
  <HeaderCompact />
  <Megamenu />

  <!-- ScrollSmoother wrapper -->
  <div id="smooth-wrapper">
    <div id="smooth-content">
      <slot />
    </div>
  </div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollSmoother } from 'gsap/ScrollSmoother';
    import { SplitText } from 'gsap/SplitText';
    import '../utils/gsap-debug';

    gsap.registerPlugin(ScrollTrigger, ScrollSmoother, SplitText);
    gsap.config({ nullTargetWarn: false });
    ScrollTrigger.config({ ignoreMobileResize: true });

    (window as any).__smoother = ScrollSmoother.create({
      smooth: 1,
      normalizeScroll: true,
    });

    // Drain init queue, then refresh
    requestAnimationFrame(() => {
      const queue: Array<() => void> = (window as any).__initQueue ?? [];
      for (const fn of queue) {
        try { fn(); } catch (e) { console.error('[init-queue]', e); }
      }
      (window as any).__initQueue = null;
      requestAnimationFrame(() => ScrollTrigger.refresh());
    });
  </script>
</body>
</html>
