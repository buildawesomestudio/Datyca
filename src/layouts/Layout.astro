---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import HeaderCompact from '../components/HeaderCompact.astro';
import Megamenu from '../components/Megamenu.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Datyca', description = '' } = Astro.props;
---

<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {/* iOS Safari address bar UI when expanded — match the dark page background.
      Defensive: the primary fix for the translucent chrome blur is body's
      dark background in global.css (theme-color does NOT control the
      translucent toolbars). Kept here as an extra hardening layer that
      costs nothing. See .claude/rules/ios-safari.md → "body background MUST
      match the dominant page color". */}
  <meta name="theme-color" content="#0D0826" />
  {description && <meta name="description" content={description} />}
  <link rel="preload" href="/src/fonts/Optik/Optik-DemiBold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/src/fonts/Optik/Optik-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <ClientRouter />
</head>
<body>

  <Header />
  <HeaderCompact />
  <Megamenu />

  <slot />

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    import '../utils/gsap-debug';

    gsap.registerPlugin(ScrollTrigger, SplitText);
    gsap.config({ nullTargetWarn: false });
    ScrollTrigger.config({ ignoreMobileResize: true });

    /* ── View Transitions GSAP lifecycle ────────────────────────────
     *  - initRegistry persists across navigations (module scope)
     *  - pageCtx wraps all GSAP objects per page for one-line cleanup
     *  - astro:page-load  fires on EVERY navigation (including initial)
     *  - astro:before-swap fires BEFORE DOM replacement (not on initial)
     * ────────────────────────────────────────────────────────────── */

    const initRegistry: Array<() => void> = [];
    let pageCtx: gsap.Context | null = null;

    function initPage() {
      // Collect new init functions pushed by component scripts
      const queue: Array<() => void> = (window as any).__initQueue ?? [];
      for (const fn of queue) {
        if (!initRegistry.includes(fn)) initRegistry.push(fn);
      }
      (window as any).__initQueue = [];

      // Astro ClientRouter + <video>: preloaded videos don't re-initialize after
      // DOM swap (known Astro issue #11918). Force re-load on every page-load so
      // the Hero video (and any others) start fresh.
      document.querySelectorAll('video').forEach(v => {
        try { v.load(); } catch { /* ignore */ }
      });

      // Page-scoped GSAP context — tracks all triggers/tweens/matchMedia for cleanup
      pageCtx = gsap.context(() => {
        // no-op: context is populated via pageCtx.add() below
      });

      // Run inits next frame (DOM layout ready)
      requestAnimationFrame(() => {
        if (!pageCtx) return; // Guard: user navigated before frame fired
        pageCtx.add(() => {
          for (const fn of initRegistry) {
            try { fn(); } catch (e) { console.error('[init]', e); }
          }
        });
        requestAnimationFrame(() => {
          ScrollTrigger.refresh();
          // iOS pin stability (WebKit #181954) — only needed on pages that
          // actually have pinned ScrollTriggers. On pin-less sub-pages we keep
          // native scroll for a snappier feel.
          const hasPins = ScrollTrigger.getAll().some(st => !!st.pin);
          ScrollTrigger.normalizeScroll(hasPins);
          // After pin-spacers are finalized, honor any #hash in the URL
          scrollToHash();
        });
      });
    }

    function cleanupPage() {
      if (pageCtx) {
        pageCtx.revert(); // Kills all GSAP objects: ScrollTriggers, tweens, matchMedia
        pageCtx = null;
      }
      // Safety: clear any scroll lock the megamenu may have left behind
      document.documentElement.style.overflow = '';
    }

    /* Cross-page navigation with a #hash needs an explicit scroll after init +
     * refresh, because pin-spacers inflate the document AFTER the browser's
     * initial anchor-scroll attempt. We use 'auto' (instant) to land directly. */
    function scrollToHash() {
      const hash = window.location.hash;
      if (!hash || hash.length < 2) return;
      let target: HTMLElement | null = null;
      try { target = document.querySelector(hash); } catch { /* invalid selector */ }
      if (!target) return;
      target.scrollIntoView({ behavior: 'auto', block: 'start' });
    }

    document.addEventListener('astro:page-load', initPage);
    document.addEventListener('astro:before-swap', cleanupPage);
  </script>
</body>
</html>
