---
import '../styles/global.css';
import Header from '../components/Header.astro';
import HeaderCompact from '../components/HeaderCompact.astro';
import Megamenu from '../components/Megamenu.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Datyca', description = '' } = Astro.props;
---

<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {/* iOS Safari address bar UI when expanded — match the dark page background.
      Defensive: the primary fix for the translucent chrome blur is body's
      dark background in global.css (theme-color does NOT control the
      translucent toolbars). Kept here as an extra hardening layer that
      costs nothing. See .claude/rules/ios-safari.md → "body background MUST
      match the dominant page color". */}
  <meta name="theme-color" content="#0D0826" />
  {description && <meta name="description" content={description} />}
  <link rel="preload" href="/src/fonts/Optik/Optik-DemiBold.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/src/fonts/Optik/Optik-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>

  <Header />
  <HeaderCompact />
  <Megamenu />

  <slot />

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    import '../utils/gsap-debug';

    gsap.registerPlugin(ScrollTrigger, SplitText);
    gsap.config({ nullTargetWarn: false });
    ScrollTrigger.config({ ignoreMobileResize: true });

    /* ── Native-navigation lifecycle ────────────────────────────────
     *  No ClientRouter: every cross-page click is a full reload, so
     *  browser handles scroll restoration (back/forward via bfcache or
     *  native history.scroll) and tears down the JS context on unload.
     *  Our only job is: drain the init queue, refresh ScrollTrigger,
     *  normalize scroll on pin pages, and honor #hash in URLs.
     * ────────────────────────────────────────────────────────────── */

    /* Cross-page navigation with a #hash: browsers try to scroll to the
     * anchor BEFORE ScrollTrigger creates pin-spacers, so the target ends
     * up at the wrong scrollY. Re-apply scrollIntoView AFTER refresh. */
    function scrollToHash() {
      const hash = window.location.hash;
      if (!hash || hash.length < 2) return;
      let target: HTMLElement | null = null;
      try { target = document.querySelector(hash); } catch { /* invalid selector */ }
      if (!target) return;
      target.scrollIntoView({ behavior: 'auto', block: 'start' });
      // Clean the hash from the URL — anchors are navigation aids, not permanent state
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }

    // For same-page anchor clicks (smooth scroll via CSS), clean the hash once scroll settles
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[href*="#"]') as HTMLAnchorElement | null;
      if (!link) return;
      const url = new URL(link.href, window.location.origin);
      // Only same-page anchors
      if (url.pathname !== window.location.pathname || !url.hash) return;
      // Wait for smooth scroll to finish, then strip hash
      setTimeout(() => {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }, 800);
    });

    /* Before the page enters bfcache (fires on unload/navigation), clear the
     * inline styles GSAP applied during hover so they don't freeze into the
     * cached page. Otherwise on back-navigation the browser restores the page
     * from bfcache with purple border/text still applied, making buttons look
     * "stuck hovered" even though the cursor is elsewhere.
     *
     * Scope: only properties commonly used by hover handlers. We don't touch
     * `transform` on non-SVG elements because it's used by pinned content,
     * entrance animations, matrix-based positioning — those should survive
     * bfcache restore. For SVG arrows inside <a>/<button>, we DO clear the
     * inline transform (they use `x: 5` on hover). */
    window.addEventListener('pagehide', () => {
      document.querySelectorAll<HTMLElement>('[style]').forEach(el => {
        el.style.removeProperty('border-color');
        el.style.removeProperty('color');
        el.style.removeProperty('background-color');
      });
      document.querySelectorAll<SVGElement>('a svg[style], button svg[style]').forEach(svg => {
        svg.style.removeProperty('transform');
      });
    });

    function initPage() {
      // Drain queue of init fns registered by component scripts at module scope
      const queue: Array<() => void> = (window as any).__initQueue ?? [];
      for (const fn of queue) {
        try { fn(); } catch (e) { console.error('[init]', e); }
      }
      (window as any).__initQueue = [];

      // Let layout settle (component matchMedia callbacks have created their
      // ScrollTriggers + pin-spacers by now), then refresh and handle scroll.
      requestAnimationFrame(() => {
        ScrollTrigger.refresh();

        // Pin stability: normalizeScroll intercepts native scroll and replaces
        // it with JS-driven scroll. On touch devices this fixes WebKit pin
        // jitter (WebKit #181954). On desktop + snap we use short momentum so
        // snap activates faster (~300ms vs native ~1500ms). Disabled on
        // pin-less pages — intercepting scroll with no benefit just makes
        // scrolling feel slower.
        const hasPins = ScrollTrigger.getAll().some(st => !!st.pin);
        const hasSnap = ScrollTrigger.getAll().some(st => !!(st as any).snap);
        if (hasPins) {
          ScrollTrigger.normalizeScroll(
            ScrollTrigger.isTouch !== 0
              ? true                          // touch: full normalizeScroll
              : hasSnap ? { momentum: 0.3 }   // desktop + snap: short momentum
              : false                          // desktop no snap: native scroll
          );
        }

        // Honor #hash in URL (after pin-spacers are finalized)
        scrollToHash();
      });
    }

    // Module scripts are deferred — they execute after HTML parsing. By the
    // time this code runs, all component <script>s earlier in the bundle have
    // already pushed their init fns into __initQueue. We still guard against
    // 'loading' in case preserveScriptOrder causes an edge case.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPage);
    } else {
      initPage();
    }
  </script>
</body>
</html>
