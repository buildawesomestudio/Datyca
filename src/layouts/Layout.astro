---
import '../styles/global.css';
import Header from '../components/Header.astro';
import HeaderCompact from '../components/HeaderCompact.astro';
import Megamenu from '../components/Megamenu.astro';
import CookieBanner from '../components/CookieBanner.astro';
import LeadMagnetModal from '../components/LeadMagnetModal.astro';
// Import font files to get their hashed, built URLs. Hardcoding '/src/fonts/...'
// in <link rel="preload"> works in `astro dev` (Vite proxy) but 404s in production
// where Astro emits '/_astro/Optik-*.<hash>.woff2'. Using `?url` imports lets Astro
// resolve to the correct path in both modes, and ensures the preload URL matches
// the one resolved from global.css's @font-face (otherwise the preload isn't used).
import optikRegular from '../fonts/Optik/Optik-Regular.woff2?url';
import optikDemiBold from '../fonts/Optik/Optik-DemiBold.woff2?url';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Datyca', description = '' } = Astro.props;
---

<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {/* iOS Safari address bar UI when expanded — match the dark page background.
      Defensive: the primary fix for the translucent chrome blur is body's
      dark background in global.css (theme-color does NOT control the
      translucent toolbars). Kept here as an extra hardening layer that
      costs nothing. See .claude/rules/ios-safari.md → "body background MUST
      match the dominant page color". */}
  <meta name="theme-color" content="#0D0826" />
  {description && <meta name="description" content={description} />}
  <link rel="preload" href={optikDemiBold} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={optikRegular} as="font" type="font/woff2" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {/* Warm up the iubenda CDN connection (DNS + TLS) in advance so that when
      iubenda_cs.js is lazy-loaded post-paint, the handshake is already done. */}
  <link rel="dns-prefetch" href="https://cdn.iubenda.com" />
  <link rel="preconnect" href="https://cdn.iubenda.com" crossorigin />
  <title>{title}</title>

  {/* iubenda Cookie Solution — config MUST be defined before iubenda_cs.js loads.
      All behavioral settings (consent duration, Consent Mode v2, storage, etc.)
      live in the iubenda dashboard, not here — frontend only passes IDs + callbacks.
      Callbacks dispatch custom events consumed by <CookieBanner /> so the UI
      is decoupled from iubenda's internals.
      `banner.customClass` tags iubenda's default banner so we can hide it
      reliably regardless of which banner layout iubenda serves. */}
  <script is:inline>
    window._iub = window._iub || [];
    window._iub.csConfiguration = {
      siteId: 4506676,
      cookiePolicyId: 48742954,
      lang: "it",
      banner: {
        customClass: "datyca-iub-hidden"
      },
      floatingPreferencesButtonDisplay: false,
      floatingPreferencesButtonHover: false,
      floatingPreferencesButtonIcon: false,
      callback: {
        onReady: function () {
          // iubenda's `consentGiven` param is unreliable in v2 (often undefined).
          // Check the SPECIFIC consent cookie instead: `_iub_previous_preference_id`
          // is set only after acceptAll/rejectAll. Other `_iub_*` cookies exist
          // for internal bookkeeping (emitter IDs, etc.) and must NOT be mistaken
          // for expressed consent — a permissive regex would make the banner
          // disappear after one reload even without user action.
          var expressed = document.cookie.indexOf('_iub_previous_preference_id') !== -1;
          // API-state fallback in case iubenda renames the cookie in a future version.
          if (!expressed) {
            try {
              var api = window._iub && window._iub.cs && window._iub.cs.api;
              if (api && api.cs) {
                if (api.cs.state && api.cs.state.consent && api.cs.state.consent.expressed) expressed = true;
                else if (typeof api.cs.isConsentExpressed === 'function' && api.cs.isConsentExpressed()) expressed = true;
              }
            } catch (e) { /* ignore */ }
          }
          window.dispatchEvent(new CustomEvent('datyca:cookie:ready', { detail: { expressed: expressed } }));
        },
        onBannerShown: function () {
          // Defense-in-depth: force-hide iubenda's own banner if it leaks past CSS
          var sels = [
            '#iubenda-cs-banner',
            '.iubenda-cs-container',
            '.iubenda-cs-default-floating',
            '.iubenda-cs-default-fixed',
            '.iub-cn-container',
            '.iubenda-cs-overlay',
            '.datyca-iub-hidden'
          ];
          document.querySelectorAll(sels.join(',')).forEach(function (el) {
            el.style.setProperty('display', 'none', 'important');
          });
        },
        onPreferenceExpressed: function () {
          window.dispatchEvent(new Event('datyca:cookie:preference-expressed'));
        },
        onConsentGiven: function () {
          window.dispatchEvent(new Event('datyca:cookie:consent-given'));
        }
      }
    };
  </script>
  {/* Lazy-load iubenda_cs.js off the critical path. Loading iubenda during the
      initial paint competes with LCP (hero video) for main thread and network.
      Instead we schedule the load for the browser's next idle window after
      DOMContentLoaded — typically ~200ms-1.5s post-paint, completely invisible
      to users but dramatic for hero smoothness.
        - requestIdleCallback: native on Chrome/Firefox/Edge — waits for a frame
          where the main thread is actually free, with a 2500ms hard timeout
          so heavy pages can't starve it indefinitely.
        - setTimeout fallback: Safari doesn't ship requestIdleCallback. A fixed
          800ms after DOMContentLoaded is a safe heuristic — long enough for
          the hero to settle, short enough that the banner still feels prompt.
      Consent Mode v2 (configured in iubenda dashboard) ensures trackers stay
      blocked until consent arrives, regardless of when the banner renders.
      Preconnect link above keeps the TLS handshake cost off the critical path. */}
  <script is:inline>
    (function () {
      function loadIubenda() {
        var s = document.createElement('script');
        s.src = 'https://cdn.iubenda.com/cs/iubenda_cs.js';
        s.async = true;
        document.head.appendChild(s);
      }
      function schedule() {
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadIubenda, { timeout: 2500 });
        } else {
          setTimeout(loadIubenda, 800);
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', schedule, { once: true });
      } else {
        schedule();
      }
    })();
  </script>

  {/* Eliminate FOUC: iubenda_cs.js is async, so the default banner may render
      for 1-2 frames before our CSS/customClass hide kicks in. A MutationObserver
      installed NOW (before iubenda has a chance to inject anything) flags the
      banner nodes with display:none the moment they enter the DOM, preventing
      the flash. Scoped strictly to banner selectors — the preferences modal
      (opened manually via openPreferences) has different selectors and is
      unaffected. */}
  <script is:inline>
    (function () {
      var bannerSelectors = [
        '#iubenda-cs-banner',
        '.datyca-iub-hidden',
        '.iubenda-cs-default-floating',
        '.iubenda-cs-default-fixed',
        '.iub-cn-container',
        '.iubenda-tp-btn',
        '#iubFloatingButton'
      ];
      var mo = null;
      var caught = false;
      function hideIubBanners() {
        for (var i = 0; i < bannerSelectors.length; i++) {
          var nodes = document.querySelectorAll(bannerSelectors[i]);
          for (var j = 0; j < nodes.length; j++) {
            nodes[j].style.setProperty('display', 'none', 'important');
            caught = true;
          }
        }
        // Stop observing once we've hidden at least one banner — iubenda won't
        // re-inject after that, and we want to avoid MO overhead during hero
        // animations (Lottie/GSAP mutate DOM heavily during initial paint).
        // Give it a small grace window in case iubenda injects additional nodes.
        if (caught && mo) {
          setTimeout(function () { if (mo) { mo.disconnect(); mo = null; } }, 500);
        }
      }
      if (window.MutationObserver) {
        mo = new MutationObserver(hideIubBanners);
        var start = function () {
          if (document.body && mo) {
            mo.observe(document.body, { childList: true, subtree: true });
            hideIubBanners();
            // Fail-safe: if iubenda never loads (network error, ad-blocker,
            // offline), kill the observer after 10s so it doesn't run forever
            // during Lottie/GSAP animations and battery-drain mobile devices.
            setTimeout(function () {
              if (!caught && mo) { mo.disconnect(); mo = null; }
            }, 10000);
          }
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start);
        } else {
          start();
        }
      }
    })();
  </script>

  {/* Static fallback: same selectors hidden via CSS, in case the observer
      misses a variant. Surgical (banner only, not preferences modal). */}
  <style is:global>
    .datyca-iub-hidden,
    #iubenda-cs-banner,
    .iubenda-cs-default-floating,
    .iubenda-cs-default-fixed,
    .iub-cn-container,
    .iubenda-tp-btn,
    .iub-cs-wizard,
    #iubFloatingButton {
      display: none !important;
    }
  </style>
</head>
<body>

  <Header />
  <HeaderCompact />
  <Megamenu />

  <slot />

  <CookieBanner />
  <LeadMagnetModal />

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    import '../utils/gsap-debug';

    gsap.registerPlugin(ScrollTrigger, SplitText);
    gsap.config({ nullTargetWarn: false });
    ScrollTrigger.config({ ignoreMobileResize: true });

    /* ── Native-navigation lifecycle ────────────────────────────────
     *  No ClientRouter: every cross-page click is a full reload, so
     *  browser handles scroll restoration (back/forward via bfcache or
     *  native history.scroll) and tears down the JS context on unload.
     *  Our only job is: drain the init queue, refresh ScrollTrigger,
     *  normalize scroll on pin pages, and honor #hash in URLs.
     * ────────────────────────────────────────────────────────────── */

    /* Compute scroll destination for an anchor target.
     *   - If target has data-scroll-align="section-end": align the BOTTOM of
     *     the closest <section> with the viewport bottom (used when the anchor
     *     heading sits near the end of a section — a normal top-align anchor
     *     would leave empty space below). Clamped to valid scroll range.
     *   - Otherwise: align target's top with viewport top (native behavior). */
    function computeAnchorScrollTop(target: HTMLElement): number | null {
      if (target.dataset.scrollAlign === 'section-end') {
        const section = target.closest('section') ?? target;
        const sectionBottom = section.getBoundingClientRect().bottom + window.scrollY;
        return Math.max(0, sectionBottom - document.documentElement.clientHeight);
      }
      return null; // signal: use native scrollIntoView
    }

    /* Cross-page navigation with a #hash: browsers try to scroll to the
     * anchor BEFORE ScrollTrigger creates pin-spacers, so the target ends
     * up at the wrong scrollY. Re-apply scrollIntoView AFTER refresh. */
    function scrollToHash() {
      const hash = window.location.hash;
      if (!hash || hash.length < 2) return;
      let target: HTMLElement | null = null;
      try { target = document.querySelector(hash); } catch { /* invalid selector */ }
      if (!target) return;
      const customTop = computeAnchorScrollTop(target);
      if (customTop !== null) {
        window.scrollTo({ top: customTop, behavior: 'auto' });
      } else {
        target.scrollIntoView({ behavior: 'auto', block: 'start' });
      }
      // Clean the hash from the URL — anchors are navigation aids, not permanent state
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }

    // For same-page anchor clicks (smooth scroll via CSS), clean the hash once scroll settles
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[href*="#"]') as HTMLAnchorElement | null;
      if (!link) return;
      const url = new URL(link.href, window.location.origin);
      // Only same-page anchors
      if (url.pathname !== window.location.pathname || !url.hash) return;
      // If the target has a custom scroll-align mode, override native anchor behavior
      let target: HTMLElement | null = null;
      try { target = document.querySelector(url.hash); } catch { /* invalid selector */ }
      const customTop = target ? computeAnchorScrollTop(target) : null;
      if (customTop !== null) {
        e.preventDefault();
        window.scrollTo({ top: customTop, behavior: 'smooth' });
      }
      // Wait for smooth scroll to finish, then strip hash
      setTimeout(() => {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }, 800);
    });

    /* Clean GSAP hover inline styles before the page is cached (bfcache) so
     * they don't persist on back-navigation restore, leaving buttons looking
     * "stuck hovered" even though the cursor is elsewhere.
     *
     * Why we clean at BOTH click-time AND pagehide:
     *   1. Click: runs synchronously before navigation starts, so the state
     *      captured by bfcache is clean even on browsers (Safari) that snapshot
     *      early in the unload sequence.
     *   2. pagehide: safety net for navigation triggered outside our click
     *      handler (browser back/forward, tab close, location.href=).
     *
     * Why killTweensOf: if the user clicks while a mouseenter tween is still
     * in-flight (hover animation not yet complete), simply removing the inline
     * style doesn't help — the tween continues and re-applies the style on the
     * next tick, freezing that state into the cache. Kill the tweens targeting
     * just the relevant properties first, then clear.
     *
     * Scope: only properties commonly used by hover handlers. We don't touch
     * `transform` on non-SVG elements because it's used by pinned content,
     * entrance animations, matrix-based positioning. For SVG arrows inside
     * <a>/<button>, we DO clear the inline transform (they use `x: 5` on hover). */
    function cleanHoverStyles() {
      document.querySelectorAll<HTMLElement>('[style]').forEach(el => {
        gsap.killTweensOf(el, 'borderColor,color,backgroundColor');
        el.style.removeProperty('border-color');
        el.style.removeProperty('color');
        el.style.removeProperty('background-color');
      });
      document.querySelectorAll<SVGElement>('a svg[style], button svg[style]').forEach(svg => {
        gsap.killTweensOf(svg, 'x,y,transform');
        svg.style.removeProperty('transform');
      });
    }

    // 1. Click on internal link → clean BEFORE navigation → bfcache captures clean state
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[href]') as HTMLAnchorElement | null;
      if (!link) return;
      try {
        const url = new URL(link.href, window.location.origin);
        if (url.origin !== window.location.origin) return;      // external
        if (url.pathname === window.location.pathname) return;  // same-page (hash anchor)
        cleanHoverStyles();
      } catch { /* malformed URL */ }
    }, true);  // capture phase so we run before any link handler

    // 2. Safety net for back/forward & tab close
    window.addEventListener('pagehide', cleanHoverStyles);

    function initPage() {
      // Drain queue of init fns registered by component scripts at module scope
      const queue: Array<() => void> = (window as any).__initQueue ?? [];
      for (const fn of queue) {
        try { fn(); } catch (e) { console.error('[init]', e); }
      }
      (window as any).__initQueue = [];

      // Let layout settle (component matchMedia callbacks have created their
      // ScrollTriggers + pin-spacers by now), then refresh and handle scroll.
      requestAnimationFrame(() => {
        ScrollTrigger.refresh();

        // Pin stability: normalizeScroll intercepts native scroll and replaces
        // it with JS-driven scroll. On touch devices this fixes WebKit pin
        // jitter (WebKit #181954). On desktop + snap we use short momentum so
        // snap activates faster (~300ms vs native ~1500ms). Disabled on
        // pin-less pages — intercepting scroll with no benefit just makes
        // scrolling feel slower.
        const hasPins = ScrollTrigger.getAll().some(st => !!st.pin);
        const hasSnap = ScrollTrigger.getAll().some(st => !!(st as any).snap);
        if (hasPins) {
          ScrollTrigger.normalizeScroll(
            ScrollTrigger.isTouch !== 0
              ? true                          // touch: full normalizeScroll
              : hasSnap ? { momentum: 0.3 }   // desktop + snap: short momentum
              : false                          // desktop no snap: native scroll
          );
        }

        // Honor #hash in URL (after pin-spacers are finalized)
        scrollToHash();
      });
    }

    // Module scripts are deferred — they execute after HTML parsing. By the
    // time this code runs, all component <script>s earlier in the bundle have
    // already pushed their init fns into __initQueue. We still guard against
    // 'loading' in case preserveScriptOrder causes an edge case.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPage);
    } else {
      initPage();
    }
  </script>
</body>
</html>
