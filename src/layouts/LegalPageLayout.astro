---
import Layout from './Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Contatti from '../components/Contatti.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  breadcrumbLabel: string;
}

const { title, description, heroTitle, heroSubtitle, breadcrumbLabel } = Astro.props;
---

<Layout title={title} description={description}>
  <main>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: breadcrumbLabel },
      ]}
    />

    {/* DARK HERO — title in brand magenta (#F21763), white italic subtitle */}
    <section class="legal-hero">
      <h1 class="text-hero legal-hero__title">{heroTitle}</h1>
      <p class="legal-hero__subtitle">{heroSubtitle}</p>
    </section>

    {/* LIGHT CONTENT AREA — legal document style */}
    <div class="legal-light">
      <div class="legal-content">
        <slot />
      </div>
    </div>

    <Contatti />
  </main>
</Layout>

<style is:global>
  /* `is:global` is mandatory here. Astro's scoped CSS applies the layout's
     data-astro-cid only to elements written inside this layout's template
     — NOT to slot content. Most `.legal-*` classes (anchor-nav, section,
     divider, contact-box, treatment) live in the slot (= page markup) and
     carry the *page's* astro-cid, not this layout's, so a scoped selector
     like `.legal-section[data-astro-cid-XXX]` would never match.
     `is:global` removes the scope; safe because `.legal-*` is a dedicated
     namespace used only by the legal pages.

     Local light-theme palette (legal document readability). Defined on the
     light wrap + content so children inherit the vars naturally; values
     are also available to page-scoped classes (`.legal-table`,
     `.legal-retention`...) via CSS custom-property inheritance. */
  .legal-light,
  .legal-content {
    --pp-text:        #2A2A2A;
    --pp-text-light:  #555555;
    --pp-light-gray:  #E1E1E1;
    --pp-row-stripe:  #F8F8FC;
    --pp-blue-tint:   #F0F0FF;
    --pp-bg:          var(--color-white-snow);
    --pp-white:       #FFFFFF;
  }

  /* ── DARK HERO ──────────────────────────────────────────────── */
  .legal-hero {
    text-align: center;
    padding: clamp(40px, 6vw, 64px) var(--section-padding-x) clamp(48px, 7vw, 72px);
    background: var(--color-bg);
  }
  .legal-hero__title {
    color: var(--color-red);
    margin-bottom: 12px;
  }
  .legal-hero__subtitle {
    font-family: var(--font-serif);
    color: var(--color-white-almost);
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 24px);
    line-height: 1.4;
    letter-spacing: -0.04em;
  }

  /* ── LIGHT WRAP ─────────────────────────────────────────────── */
  .legal-light {
    background: var(--pp-bg);
    color: var(--pp-text);
  }
  .legal-content {
    max-width: 820px;
    margin-inline: auto;
    padding: clamp(48px, 6vw, 80px) clamp(20px, 4vw, 40px) clamp(64px, 8vw, 100px);
  }

  /* ── ANCHOR NAV ─────────────────────────────────────────────── */
  .legal-anchor-nav {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-radius: 12px;
    padding: clamp(24px, 3vw, 36px);
    margin-bottom: clamp(40px, 5vw, 56px);
  }
  .legal-anchor-nav__title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-grey-400);
    margin-bottom: 16px;
  }
  .legal-anchor-nav__list {
    list-style: none;
    counter-reset: pp-nav;
    columns: 2;
    column-gap: 40px;
    padding: 0;
    margin: 0;
  }
  .legal-anchor-nav__item {
    counter-increment: pp-nav;
    margin-bottom: 8px;
    break-inside: avoid;
  }
  .legal-anchor-nav__item a {
    color: var(--pp-text);
    text-decoration: none;
    font-size: 15px;
    display: block;
    padding: 4px 0;
    transition: color 0.2s var(--ease-signature);
  }
  .legal-anchor-nav__item a::before {
    content: counter(pp-nav) ". ";
    color: var(--color-purple-500);
    font-weight: 600;
    margin-right: 4px;
  }
  .legal-anchor-nav__item a:hover {
    color: var(--color-purple-500);
  }

  /* ── DIVIDER ───────────────────────────────────────────────── */
  .legal-divider {
    border: none;
    border-top: 1px solid var(--pp-light-gray);
    margin: 0 0 clamp(40px, 5vw, 52px);
  }

  /* ── SECTIONS ──────────────────────────────────────────────── */
  .legal-section {
    margin-bottom: clamp(40px, 5vw, 52px);
    /* Header is fixed (~120px desktop / 80px mobile) — push anchor jumps below it */
    scroll-margin-top: 140px;
  }
  .legal-section__num {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-purple-500);
    margin-bottom: 8px;
  }
  .legal-section__title {
    font-family: var(--font-sans);
    font-size: clamp(22px, 2.4vw, 26px);
    font-weight: 600;
    color: var(--color-black-almost-900);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .legal-section p {
    font-size: clamp(15px, 1.1vw, 16px);
    color: var(--pp-text-light);
    margin-bottom: 14px;
    line-height: 1.75;
  }
  .legal-section p strong {
    color: var(--pp-text);
    font-weight: 600;
  }
  .legal-section a {
    color: var(--color-purple-500);
    text-decoration: none;
    font-weight: 500;
  }
  .legal-section a:hover { text-decoration: underline; }

  /* ── CONTACT BOX ───────────────────────────────────────────── */
  .legal-contact-box {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-left: 4px solid var(--color-purple-500);
    border-radius: 0 8px 8px 0;
    padding: 20px 24px;
    margin: 16px 0 20px;
  }
  .legal-contact-box p {
    margin-bottom: 4px;
    font-size: 15px;
  }
  .legal-contact-box p:last-child { margin-bottom: 0; }

  /* ── TREATMENT BLOCKS ──────────────────────────────────────── */
  .legal-treatment {
    background: var(--pp-white);
    border: 1px solid var(--pp-light-gray);
    border-radius: 12px;
    padding: clamp(20px, 2.5vw, 28px) clamp(20px, 3vw, 32px);
    margin: 20px 0;
  }
  .legal-treatment__title {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-black-almost-900);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .legal-treatment__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-purple-500);
    flex-shrink: 0;
  }
  .legal-treatment p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--pp-text-light);
    margin-bottom: 10px;
  }
  .legal-treatment p:last-child { margin-bottom: 0; }
  .legal-treatment__legal {
    font-size: 13px !important;
    color: var(--color-grey-400) !important;
    font-style: italic;
    margin-top: 8px;
    margin-bottom: 0 !important;
  }

  /* ── MOBILE ────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .legal-section {
      scroll-margin-top: 100px;
    }
    .legal-anchor-nav__list {
      columns: 1;
    }
  }
</style>
