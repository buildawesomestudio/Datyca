---
const sedi = [
  { city: 'Palermo', address: 'Via Principe di Belmonte, 101', href: 'https://maps.app.goo.gl/rN8tKF9DiP8kpdCK9' },
  { city: 'Milano', address: 'Via Monte Rosa, 21', href: 'https://maps.app.goo.gl/YUbD2QCikD3WygVc7' },
  { city: 'Roma', address: 'Via Giuseppe Pisanelli, 1', href: 'https://maps.app.goo.gl/kvgE5BPMKDGFuqpCA' },
];

const footerLinksLeft = [
  { label: 'Chi siamo', href: '/#hero' },
  { label: 'AI Governance', href: '/#ai-governance' },
  { label: 'Servizi', href: '/#cosa-facciamo' },
  { label: 'Il nostro impatto', href: '/#il-nostro-impatto' },
  { label: 'Risorse', href: '/risorse' },
];

const footerLinksRight = [
  { label: 'info@datyca.com', href: 'mailto:info@datyca.com' },
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'AI Policy', href: '/ai-policy' },
  { label: 'Cookie Policy', href: 'https://www.iubenda.com/privacy-policy/48742954/cookie-policy', external: true },
  { label: 'Preferenze cookie', href: '#', preferences: true },
];

const socialLinks = [
  { label: 'LinkedIn',  icon: 'icon-linkedin',  href: 'https://www.linkedin.com/company/datyca-legal-design-lab/' },
  { label: 'Facebook',  icon: 'icon-facebook',  href: 'https://www.facebook.com/profile.php?id=61564593341545' },
  { label: 'Instagram', icon: 'icon-instagram', href: '#', disabled: true },
  { label: 'YouTube',   icon: 'icon-youtube',   href: 'https://www.youtube.com/@datyca' },
];
---

<section id="contatti" class="contatti">
  <div class="contatti__inner">
    <h2 class="text-h2 contatti__title">Contatti</h2>

    <div class="contatti__grid">
      <!-- Left: Sedi -->
      <div class="contatti__info">
        <p class="text-para-title contatti__sedi-label">Le nostre sedi</p>
        <div class="contatti__sedi-list">
          {sedi.map(({ city, address, href }) => (
            <div class="contatti__sede">
              <p class="text-para-title contatti__sede-city">{city}</p>
              <a href={href} target="_blank" rel="noopener noreferrer" class="contatti__sede-address" data-contatti-address>{address}</a>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Form -->
      <form class="contatti__form" novalidate>
        <!-- Honeypot — hidden from humans, bots fill it -->
        <div class="contatti__hp" aria-hidden="true">
          <label for="contatti-website">Website</label>
          <input type="text" id="contatti-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="contatti__field">
          <label for="contatti-nome" class="sr-only">Nome</label>
          <input
            type="text"
            id="contatti-nome"
            name="nome"
            class="contatti__input"
            placeholder="Nome*"
            maxlength="100"
            autocomplete="name"
          />
          <span class="contatti__error"></span>
        </div>

        <div class="contatti__row">
          <div class="contatti__field contatti__field--half">
            <label for="contatti-email" class="sr-only">Email</label>
            <input
              type="email"
              id="contatti-email"
              name="email"
              class="contatti__input"
              placeholder="Email*"
              autocomplete="email"
            />
            <span class="contatti__error"></span>
          </div>
          <div class="contatti__field contatti__field--half">
            <label for="contatti-oggetto" class="sr-only">Oggetto</label>
            <div class="contatti__select-wrap">
              <select
                id="contatti-oggetto"
                name="oggetto"
                class="contatti__input contatti__select"
              >
                <option value="" disabled selected>Oggetto*</option>
                <option value="info">Informazioni generali</option>
                <option value="collaborazione">Collaborazione</option>
                <option value="consulenza">Consulenza</option>
                <option value="altro">Altro</option>
              </select>
              <svg class="contatti__select-icon" width="12" height="12" aria-hidden="true"><use href="#icon-chevron-down" /></svg>
            </div>
            <span class="contatti__error"></span>
          </div>
        </div>

        <div class="contatti__field">
          <label for="contatti-messaggio" class="sr-only">Messaggio</label>
          <textarea
            id="contatti-messaggio"
            name="messaggio"
            class="contatti__input contatti__textarea"
            placeholder="Messaggio* (min. 10 caratteri)"
            rows="5"
            maxlength="2000"
            autocomplete="off"
          ></textarea>
          <span class="contatti__error"></span>
        </div>

        <div class="contatti__consents">
          <div class="contatti__consent-wrap" data-contatti-privacy-wrap>
            <label class="contatti__consent">
              <input type="checkbox" name="consent_privacy" data-contatti-privacy required />
              <span class="contatti__consent-text">
                Ho preso visione della
                <a href="/privacy-policy" target="_blank" rel="noopener noreferrer" data-contatti-privacy-link>Privacy Policy</a>
                e acconsento al trattamento dei miei dati per essere ricontattato/a in merito alla mia richiesta.
                <span class="contatti__required" aria-hidden="true">*</span>
              </span>
            </label>
            <span class="contatti__consent-error" data-contatti-privacy-error></span>
          </div>

          <label class="contatti__consent">
            <input type="checkbox" name="consent_marketing" />
            <span class="contatti__consent-text">
              Voglio ricevere aggiornamenti e approfondimenti di DATYCA su AI Governance, data protection e cybersecurity. Posso revocare il consenso in qualsiasi momento dal link di disiscrizione presente in ogni email.
            </span>
          </label>
        </div>

        <!-- Turnstile widget container -->
        <div id="contatti-turnstile" class="contatti__turnstile"></div>

        <div class="contatti__submit-row">
          <button type="button" class="contatti__submit text-cta" data-contatti-submit>
            <span data-contatti-submit-label>INVIA</span>
            <svg class="contatti__submit-arrow" width="24" height="24" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
            <svg class="contatti__submit-spinner" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-dasharray="50 20" stroke-linecap="round" />
            </svg>
          </button>
        </div>
        <p class="contatti__form-status" data-contatti-status></p>
      </form>
    </div>

    <hr class="contatti__separator" />

    <footer class="contatti__footer">
      <div class="contatti__footer-links">
        <nav class="contatti__footer-col">
          {footerLinksLeft.map(({ label, href }) => (
            <a href={href} class="contatti__footer-link" data-contatti-footer-link>{label}</a>
          ))}
        </nav>
        <div class="contatti__footer-col">
          {footerLinksRight.map(({ label, href, external, preferences }) => (
            <a
              href={href}
              class="contatti__footer-link"
              data-contatti-footer-link
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              {...(preferences ? { 'data-cookie-preferences': '' } : {})}
            >{label}</a>
          ))}
        </div>
      </div>

      <div class="contatti__social" data-contatti-social>
        {socialLinks.map(({ label, icon, href, disabled }) => (
          <a
            href={href}
            class="contatti__social-link"
            data-contatti-social-link
            aria-label={disabled ? `${label} (in arrivo)` : label}
            {...(disabled
              ? { 'aria-disabled': 'true', tabindex: -1, 'data-social-disabled': '' }
              : { target: '_blank', rel: 'noopener noreferrer' })}
          >
            <svg class="contatti__social-icon" width="22" height="22" aria-hidden="true"><use href={`#${icon}`} /></svg>
          </a>
        ))}
      </div>

      <div class="contatti__bottom">
        <a href="/" class="contatti__logo-link">
          <img
            src="/images/logo-full_dark.svg"
            alt="Datyca - Legal Design Lab"
            class="contatti__logo"
            width="193"
            height="60"
          />
        </a>
        <p class="contatti__copyright">
          &copy; 2026 DATYCA Legal Design Lab S.r.l. &mdash; P.IVA 06954020829
        </p>
      </div>
    </footer>
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .contatti {
    --_pad-x: clamp(40px, 10.9vw, 157px);
    background: var(--color-white-snow);
    color: var(--color-black-almost-900);
    position: relative;
  }

  .contatti__inner {
    max-width: 1440px;
    margin-inline: auto;
  }

  /* ── Title ── */
  .contatti__title {
    padding: var(--section-padding-y) var(--_pad-x) 0;
  }

  /* ── Grid ── */
  .contatti__grid {
    display: flex;
    justify-content: space-between;
    padding: 60px var(--_pad-x) 0;
    gap: clamp(40px, 6vw, 80px);
  }

  /* ── Left: Info / Sedi ── */
  .contatti__info {
    width: 277px;
    flex-shrink: 0;
  }

  .contatti__sedi-label {
    margin-bottom: 40px;
  }

  .contatti__sedi-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contatti__sede-address {
    display: block;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    line-height: 20px;
    color: var(--color-purple-500);
    text-decoration: none;
  }

  /* ── Right: Form ── */
  .contatti__form {
    flex: 1;
    max-width: 660px;
    display: flex;
    flex-direction: column;
  }

  /* Borders on field containers, NOT on inputs */
  .contatti__field {
    border: 2px solid var(--color-black-almost-900);
  }

  /* Collapse vertical borders between stacked fields */
  .contatti__field + .contatti__row,
  .contatti__row + .contatti__field {
    margin-top: -2px;
  }

  .contatti__input {
    width: 100%;
    border: none;
    padding: 21px 20px 21px 25px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 20px;
    line-height: 28px;
    background: transparent;
    color: var(--color-black-almost-900);
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
  }

  .contatti__input::placeholder {
    color: var(--color-black-almost-900);
  }

  /* Reserve space on the right of the email input for password-manager
     autofill badges (1Password, iCloud Keychain, Bitwarden). Without this,
     the badge overlays the text or resizes the input on focus, causing a
     visible layout shift when the modal/form first gets focus. */
  .contatti__input[type="email"] {
    padding-right: 48px;
  }

  .contatti__input:-webkit-autofill,
  .contatti__input:-webkit-autofill:hover,
  .contatti__input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px var(--color-white-snow) inset;
    -webkit-text-fill-color: var(--color-black-almost-900);
  }

  .contatti__row {
    display: flex;
  }

  .contatti__field--half {
    flex: 1;
    position: relative; /* chevron positioning */
  }

  /* Collapse horizontal border between half fields */
  .contatti__field--half + .contatti__field--half {
    border-left: none;
  }

  /* Textarea */
  .contatti__textarea {
    min-height: 200px;
    resize: vertical;
  }

  /* Select */
  .contatti__select-wrap {
    position: relative;
  }

  .contatti__select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 50px;
    cursor: pointer;
  }

  /* Placeholder-like style for unselected state */
  .contatti__select:invalid {
    color: var(--color-black-almost-900);
  }

  .contatti__select-icon {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--color-black-almost-900);
  }

  /* Submit button */
  .contatti__submit {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    background: var(--color-purple-500);
    color: var(--color-white-almost);
    border: none;
    padding: 18px 20px 18px 25px;
    cursor: pointer;
    border-radius: 0;
  }

  .contatti__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  /* ── Honeypot (invisible to humans) ── */
  .contatti__hp {
    position: absolute;
    left: -9999px;
    height: 0;
    overflow: hidden;
  }

  /* ── Turnstile ──
     The widget is invisible by default — only when Cloudflare escalates
     to an interactive challenge does it become visible. The container
     stays clipped to 0 height regardless of whether the iframe is mounted
     (height:0 + overflow:hidden), so the submit button never shifts down
     during the ~1.5s the widget runs the invisible challenge. `is-visible`
     is toggled on/off by Turnstile's before-/after-interactive-callback
     only for the ~10% of users that get a "Verify you are human" checkbox
     — only that case justifies the form growing. Iframe stays alive (just
     visually clipped) so the challenge runs in either path. */
  .contatti__turnstile {
    align-self: flex-end;
    height: 0;
    margin: 0;
    overflow: hidden;
  }
  .contatti__turnstile.is-visible {
    height: auto;
    margin-top: 12px;
    overflow: visible;
  }

  /* ── Submit row ── */
  .contatti__submit-row {
    align-self: flex-end;
    margin-top: 20px;
  }

  /* ── Spinner ── */
  .contatti__submit-spinner {
    display: none;
  }

  .contatti__submit--sending .contatti__submit-arrow {
    display: none;
  }

  .contatti__submit--sending .contatti__submit-spinner {
    display: block;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Form status message ── */
  .contatti__form-status {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 20px;
    margin: 10px 0 0;
    text-align: right;
    min-height: 20px;
  }

  .contatti__form-status--success {
    color: #16a34a;
  }

  .contatti__form-status--error {
    color: var(--color-red);
  }

  /* ── Errors ── */
  .contatti__error {
    display: none;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 20px;
    color: var(--color-red);
    padding: 6px 0 8px 25px;
  }

  .contatti__field--error {
    border-color: var(--color-red);
    position: relative;
    z-index: 1;
  }


  .contatti__field--error .contatti__error {
    display: block;
  }

  /* ── Consents (privacy + marketing) ── */
  .contatti__consents {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 20px;
  }

  .contatti__required {
    color: var(--color-purple-500);
  }

  .contatti__consent {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }

  /* Branded checkbox: 2px black border, zero radius, purple fill when checked.
     Mirrors the input field aesthetic — no native OS widget look. */
  .contatti__consent input[type="checkbox"] {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin: 2px 0 0;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 2px solid var(--color-black-almost-900);
    border-radius: 0;
    cursor: pointer;
    position: relative;
    display: grid;
    place-content: center;
    padding: 0;
  }

  .contatti__consent input[type="checkbox"]:checked {
    background: var(--color-purple-500);
    border-color: var(--color-purple-500);
  }

  .contatti__consent input[type="checkbox"]:checked::after {
    content: '';
    width: 10px;
    height: 5px;
    border-left: 2px solid var(--color-white-almost);
    border-bottom: 2px solid var(--color-white-almost);
    transform: translate(0, -2px) rotate(-45deg);
  }

  .contatti__consent input[type="checkbox"]:focus-visible {
    border-color: var(--color-purple-500);
  }

  .contatti__consent-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contatti__consent-error {
    display: none;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-red);
    padding-left: 32px;
  }

  .contatti__consent-wrap--error .contatti__consent input[type="checkbox"] {
    border-color: var(--color-red);
  }

  .contatti__consent-wrap--error .contatti__consent-error {
    display: block;
  }

  .contatti__consent-text {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-black-almost-900);
  }

  .contatti__consent-text a {
    color: var(--color-purple-500);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }

  /* ── Separator ── */
  .contatti__separator {
    border: none;
    border-top: 2px solid var(--color-grey-toned-600);
    margin: 100px var(--_pad-x);
  }

  /* ── Footer ── */
  .contatti__footer-links {
    display: flex;
    gap: clamp(80px, 16vw, 233px);
    padding: 0 var(--_pad-x);
  }

  .contatti__footer-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contatti__footer-link {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    line-height: 24px;
    color: var(--color-black-almost-900);
    text-decoration: none;
  }

  /* ── Social row ── */
  .contatti__social {
    display: flex;
    gap: 24px;
    justify-content: flex-end;
    padding: 40px var(--_pad-x) 0;
  }

  .contatti__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-black-almost-900);
    text-decoration: none;
  }

  .contatti__social-icon {
    width: 22px;
    height: 22px;
  }

  /* ── Bottom bar ── */
  .contatti__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 40px var(--_pad-x) 60px;
  }

  .contatti__logo {
    width: 193px;
    height: 60px;
  }

  .contatti__copyright {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 14px;
    line-height: 24px;
    color: var(--color-black-almost-900);
    text-align: right;
  }

  @media (max-width: 1023px) {
    .contatti {
      --_pad-x: var(--section-padding-x);
    }
    .contatti__grid {
      flex-direction: column;
      gap: 40px;
    }
    .contatti__form {
      order: -1;
      max-width: none;
    }
    .contatti__info {
      width: 100%;
    }
    .contatti__sedi-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .contatti__row {
      flex-direction: column;
    }
    .contatti__field--half + .contatti__field--half {
      border-left: 2px solid var(--color-black-almost-900);
      margin-top: -2px;
    }
    .contatti__textarea {
      min-height: 150px;
    }
    .contatti__submit-row {
      align-self: flex-end;
    }
    .contatti__separator {
      margin: 60px var(--_pad-x);
    }
    .contatti__footer-links {
      gap: 20px;
      padding-left: var(--_pad-x);
    }
    .contatti__footer-col {
      flex: 1;
    }
    .contatti__social {
      justify-content: flex-start;
      padding-left: var(--_pad-x);
    }
    .contatti__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding-left: var(--_pad-x);
    }
    .contatti__copyright {
      text-align: left;
    }
    .contatti__input {
      font-size: 17px;
      padding: 16px 16px 16px 20px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initContatti() {
    const section = document.getElementById('contatti');
    if (!section) return;

    let hasRevealed = false;

    function setup() {
      const ac = new AbortController();

      const title = section.querySelector('.contatti__title') as HTMLElement;
      const sediLabel = section.querySelector('.contatti__sedi-label') as HTMLElement;
      const sedi = section.querySelectorAll<HTMLElement>('.contatti__sede');
      const fields = section.querySelectorAll<HTMLElement>('.contatti__field, .contatti__row, .contatti__consents');
      const privacyWrap = section.querySelector('[data-contatti-privacy-wrap]') as HTMLElement | null;
      const privacyCb = section.querySelector('[data-contatti-privacy]') as HTMLInputElement | null;
      const privacyErr = section.querySelector('[data-contatti-privacy-error]') as HTMLElement | null;
      const submitBtn = section.querySelector('[data-contatti-submit]') as HTMLElement;
      const separator = section.querySelector('.contatti__separator') as HTMLElement;
      const footerLinks = section.querySelectorAll<HTMLAnchorElement>('[data-contatti-footer-link]');
      const socialLinks = section.querySelectorAll<HTMLAnchorElement>('[data-contatti-social-link]');
      const bottom = section.querySelector('.contatti__bottom') as HTMLElement;
      const form = section.querySelector('.contatti__form') as HTMLFormElement;
      const addresses = section.querySelectorAll<HTMLAnchorElement>('[data-contatti-address]');

      // ── Reveal animation ──
      if (hasRevealed) {
        gsap.set(title, { autoAlpha: 1 });
        gsap.set(sediLabel, { autoAlpha: 1, y: 0 });
        gsap.set(sedi, { autoAlpha: 1, y: 0 });
        gsap.set(fields, { autoAlpha: 1, y: 0 });
        gsap.set(submitBtn, { autoAlpha: 1, y: 0 });
        gsap.set(separator, { scaleX: 1 });
        gsap.set(footerLinks, { autoAlpha: 1, y: 0 });
        gsap.set(socialLinks, { autoAlpha: 1, y: 0 });
        gsap.set(bottom, { autoAlpha: 1 });
      } else {
        gsap.set(title, { autoAlpha: 0 });
        gsap.set(sediLabel, { autoAlpha: 0, y: 20 });
        gsap.set(sedi, { autoAlpha: 0, y: 15 });
        gsap.set(fields, { autoAlpha: 0, y: 20 });
        gsap.set(submitBtn, { autoAlpha: 0, y: 15 });
        gsap.set(separator, { scaleX: 0, transformOrigin: 'left center' });
        gsap.set(footerLinks, { autoAlpha: 0, y: 15 });
        gsap.set(socialLinks, { autoAlpha: 0, y: 15 });
        gsap.set(bottom, { autoAlpha: 0 });

        const titleSplit = SplitText.create(title, { type: 'words', aria: 'none' });
        gsap.set(titleSplit.words, { autoAlpha: 0, y: 25 });
        gsap.set(title, { autoAlpha: 1 });

        const revealTl = gsap.timeline({ paused: true });

        // Title words
        revealTl.to(titleSplit.words, {
          autoAlpha: 1, y: 0,
          duration: 0.7, stagger: 0.12,
          ease: 'power2.out',
        }, 0);

        // "Le nostre sedi"
        revealTl.to(sediLabel, {
          autoAlpha: 1, y: 0,
          duration: 0.6, ease: 'power2.out',
        }, 0.2);

        // Cities
        revealTl.to(sedi, {
          autoAlpha: 1, y: 0,
          duration: 0.5, stagger: 0.1,
          ease: 'power2.out',
        }, 0.3);

        // Form fields
        revealTl.to(fields, {
          autoAlpha: 1, y: 0,
          duration: 0.5, stagger: 0.1,
          ease: 'power2.out',
        }, 0.2);

        // Submit button
        revealTl.to(submitBtn, {
          autoAlpha: 1, y: 0,
          duration: 0.5, ease: 'power2.out',
        }, 0.5);

        // Separator
        revealTl.to(separator, {
          scaleX: 1,
          duration: 0.8, ease: 'power2.out',
        }, 0.7);

        // Footer links
        revealTl.to(footerLinks, {
          autoAlpha: 1, y: 0,
          duration: 0.4, stagger: 0.06,
          ease: 'power2.out',
        }, 0.85);

        // Social icons
        revealTl.to(socialLinks, {
          autoAlpha: 1, y: 0,
          duration: 0.4, stagger: 0.05,
          ease: 'power2.out',
        }, 1.0);

        // Bottom bar
        revealTl.to(bottom, {
          autoAlpha: 1,
          duration: 0.5, ease: 'power2.out',
        }, 1.1);

        revealTl.eventCallback('onComplete', () => {
          titleSplit.revert();
        });

        ScrollTrigger.create({
          id: 'contatti-reveal',
          trigger: section,
          start: 'top 75%',
          once: true,
          onEnter: () => {
            hasRevealed = true;
            revealTl.play();
          },
        });
      }

      // ── Hover: Submit button ──
      const submitArrow = submitBtn.querySelector('.contatti__submit-arrow') as SVGElement;

      submitBtn.addEventListener('mouseenter', () => {
        gsap.to(submitBtn, {
          backgroundColor: '#6666FF',
          duration: 0.3, overwrite: 'auto',
        });
        gsap.to(submitArrow, {
          x: 5, duration: 0.3, ease: 'power2.out', overwrite: 'auto',
        });
      }, { signal: ac.signal });

      submitBtn.addEventListener('mouseleave', () => {
        gsap.to(submitBtn, {
          backgroundColor: '#4545F7',
          duration: 0.3, overwrite: 'auto',
        });
        gsap.to(submitArrow, {
          x: 0, duration: 0.3, ease: 'power2.out', overwrite: 'auto',
        });
      }, { signal: ac.signal });

      // ── Hover: Footer links ──
      footerLinks.forEach(link => {
        link.addEventListener('mouseenter', () => {
          gsap.to(link, {
            color: '#F21763',
            duration: 0.25, overwrite: 'auto',
          });
        }, { signal: ac.signal });

        link.addEventListener('mouseleave', () => {
          gsap.to(link, {
            color: '#0D0826',
            duration: 0.25, overwrite: 'auto',
          });
        }, { signal: ac.signal });
      });

      // ── Hover: Social icons ──
      // Disabled links (placeholder for not-yet-active accounts) keep the icon
      // visible but get no hover reaction and a click swallow, so they don't
      // look interactive then do nothing on click.
      socialLinks.forEach(link => {
        if (link.hasAttribute('data-social-disabled')) {
          link.addEventListener('click', (e) => e.preventDefault(), { signal: ac.signal });
          return;
        }

        link.addEventListener('mouseenter', () => {
          gsap.to(link, {
            color: '#F21763',
            scale: 1.12,
            duration: 0.25, ease: 'power2.out', overwrite: 'auto',
          });
        }, { signal: ac.signal });

        link.addEventListener('mouseleave', () => {
          gsap.to(link, {
            color: '#0D0826',
            scale: 1,
            duration: 0.25, ease: 'power2.out', overwrite: 'auto',
          });
        }, { signal: ac.signal });
      });

      // ── Preferenze cookie: riapre la modale iubenda ──
      const prefsLink = section.querySelector('[data-cookie-preferences]') as HTMLAnchorElement | null;
      prefsLink?.addEventListener('click', (e) => {
        e.preventDefault();
        (window as any)._iub?.cs?.api?.openPreferences?.();
      }, { signal: ac.signal });

      // ── Hover: Indirizzi sedi ──
      addresses.forEach(addr => {
        addr.addEventListener('mouseenter', () => {
          gsap.to(addr, {
            color: '#F21763',
            duration: 0.25, overwrite: 'auto',
          });
        }, { signal: ac.signal });

        addr.addEventListener('mouseleave', () => {
          gsap.to(addr, {
            color: '#4545F7',
            duration: 0.25, overwrite: 'auto',
          });
        }, { signal: ac.signal });
      });

      // ── Turnstile: render only at submit ──
      // Layout.astro auto-schedules T.load() in idle, so the API script is
      // parsed and `window.turnstile` is ready by the time the user reaches
      // submit. The widget itself (the iframe that runs the actual challenge)
      // is rendered ONLY inside handleSubmit() below — never on focus.
      // Why: on Safari, turnstile.render() blocks the main thread for ~1.5s
      // (community.cloudflare.com/t/1500ms-hang-...). Rendering on focus
      // would freeze the form for that window every time the user clicks an
      // input. Rendering at submit moves the block to a moment where the
      // user already expects a wait (spinner). It also makes the Safari
      // self-check loop in interaction-only widgets structurally impossible:
      // the iframe lives <2s and only inside the in-flight submission.
      const TURNSTILE_SITE_KEY = '0x4AAAAAAC97pyXgUgHeiHAx';
      let turnstileWidgetId: string | null = null;

      function getTurnstileToken(): Promise<string | null> {
        return new Promise((resolve) => {
          const container = document.getElementById('contatti-turnstile');
          if (!container || !(window as any).turnstile) {
            resolve(null);
            return;
          }

          // Reset visibility in case a previous submit ended in the interactive
          // path and the class is still attached.
          container.classList.remove('is-visible');

          let resolved = false;
          const safeResolve = (val: string | null) => {
            if (resolved) return;
            resolved = true;
            resolve(val);
          };

          turnstileWidgetId = (window as any).turnstile.render(container, {
            sitekey: TURNSTILE_SITE_KEY,
            appearance: 'interaction-only',
            theme: 'light',
            callback: (token: string) => safeResolve(token),
            'error-callback': () => safeResolve(null),
            'timeout-callback': () => safeResolve(null),
            // Reveal the iframe in the form layout only when Cloudflare
            // needs an interactive checkbox. The 90% of users on invisible
            // challenges never see the submit button shift down.
            'before-interactive-callback': () => container.classList.add('is-visible'),
            'after-interactive-callback': () => container.classList.remove('is-visible'),
          });

          // Hard ceiling: with appearance:interaction-only, ~10% of users get
          // a visible "Verify you are human" checkbox that waits for a click.
          // 30s gives a human enough time to interact; if nothing arrives by
          // then the submit handler shows a generic error.
          setTimeout(() => safeResolve(null), 30000);
        });
      }

      // ── Form validation ──
      const validationRules: Record<string, { test: (v: string) => boolean; message: string }> = {
        nome:      { test: (v) => v.trim().length >= 2,                   message: 'Inserisci il tuo nome (min. 2 caratteri)' },
        email:     { test: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v),  message: 'Inserisci un\'email valida' },
        oggetto:   { test: (v) => v.length > 0,                           message: 'Seleziona un oggetto' },
        messaggio: { test: (v) => v.trim().length >= 10,                  message: 'Inserisci un messaggio (min. 10 caratteri)' },
      };

      function showError(fieldEl: HTMLElement, _input: HTMLElement, message: string) {
        fieldEl.classList.add('contatti__field--error');
        const errSpan = fieldEl.querySelector('.contatti__error') as HTMLElement;
        if (errSpan) errSpan.textContent = message;
      }

      function clearError(fieldEl: HTMLElement, _input: HTMLElement) {
        fieldEl.classList.remove('contatti__field--error');
        const errSpan = fieldEl.querySelector('.contatti__error') as HTMLElement;
        if (errSpan) errSpan.textContent = '';
      }

      // Clear error on focus/input
      form.querySelectorAll<HTMLElement>('.contatti__input').forEach(input => {
        const fieldEl = input.closest('.contatti__field') as HTMLElement;
        if (!fieldEl) return;

        const fieldName = (input as HTMLInputElement).name;
        const rule = validationRules[fieldName];
        if (!rule) return;

        // Real-time: re-validate on input — clear error when valid, keep when invalid
        const validateOnInput = () => {
          if (!fieldEl.classList.contains('contatti__field--error')) return;
          if (rule.test((input as HTMLInputElement).value)) {
            clearError(fieldEl, input);
          }
        };

        // On blur: validate and show error if invalid (only if field was touched)
        const validateOnBlur = () => {
          const val = (input as HTMLInputElement).value;
          if (val.trim().length === 0 && !fieldEl.classList.contains('contatti__field--error')) return; // skip empty untouched
          if (!rule.test(val)) {
            showError(fieldEl, input, rule.message);
          } else {
            clearError(fieldEl, input);
          }
        };

        input.addEventListener('input', validateOnInput, { signal: ac.signal });
        input.addEventListener('change', validateOnInput, { signal: ac.signal });
        input.addEventListener('blur', validateOnBlur, { signal: ac.signal });
      });

      // ── Privacy checkbox: clear error as soon as user ticks it ──
      function showPrivacyError(message: string) {
        if (!privacyWrap || !privacyErr) return;
        privacyWrap.classList.add('contatti__consent-wrap--error');
        privacyErr.textContent = message;
      }
      function clearPrivacyError() {
        if (!privacyWrap || !privacyErr) return;
        privacyWrap.classList.remove('contatti__consent-wrap--error');
        privacyErr.textContent = '';
      }
      privacyCb?.addEventListener('change', () => {
        if (privacyCb.checked) clearPrivacyError();
      }, { signal: ac.signal });

      // ── Submit state helpers ──
      const submitLabel = submitBtn.querySelector('[data-contatti-submit-label]') as HTMLElement;
      const statusEl = section.querySelector('[data-contatti-status]') as HTMLElement;
      let isSubmitting = false;

      function setSubmitting(sending: boolean) {
        isSubmitting = sending;
        submitBtn.classList.toggle('contatti__submit--sending', sending);
        (submitBtn as HTMLButtonElement).disabled = sending;
        if (submitLabel) submitLabel.textContent = sending ? 'INVIO IN CORSO...' : 'INVIA';
      }

      function showStatus(message: string, type: 'success' | 'error') {
        if (!statusEl) return;
        gsap.killTweensOf(statusEl);
        statusEl.textContent = message;
        statusEl.className = 'contatti__form-status contatti__form-status--' + type;
        gsap.fromTo(statusEl, { autoAlpha: 0, y: 5 }, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' });
      }

      function clearStatus() {
        if (!statusEl) return;
        gsap.killTweensOf(statusEl);
        statusEl.textContent = '';
        gsap.set(statusEl, { autoAlpha: 0 });
      }

      // ── Submit handler ──
      // Use click + Enter instead of form submit to bypass Astro ClientRouter
      // interception (captures submit events at document level before preventDefault)
      async function handleSubmit() {
        if (isSubmitting) return;

        clearStatus();
        let valid = true;

        for (const [name, rule] of Object.entries(validationRules)) {
          const input = form.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(`[name="${name}"]`);
          if (!input) continue;

          const fieldEl = input.closest('.contatti__field') as HTMLElement;
          if (!fieldEl) continue;

          if (!rule.test(input.value)) {
            showError(fieldEl, input, rule.message);
            valid = false;
          } else {
            clearError(fieldEl, input);
          }
        }

        if (privacyCb && !privacyCb.checked) {
          showPrivacyError('Per inviare il messaggio è necessario accettare la Privacy Policy.');
          valid = false;
        } else {
          clearPrivacyError();
        }

        if (!valid) {
          // Shake the submit button
          gsap.to(submitBtn, {
            x: [-8, 8, -6, 6, -3, 3, 0],
            duration: 0.5,
            ease: 'power2.out',
          });
          return;
        }

        // From here on the user has committed to a submit — show the spinner
        // and start Turnstile work. setSubmitting(true) happens BEFORE any
        // await so the button label switches immediately.
        setSubmitting(true);
        clearStatus();

        // 1. Make sure the API script is parsed. Idle-preloaded by Layout,
        // so this resolves instantly in the common case; only matters if the
        // user is faster than the idle scheduler or the CDN is slow.
        const T = (window as any).datycaTurnstile;
        if (T) {
          T.load();
          const ready = await new Promise<boolean>((resolve) => T.onReady(resolve));
          if (!ready) {
            showStatus('Verifica antispam non disponibile. Scrivici direttamente a info@datyca.com.', 'error');
            setSubmitting(false);
            return;
          }
        }

        // 2-3. Render the widget, await the token, send to backend. Wrapped
        // in try/finally so the widget is always destroyed on the way out
        // (including when the token times out or the fetch throws). Tokens
        // are single-use, so keeping the iframe alive after submit wins
        // nothing and would re-introduce the Safari self-check loop — a
        // retry just re-renders from scratch.
        try {
          const turnstileToken = await getTurnstileToken();
          if (!turnstileToken) {
            showStatus('Verifica antispam non completata. Riprova o scrivici a info@datyca.com.', 'error');
            return;
          }

          // FormData → plain object, then override the two checkboxes as
          // booleans (FormData yields 'on' for checked / omits unchecked —
          // the PHP backend expects strict booleans for consent flags).
          const fd = new FormData(form);
          const formData: Record<string, unknown> = Object.fromEntries(fd);
          formData['consent_privacy']      = !!fd.get('consent_privacy');
          formData['consent_marketing']    = !!fd.get('consent_marketing');
          formData['cf-turnstile-response'] = turnstileToken;

          const res = await fetch('/contact.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData),
          });

          const result = await res.json();

          if (res.ok) {
            showStatus('Messaggio inviato con successo!', 'success');
            form.reset();
            // Animate success on button
            gsap.to(submitBtn, {
              backgroundColor: '#16a34a',
              duration: 0.3,
              onComplete: () => {
                if (submitLabel) submitLabel.textContent = 'INVIATO!';
                gsap.to(submitBtn, {
                  backgroundColor: '#4545F7',
                  duration: 0.3,
                  delay: 2,
                  onComplete: () => {
                    if (submitLabel) submitLabel.textContent = 'INVIA';
                  },
                });
              },
            });
          } else {
            const msg = result.message || 'Errore nell\'invio. Riprova.';
            showStatus(msg, 'error');

            // Show server-side field errors if present
            if (result.errors) {
              for (const [fieldName, errorMsg] of Object.entries(result.errors)) {
                const input = form.querySelector<HTMLElement>(`[name="${fieldName}"]`);
                if (!input) continue;
                const fieldEl = input.closest('.contatti__field') as HTMLElement;
                if (fieldEl) showError(fieldEl, input, errorMsg as string);
              }
            }
          }
        } catch {
          showStatus('Errore di connessione. Controlla la tua rete e riprova.', 'error');
        } finally {
          if ((window as any).turnstile && turnstileWidgetId !== null) {
            try { (window as any).turnstile.remove(turnstileWidgetId); } catch { /* ignore */ }
            turnstileWidgetId = null;
          }
          setSubmitting(false);
        }
      }

      submitBtn.addEventListener('click', handleSubmit, { signal: ac.signal });

      // Enter key on inputs triggers submit (textarea excluded — Enter = newline)
      form.querySelectorAll<HTMLElement>('input, select').forEach(input => {
        input.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter') {
            e.preventDefault();
            handleSubmit();
          }
        }, { signal: ac.signal });
      });

      return () => { ac.abort(); };
    }

    const mm = gsap.matchMedia();
    mm.add('(min-width: 1024px)', setup);
    mm.add('(max-width: 1023px)', setup);
  }

  ((window as any).__initQueue ??= []).push(initContatti);
</script>
