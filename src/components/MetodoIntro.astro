---
const fasi = [
  {
    n: 'Fase 1',
    title: 'ANALISI DEI BISOGNI',
    body: 'Partiamo dall\u2019analisi delle specifiche esigenze dell\u2019organizzazione, del settore di riferimento e dei processi impattati. Ogni intervento nasce da una comprensione profonda del contesto operativo, normativo e umano, per costruire soluzioni realmente su misura e mai generaliste.',
  },
  {
    n: 'Fase 2',
    title: 'PROGETTAZIONE E ATTUAZIONE',
    body: 'Traduciamo gli obiettivi in interventi concreti di governance, compliance e design dei processi. Pianifichiamo e attuiamo soluzioni integrate, proporzionate al livello di rischio e all\u2019impatto organizzativo, accompagnando l\u2019implementazione fino alla piena operatività.',
  },
  {
    n: 'Fase 3',
    title: 'CHANGE MANAGEMENT',
    body: 'Il valore di un progetto si misura nella sua adozione. Affianchiamo le organizzazioni con percorsi personalizzati di formazione e sviluppiamo strumenti operativi su misura per la gestione collaborativa dei nuovi flussi, rendendo il cambiamento comprensibile e sostenibile nel tempo.',
  },
];
---

<section id="metodo-intro" class="mi">
  <div class="mi__left">
    <h1 class="text-hero mi__title">Il nostro metodo.</h1>

    <ol class="mi__fasi">
      {fasi.map((fase) => (
        <li class="mi__fase">
          <p class="mi__fase-n">{fase.n}</p>
          <h2 class="text-h2 mi__fase-title">{fase.title}</h2>
          <p class="text-body mi__fase-body">{fase.body}</p>
        </li>
      ))}
    </ol>
  </div>

  <div class="mi__right" aria-hidden="true">
    <div class="mi__line"></div>
    <p class="mi__placeholder">illustrazione to do</p>
  </div>
</section>

<style>
  .mi {
    --_pad-x: clamp(40px, 10.9vw, 157px);
    position: relative;
    max-width: 1440px;
    margin-inline: auto;
    padding: clamp(40px, 6vw, 80px) var(--_pad-x) var(--section-padding-y);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(40px, 5vw, 80px);
  }

  /* ── LEFT: title + fasi ── */
  .mi__left {
    display: flex;
    flex-direction: column;
  }

  .mi__title {
    color: var(--color-purple-600);
    margin-bottom: clamp(60px, 8vw, 120px);
  }

  .mi__fasi {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(60px, 6vw, 90px);
    max-width: 460px;
  }

  .mi__fase {
    display: flex;
    flex-direction: column;
  }

  .mi__fase-n {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    line-height: 1;
    color: var(--color-red);
    margin-bottom: 16px;
  }

  .mi__fase-title {
    color: var(--color-white-almost);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .mi__fase-body {
    color: var(--color-white-almost);
  }

  /* ── RIGHT: placeholder + vertical line ── */
  .mi__right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
  }

  .mi__line {
    position: absolute;
    top: 0;
    right: 0;
    width: 1px;
    height: 100%;
    background: var(--color-purple-500);
    opacity: 0.4;
  }

  .mi__placeholder {
    font-family: var(--font-sans);
    font-size: 30px;
    color: var(--color-grey-400);
    text-align: center;
  }

  /* ── Initial states (GSAP) — prevent FOUC ── */
  .mi__title,
  .mi__fase,
  .mi__right {
    visibility: hidden;
  }

  @media (max-width: 767px) {
    .mi {
      grid-template-columns: 1fr;
      gap: 60px;
      padding: 40px var(--section-padding-x) var(--section-padding-y);
    }

    .mi__title {
      margin-bottom: 50px;
    }

    .mi__fasi {
      gap: 60px;
      max-width: none;
    }

    .mi__fase-n {
      font-size: 16px;
    }

    /* Placeholder: below content, reduced */
    .mi__right {
      min-height: 200px;
      order: 2;
    }

    .mi__placeholder {
      font-size: 20px;
    }

    .mi__line {
      /* Horizontal line on mobile */
      width: 100%;
      height: 1px;
      top: auto;
      bottom: 0;
      right: 0;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initMetodoIntro() {
    const section = document.getElementById('metodo-intro');
    if (!section) return;

    let hasRevealed = false;

    function setup() {
      const titleEl = section!.querySelector('.mi__title') as HTMLElement;
      const fasi = section!.querySelectorAll<HTMLElement>('.mi__fase');
      const right = section!.querySelector('.mi__right') as HTMLElement;

      if (hasRevealed) {
        gsap.set(titleEl, { autoAlpha: 1, y: 0 });
        gsap.set(fasi, { autoAlpha: 1, y: 0 });
        gsap.set(right, { autoAlpha: 1 });
        return;
      }

      // Initial hidden state (autoAlpha replaces the CSS visibility: hidden)
      gsap.set([titleEl, ...Array.from(fasi)], { autoAlpha: 0, y: 20 });
      gsap.set(right, { autoAlpha: 0 });

      const wordSplit = SplitText.create(titleEl, { type: 'words', aria: 'none' });
      gsap.set(wordSplit.words, { autoAlpha: 0, y: 20 });
      gsap.set(titleEl, { autoAlpha: 1, y: 0 }); // Container visible, words hidden

      const revealTl = gsap.timeline({ paused: true });

      revealTl.to(wordSplit.words, {
        autoAlpha: 1, y: 0,
        duration: 0.6, stagger: 0.1,
        ease: 'power2.out',
      }, 0);

      revealTl.to(fasi, {
        autoAlpha: 1, y: 0,
        duration: 0.6, stagger: 0.15,
        ease: 'power2.out',
      }, 0.3);

      revealTl.to(right, {
        autoAlpha: 1,
        duration: 0.8, ease: 'power2.out',
      }, 0.2);

      revealTl.eventCallback('onComplete', () => {
        wordSplit.revert();
      });

      ScrollTrigger.create({
        id: 'metodo-intro-reveal',
        trigger: section!,
        start: 'top 75%',
        once: true,
        onEnter: () => {
          hasRevealed = true;
          revealTl.play();
        },
      });
    }

    const mm = gsap.matchMedia();
    mm.add('(min-width: 768px)', setup);
    mm.add('(max-width: 767px)', setup);
  }

  ((window as any).__initQueue ??= []).push(initMetodoIntro);
</script>
