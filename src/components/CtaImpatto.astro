---
import Section from './Section.astro';
import PromoCards from './PromoCards.astro';

const impattoCards = [
  {
    title: 'TAIG Lab',
    description: 'Il Centro Studi per la ricerca applicata sulla Technical AI Governance.',
    cta: 'SCOPRI TAIG LAB',
    href: '/il-nostro-impatto/taig-lab',
  },
  {
    title: 'AI Learn Hub',
    description: 'Competenze per l\'era dell\'intelligenza artificiale. La prima piattaforma italiana di AI Literacy per le organizzazioni.',
    cta: 'SCOPRI AI LEARN HUB',
    href: '/il-nostro-impatto/ai-learn-hub',
  },
  {
    title: 'Per la PA',
    description: 'Le nostre competenze al servizio della trasformazione digitale della Pubblica Amministrazione.',
    cta: 'SCOPRI I SERVIZI PER LA PA',
    href: '/il-nostro-impatto/per-la-pa',
  },
];
---

<Section id="cta-impatto" class="cta-impatto">
  <PromoCards />

  <!-- ── Il nostro impatto ── -->
  <h2 id="il-nostro-impatto" data-scroll-align="section-end" class="text-h1 impatto-title">Il nostro impatto</h2>

  <div class="impatto-grid">
    {impattoCards.map((card) => (
      <div class="impatto-card" data-impatto-card>
        <h3 class="impatto-card__title">{card.title}</h3>
        <p class="text-body impatto-card__body">{card.description}</p>
        <a href={card.href} class="text-cta impatto-card__cta" data-impatto-cta>
          <span>{card.cta}</span>
          <svg width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
        </a>
      </div>
    ))}
  </div>

</Section>

<style>
  /* ── Section — :global needed because <section> is rendered by Section.astro ── */
  :global(#cta-impatto) {
    position: relative;
    background: linear-gradient(
      56.66deg,
      var(--color-red) -6.51%,
      var(--color-blue-deep-800) 18.05%,
      var(--color-black-almost-900) 39.52%
    );
  }

  :global(#cta-impatto .section__inner) {
    padding-bottom: clamp(160px, 15.3vw, 220px);
  }

  /* ── Impatto ── */
  .impatto-title {
    font-family: var(--font-serif);
    letter-spacing: -0.04em;
    text-align: center;
    margin-top: clamp(120px, 18.75vw, 270px);
  }

  .impatto-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(40px, 5.5vw, 80px);
  }

  .impatto-card {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-height: 400px;
    border-right: 2px solid var(--grid-border-color);
    border-bottom: 2px solid var(--grid-border-color);
  }

  .impatto-card:nth-child(-n+3) {
    border-top: 2px solid var(--grid-border-color);
  }

  .impatto-card:nth-child(3n+1) {
    border-left: 2px solid var(--grid-border-color);
  }

  .impatto-card__title {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 28px;
    line-height: normal;
    color: var(--color-red);
  }

  .impatto-card__body {
    flex: 1;
  }

  .impatto-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    text-decoration: none;
    align-self: flex-start;
    margin-top: auto;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .impatto-title {
      margin-top: 80px;
    }
    .impatto-grid {
      grid-template-columns: 1fr;
    }
    .impatto-card {
      padding: 24px;
      min-height: auto;
      border-left: 2px solid var(--grid-border-color);
    }
    .impatto-card:nth-child(-n+3) {
      border-top: none;
    }
    .impatto-card:first-child {
      border-top: 2px solid var(--grid-border-color);
    }
    .impatto-card__cta {
      align-self: stretch;
      justify-content: space-between;
    }
  }
</style>

<script>
  import { MQ } from '@utils/breakpoints';
  import { registerInit } from '@utils/init';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initCtaImpatto() {
    const section = document.getElementById('cta-impatto');
    if (!section) return;

    let hasRevealed = false;

    function setup() {
      const root = getComputedStyle(document.documentElement);
      const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      const impattoCards = section.querySelectorAll<HTMLElement>('[data-impatto-card]');
      const sectionTitle = section.querySelector('.impatto-title') as HTMLElement;
      const impattoCtaBtns = section.querySelectorAll<HTMLElement>('[data-impatto-cta]');

      const ac = new AbortController();

      if (hasRevealed) {
        if (sectionTitle) gsap.set(sectionTitle, { autoAlpha: 1 });
        gsap.set(impattoCards, { autoAlpha: 1, y: 0 });
      } else {
        gsap.set(impattoCards, { autoAlpha: 0, y: 30 });

        const revealTl = gsap.timeline({ paused: true });

        // Section title — SplitText words
        if (sectionTitle) {
          const titleSplit = SplitText.create(sectionTitle, { type: 'words', aria: 'none' });
          gsap.set(titleSplit.words, { autoAlpha: 0, y: 25 });

          revealTl.to(titleSplit.words, {
            autoAlpha: 1, y: 0,
            duration: 0.7, stagger: 0.1,
            ease: 'power2.out',
          }, 0);

          revealTl.eventCallback('onComplete', () => {
            titleSplit.revert();
          });
        }

        // Impatto cards stagger
        revealTl.to(impattoCards, {
          autoAlpha: 1, y: 0,
          duration: 0.7, stagger: 0.16,
          ease: 'power2.out',
        }, 0.4);

        ScrollTrigger.create({
          id: 'cta-impatto-reveal',
          trigger: sectionTitle || section,
          start: 'top 75%',
          once: true,
          onEnter: () => {
            hasRevealed = true;
            revealTl.play();
          },
        });
      }

      // ── CTA button hover ──
      impattoCtaBtns.forEach(cta => {
        const arrow = cta.querySelector('svg') as SVGElement;

        cta.addEventListener('mouseenter', () => {
          gsap.to(cta, { borderColor: colorPurple600, color: colorPurple600, duration: 0.25, overwrite: 'auto' });
          if (arrow) gsap.to(arrow, { x: 5, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
        }, { signal: ac.signal });

        cta.addEventListener('mouseleave', () => {
          gsap.to(cta, { borderColor: colorText, color: colorText, duration: 0.25, overwrite: 'auto' });
          if (arrow) gsap.to(arrow, { x: 0, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
        }, { signal: ac.signal });
      });

      return () => { ac.abort(); };
    }

    const mm = gsap.matchMedia();
    mm.add(MQ.tabletUp, setup);
    mm.add(MQ.belowTablet, setup);
  }

  registerInit(initCtaImpatto);
</script>
