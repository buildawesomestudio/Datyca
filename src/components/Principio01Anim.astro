---
import fs from 'node:fs';
import path from 'node:path';

const svgPath = path.resolve('public/images/Principio 01.svg');
let svgContent = fs.readFileSync(svgPath, 'utf-8');

svgContent = svgContent
  .replace('<svg ', '<svg id="p01-svg" aria-hidden="true" class="tp-anim-svg" ')
  .replace(/style="[^"]*"/, '');
---

<Fragment set:html={svgContent} />

<script>
// Pause immediately — Principi component manages play/pause per state
function initPrincipio01() {
  const svg = document.getElementById('p01-svg') as SVGSVGElement | null;
  if (svg) svg.pauseAnimations();
}
((window as any).__initQueue ??= []).push(initPrincipio01);
</script>
