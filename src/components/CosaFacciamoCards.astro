---
import Section from './Section.astro';
import SectionHeader from './SectionHeader.astro';

interface CardItem {
  title: string;
  body: string;
}

interface Props {
  items: CardItem[];
  hideCta?: boolean;
  sectionTitle?: string;
}

const { items, hideCta, sectionTitle = 'Cosa facciamo' } = Astro.props;
---

<Section id="cosa-facciamo-cards" class="cfc">
  <div class="cfc__inner">
    <SectionHeader title={sectionTitle} titleClass="text-section-title" />

    <div class="cfc__stack">
      {items.map((item) => (
        <article class="cfc__card">
          <h3 class="cfc__title">{item.title.replace(/\n/g, ' ')}</h3>
          <p class="text-body cfc__body">{item.body}</p>
        </article>
      ))}
    </div>

    {!hideCta && (
      <a href="#contatti" class="cfc__cta text-cta">
        <span>Contattaci</span>
        <svg width="24" height="24" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
      </a>
    )}
  </div>
</Section>

<style>
  .cfc__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cfc__inner :global(.section-header) {
    width: 100%;
  }

  .cfc__stack {
    width: 100%;
    max-width: 1123px;
    margin-top: clamp(50px, 6vw, 80px);
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-purple-500);
    background: var(--color-bg);
  }

  .cfc__card {
    padding: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 1.5vw, 24px);
  }

  /* Single shared divider between adjacent cards (no double border). */
  .cfc__card + .cfc__card {
    border-top: 1px solid var(--color-purple-500);
  }

  .cfc__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(24px, calc(24px + 8 * (100vw - 375px) / 1065), 32px);
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--color-red);
    margin: 0;
  }

  .cfc__body {
    color: var(--color-white-almost);
    margin: 0;
  }

  .cfc__cta {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-top: clamp(50px, 6vw, 80px);
    padding: 16px 24px;
    background: var(--color-purple-500);
    color: var(--color-white-almost);
    text-decoration: none;
    align-self: center;
  }
</style>
