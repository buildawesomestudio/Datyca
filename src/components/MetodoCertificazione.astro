---
---

<section id="metodo-certificazione" class="mc">
  <div class="mc__inner">
    <h2 class="text-h2 mc__title">La fiducia inizia dal nostro modo di operare</h2>

    <p class="text-body mc__body">
      DATYCA è tra le prime società in Italia ad aver conseguito la certificazione <strong>ISO/IEC 42001</strong> (Artificial Intelligence Management System) per l&rsquo;utilizzo di sistemi di IA a supporto delle attività consulenziali.<br /><br />
      Questo garantisce ai nostri clienti che le informazioni gestite attraverso strumenti intelligenti sono trattate secondo standard riconosciuti di governance, sicurezza e trasparenza, a tutela della riservatezza dei dati ricevuti e dell&rsquo;affidabilità dei relativi processi di consulenza.
    </p>

    <a href="/docs/DATYCA_Certificazione_ISO_42001.pdf" class="text-cta mc__cta" data-cta-btn download target="_blank" rel="noopener noreferrer">
      <span>Scarica la nostra certificazione</span>
      <svg width="18" height="18" aria-hidden="true">
        <use href="#icon-diagonal-down-thick" />
      </svg>
    </a>
  </div>
</section>

<style>
  .mc {
    --_pad-x: clamp(40px, 10.9vw, 157px);
    position: relative;
    max-width: 1440px;
    margin-inline: auto;
    padding: clamp(40px, 6vw, 80px) var(--_pad-x) var(--section-padding-y);
  }

  .mc__inner {
    display: flex;
    flex-direction: column;
    max-width: 1027px;
  }

  .mc__title {
    font-family: var(--font-serif);
    color: var(--color-red);
    margin-bottom: clamp(24px, 3vw, 40px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .mc__body {
    color: var(--color-white-almost);
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .mc__body strong {
    font-weight: 600;
  }

  .mc__cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid var(--color-white-almost);
    color: var(--color-white-almost);
    text-decoration: none;
    align-self: flex-start;
  }

  /* ── FOUC gate ── */
  .mc__title,
  .mc__body,
  .mc__cta {
    visibility: hidden;
  }

  @media (max-width: 767px) {
    .mc {
      padding: 40px var(--section-padding-x) var(--section-padding-y);
    }

    .mc__cta {
      align-self: stretch;
      justify-content: space-between;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initMetodoCertificazione() {
    const section = document.getElementById('metodo-certificazione');
    if (!section) return;

    let hasRevealed = false;

    function setup() {
      const titleEl = section!.querySelector('.mc__title') as HTMLElement;
      const bodyEl = section!.querySelector('.mc__body') as HTMLElement;
      const cta = section!.querySelector('.mc__cta') as HTMLElement;

      if (hasRevealed) {
        gsap.set([titleEl, bodyEl, cta], { autoAlpha: 1, y: 0 });
      } else {
        gsap.set([bodyEl, cta], { autoAlpha: 0, y: 20 });
        gsap.set(titleEl, { autoAlpha: 1 });

        const wordSplit = SplitText.create(titleEl, { type: 'words', aria: 'none' });
        gsap.set(wordSplit.words, { autoAlpha: 0, y: 20 });

        const revealTl = gsap.timeline({ paused: true });

        revealTl.to(wordSplit.words, {
          autoAlpha: 1, y: 0,
          duration: 0.6, stagger: 0.08,
          ease: 'power2.out',
        }, 0);

        revealTl.to(bodyEl, {
          autoAlpha: 1, y: 0,
          duration: 0.6, ease: 'power2.out',
        }, 0.4);

        revealTl.to(cta, {
          autoAlpha: 1, y: 0,
          duration: 0.5, ease: 'power2.out',
        }, 0.6);

        revealTl.eventCallback('onComplete', () => {
          wordSplit.revert();
        });

        ScrollTrigger.create({
          id: 'metodo-cert-reveal',
          trigger: section!,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            hasRevealed = true;
            revealTl.play();
          },
        });
      }

      // ── CTA hover (desktop pointer only) ──
      if (!window.matchMedia('(pointer: fine)').matches) return;

      const root = getComputedStyle(document.documentElement);
      const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      const ac = new AbortController();

      cta.addEventListener('mouseenter', () => {
        gsap.to(cta, { borderColor: colorPurple600, color: colorPurple600, duration: 0.25, overwrite: true });
      }, { signal: ac.signal });

      cta.addEventListener('mouseleave', () => {
        gsap.to(cta, { borderColor: colorText, color: colorText, duration: 0.25, overwrite: true });
      }, { signal: ac.signal });

      return () => { ac.abort(); };
    }

    const mm = gsap.matchMedia();
    mm.add('(min-width: 768px)', setup);
    mm.add('(max-width: 767px)', setup);
  }

  ((window as any).__initQueue ??= []).push(initMetodoCertificazione);
</script>
