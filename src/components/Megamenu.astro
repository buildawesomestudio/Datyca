---
interface SubItem {
  label: string;
  href: string;
}

interface NavGroup {
  label: string;
  href: string;
  children?: SubItem[];
}

const leftColumn: (NavGroup | { label: string; href: string })[] = [
  { label: 'Home', href: '/' },
  {
    label: 'Chi siamo',
    href: '/chi-siamo',
    children: [
      { label: 'Perché Datyca', href: '/#why-datyca' },
      { label: 'Missione', href: '/#missione' },
      { label: 'Principi', href: '/#principi' },
      { label: 'Metodo', href: '/chi-siamo/metodo' },
    ],
  },
  {
    label: 'Il nostro impatto',
    href: '/il-nostro-impatto',
    children: [
      { label: 'TAIG Lab', href: '/il-nostro-impatto/taig-lab' },
      { label: 'AI Learn Hub', href: '/il-nostro-impatto/ai-learn-hub' },
      { label: 'Per la PA', href: '/il-nostro-impatto/per-la-pa' },
    ],
  },
];

const rightColumn: (NavGroup | { label: string; href: string })[] = [
  {
    label: 'AI Governance',
    href: '/ai-governance',
    children: [
      { label: 'Responsible AI', href: '/ai-governance/responsible-ai' },
      { label: 'Trustworthy AI', href: '/ai-governance/trustworthy-ai' },
    ],
  },
  {
    label: 'Servizi',
    href: '/servizi',
    children: [
      { label: 'Data Protection', href: '/servizi/data-protection' },
      { label: 'Cybersecurity', href: '/servizi/cybersecurity' },
      { label: 'Legal Desk', href: '/servizi/legal-desk' },
      { label: 'Legal Design', href: '/servizi/legal-design' },
    ],
  },
  { label: 'Risorse', href: '/risorse' },
  { label: 'Contatti', href: '#contatti' },
];
---

<div id="megamenu">
  <div class="megamenu-header">
    <a href="/" class="megamenu-logo">
      <img src="/images/logo-full_dark.svg" alt="Datyca - Legal Design Lab" width="220" height="68" />
    </a>
    <button id="megamenu-close" class="megamenu-close" aria-label="Chiudi menu">
      <svg width="31" height="31" aria-hidden="true" fill="currentColor"><use href="#icon-close" /></svg>
    </button>
  </div>

  <div class="megamenu-columns">
    <div class="megamenu-col">
      {leftColumn.map((group) => (
        <div class="megamenu-group">
          {'children' in group && group.children ? (
            <>
              <button class="megamenu-parent" type="button" aria-expanded="false">
                <span>{group.label}</span>
                <svg class="megamenu-chevron" width="12" height="12" aria-hidden="true"><use href="#icon-chevron-down" /></svg>
              </button>
              <div class="megamenu-children">
                {group.children.map((child) => (
                  <a href={child.href} class="megamenu-link">
                    <span>{child.label}</span>
                    <svg class="megamenu-arrow" width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a href={group.href} class="megamenu-link megamenu-link--top">
              <span>{group.label}</span>
              <svg class="megamenu-arrow megamenu-arrow--top" width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
            </a>
          )}
        </div>
      ))}
    </div>

    <div class="megamenu-col">
      {rightColumn.map((group) => (
        <div class="megamenu-group">
          {'children' in group && group.children ? (
            <>
              <button class="megamenu-parent" type="button" aria-expanded="false">
                <span>{group.label}</span>
                <svg class="megamenu-chevron" width="12" height="12" aria-hidden="true"><use href="#icon-chevron-down" /></svg>
              </button>
              <div class="megamenu-children">
                {group.children.map((child) => (
                  <a href={child.href} class="megamenu-link">
                    <span>{child.label}</span>
                    <svg class="megamenu-arrow" width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a href={group.href} class="megamenu-link megamenu-link--top">
              <span>{group.label}</span>
              <svg class="megamenu-arrow megamenu-arrow--top" width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  #megamenu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    background: var(--color-white-snow);
    clip-path: circle(0% at 95% 3%);
    pointer-events: none;
    overflow: hidden;
  }

  .megamenu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 120px;
    padding: 0 40px;
  }

  .megamenu-logo {
    display: flex;
    align-items: center;
  }

  .megamenu-logo img {
    width: 220px;
    height: auto;
  }

  .megamenu-close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 15px;
    margin-right: -15px;
    color: var(--color-purple-500);
  }

  .megamenu-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 60px;
    padding: 0 40px 20px;
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: none;
    scrollbar-width: none;
  }

  .megamenu-columns::-webkit-scrollbar {
    display: none;
  }

  .megamenu-group {
    border-bottom: 2px solid var(--color-grey-toned-600);
    padding-bottom: 10px;
    margin-bottom: 10px;
  }

  .megamenu-group:first-child {
    border-top: 2px solid var(--color-grey-toned-600);
    padding-top: 10px;
  }

  .megamenu-parent {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 26px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: -0.04em;
    color: var(--color-blue-deep-800);
    padding: 20px 0;
    cursor: default;
    text-align: left;
  }

  .megamenu-chevron {
    display: none;
    flex-shrink: 0;
  }

  .megamenu-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 26px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 0;
    color: var(--color-purple-500);
    text-decoration: none;
    padding: 20px 0 20px 40px;
  }

  .megamenu-link--top {
    padding: 20px 0;
    justify-content: space-between;
  }

  .megamenu-arrow {
    color: var(--color-purple-500);
  }

  .megamenu-arrow--top {
    display: none;
  }

  @media (max-width: 767px) {
    .megamenu-header {
      height: 80px;
      padding: 0 20px;
    }
    .megamenu-logo img {
      width: 180px;
    }
    .megamenu-columns {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 20px 20px 60px;
    }
    .megamenu-parent {
      cursor: pointer;
      font-size: 22px;
      padding: 16px 0;
    }
    .megamenu-chevron {
      display: block;
      color: var(--color-blue-deep-800);
    }
    .megamenu-link {
      font-size: 22px;
      padding: 16px 0 16px 24px;
    }
    .megamenu-link--top {
      padding: 16px 0;
    }
    .megamenu-arrow--top {
      display: block;
    }
    .megamenu-chevron,
    .megamenu-arrow {
      width: 24px;
      height: 24px;
    }
    .megamenu-group {
      padding-bottom: 8px;
      margin-bottom: 8px;
    }
    .megamenu-col {
      display: contents;
    }

    .megamenu-group:first-child {
      border-top: none;
      padding-top: 0;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initMegamenu() {
    const megamenu = document.getElementById('megamenu');
    const openBtn1 = document.getElementById('menu-toggle');
    const openBtn2 = document.getElementById('header-menu-toggle');
    const closeBtn = document.getElementById('megamenu-close');
    const openBtns = [openBtn1, openBtn2].filter(Boolean) as HTMLElement[];
    if (!megamenu || openBtns.length === 0 || !closeBtn) return;

    const root = getComputedStyle(document.documentElement);
    const colorPurple = root.getPropertyValue('--color-purple-500').trim();
    const colorRed = root.getPropertyValue('--color-red').trim();
    let isOpen = false;
    let tween: gsap.core.Tween | null = null;
    let activeOpenBtn: HTMLElement = openBtns[0];

    const ac = new AbortController();
    const { signal } = ac;

    // ═══ CIRCLE ORIGIN (center of whichever hamburger was clicked) ═══
    function getOrigin() {
      const rect = activeOpenBtn.getBoundingClientRect();
      const x = ((rect.left + rect.width / 2) / document.documentElement.clientWidth) * 100;
      const y = ((rect.top + rect.height / 2) / document.documentElement.clientHeight) * 100;
      return `${x.toFixed(1)}% ${y.toFixed(1)}%`;
    }

    // ═══ OPEN ═══
    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (isOpen) return;
        activeOpenBtn = btn;
        isOpen = true;
        if (tween) tween.kill();

        const origin = getOrigin();

        ScrollTrigger.normalizeScroll(false);
        const columns = megamenu.querySelector('.megamenu-columns') as HTMLElement;
        if (columns) columns.scrollTop = 0;

        gsap.set(megamenu, { clipPath: `circle(0% at ${origin})` });
        megamenu.style.display = '';
        megamenu.style.pointerEvents = 'auto';
        document.documentElement.style.overflow = 'hidden';

        tween = gsap.to(megamenu, {
          clipPath: `circle(150% at ${origin})`,
          duration: 1,
          ease: 'power3.inOut',
          onComplete: () => {
            megamenu.style.clipPath = 'none';
          },
        });
      }, { signal });
    });

    // ═══ RESTORE normalizeScroll (mirrors Layout.astro logic) ═══
    function restoreNormalizeScroll() {
      const hasPins = ScrollTrigger.getAll().some(st => !!st.pin);
      const hasSnap = ScrollTrigger.getAll().some(st => !!(st as any).snap);
      if (hasPins) {
        ScrollTrigger.normalizeScroll(
          ScrollTrigger.isTouch !== 0
            ? true
            : hasSnap ? { momentum: 0.3 } : false
        );
      }
    }

    // ═══ CLOSE ═══
    function close() {
      if (!isOpen) return;
      isOpen = false;
      if (tween) tween.kill();

      // Unlock scroll immediately — waiting for onComplete blocks scroll on
      // same-page hash navigation (e.g. /#principi while already on /).
      document.documentElement.style.overflow = '';

      const origin = getOrigin();
      gsap.set(megamenu, { clipPath: `circle(150% at ${origin})` });
      tween = gsap.to(megamenu, {
        clipPath: `circle(0% at ${origin})`,
        duration: 0.8,
        ease: 'power3.inOut',
        onComplete: () => {
          megamenu.style.pointerEvents = 'none';
          megamenu.style.display = 'none';
          restoreNormalizeScroll();
        },
      });
    }

    closeBtn.addEventListener('click', close, { signal });

    // Close menu when any link is clicked (critical for same-page hash links
    // like /#principi — Astro ClientRouter doesn't fire astro:before-swap for
    // same-page hashes, so the cleanupPage safety net never runs).
    megamenu.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
      link.addEventListener('click', () => {
        close();
      }, { signal });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) close();
    }, { signal });

    // ═══ INITIAL STATES ═══
    gsap.set('.megamenu-arrow:not(.megamenu-arrow--top)', { autoAlpha: 0, x: -8 });
    megamenu.style.display = 'none';

    // ═══ LINK HOVER ═══
    megamenu.querySelectorAll<HTMLElement>('.megamenu-link').forEach((link) => {
      const arrow = link.querySelector<SVGElement>('.megamenu-arrow');

      link.addEventListener('mouseenter', () => {
        gsap.to(link, { color: colorRed, duration: 0.25, overwrite: true });
        if (arrow) gsap.to(arrow, { autoAlpha: 1, x: 0, color: colorRed, duration: 0.25, overwrite: true });
      }, { signal });

      link.addEventListener('mouseleave', () => {
        gsap.to(link, { color: colorPurple, duration: 0.25, overwrite: true });
        if (arrow) gsap.to(arrow, { autoAlpha: 0, x: -8, duration: 0.2, overwrite: true });
      }, { signal });
    });

    // ═══ CLOSE BUTTON HOVER ═══
    closeBtn.addEventListener('mouseenter', () => {
      gsap.to(closeBtn, { color: colorRed, duration: 0.25, overwrite: true });
    }, { signal });

    closeBtn.addEventListener('mouseleave', () => {
      gsap.to(closeBtn, { color: colorPurple, duration: 0.25, overwrite: true });
    }, { signal });

    // ═══ MOBILE ACCORDION ═══
    const mm = gsap.matchMedia();

    mm.add('(max-width: 767px)', () => {
      const mobileAc = new AbortController();
      const { signal: mobileSignal } = mobileAc;

      megamenu.querySelectorAll('.megamenu-group').forEach((group) => {
        const parent = group.querySelector<HTMLButtonElement>('.megamenu-parent');
        const children = group.querySelector<HTMLElement>('.megamenu-children');
        const chevron = group.querySelector<SVGElement>('.megamenu-chevron');
        if (!parent || !children || !chevron) return;

        // Collapsed by default
        gsap.set(children, { height: 0, overflow: 'hidden' });
        gsap.set(chevron, { rotation: 0 });

        let expanded = false;

        parent.addEventListener('click', () => {
          expanded = !expanded;
          parent.setAttribute('aria-expanded', String(expanded));

          if (expanded) {
            gsap.to(children, { height: 'auto', duration: 0.4, ease: 'power2.out', overwrite: true });
            gsap.to(chevron, { rotation: 180, duration: 0.3, overwrite: true });
          } else {
            gsap.to(children, { height: 0, duration: 0.3, ease: 'power2.in', overwrite: true });
            gsap.to(chevron, { rotation: 0, duration: 0.3, overwrite: true });
          }
        }, { signal: mobileSignal });
      });

      return () => { mobileAc.abort(); };
    });
  }

  ((window as any).__initQueue ??= []).push(initMegamenu);
</script>
