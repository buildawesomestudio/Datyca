<div
  id="leadmagnet-modal"
  class="lm-modal"
  data-state="idle"
  role="dialog"
  aria-modal="true"
  aria-labelledby="leadmagnet-title"
  lang="it"
>
  <div class="lm-modal__backdrop" data-lm-backdrop aria-hidden="true"></div>

  <div class="lm-modal__card" data-lm-card>
    <button
      type="button"
      class="lm-modal__close"
      data-lm-close
      aria-label="Chiudi"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M2 2 L14 14 M14 2 L2 14" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" />
      </svg>
    </button>

    {/* ── FORM ────────────────────────────────────────────────── */}
    <div class="lm-modal__pane lm-modal__pane--form" data-lm-pane="form">
      <p class="lm-modal__kicker">Guida gratuita</p>
      <h2 id="leadmagnet-title" class="lm-modal__title">Scarica la guida</h2>
      <p class="lm-modal__subtitle">
        Inserisci la tua e-mail per ricevere la guida pratica <em>&ldquo;Governare l&rsquo;IA in 10 step&rdquo;</em>.
      </p>

      <form class="lm-modal__form" data-lm-form novalidate>
        {/* Honeypot */}
        <div class="lm-modal__hp" aria-hidden="true">
          <label for="lm-website">Website</label>
          <input type="text" id="lm-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="lm-modal__field">
          <label for="lm-email" class="lm-modal__label">E-mail <span class="lm-modal__required" aria-hidden="true">*</span></label>
          <input
            type="email"
            id="lm-email"
            name="email"
            class="lm-modal__input"
            autocomplete="email"
            required
          />
          <span class="lm-modal__error" data-lm-field-error></span>
        </div>

        <div class="lm-modal__field">
          <label for="lm-nome" class="lm-modal__label">Nome <span class="lm-modal__optional">— facoltativo</span></label>
          <input
            type="text"
            id="lm-nome"
            name="nome"
            class="lm-modal__input"
            autocomplete="given-name"
            maxlength="100"
          />
        </div>

        <div class="lm-modal__field">
          <label for="lm-ruolo" class="lm-modal__label">Ruolo in azienda <span class="lm-modal__optional">— facoltativo</span></label>
          <input
            type="text"
            id="lm-ruolo"
            name="ruolo"
            class="lm-modal__input"
            autocomplete="organization-title"
            maxlength="150"
          />
        </div>

        <div class="lm-modal__consents">
          <div class="lm-modal__consent-wrap" data-lm-privacy-wrap>
            <label class="lm-modal__consent">
              <input type="checkbox" name="consent_privacy" data-lm-privacy required />
              <span class="lm-modal__consent-text">
                Ho preso visione della <a href="/privacy-policy" target="_blank" rel="noopener noreferrer" data-lm-privacy-link>Privacy Policy</a> e acconsento al trattamento dei miei dati per ricevere la guida. <span class="lm-modal__required" aria-hidden="true">*</span>
              </span>
            </label>
            <span class="lm-modal__consent-error" data-lm-privacy-error></span>
          </div>

          <label class="lm-modal__consent">
            <input type="checkbox" name="consent_marketing" />
            <span class="lm-modal__consent-text">
              Voglio ricevere aggiornamenti e approfondimenti di DATYCA su AI Governance, data protection e cybersecurity. Posso revocare il consenso in qualsiasi momento dal link di disiscrizione presente in ogni email.
            </span>
          </label>
        </div>

        {/* Turnstile container — lazy-mounted on first focus */}
        <div id="leadmagnet-turnstile" class="lm-modal__turnstile"></div>

        <p class="lm-modal__banner" data-lm-banner role="alert"></p>

        <button type="button" class="lm-modal__submit text-cta" data-lm-submit>
          <span data-lm-submit-label>SCARICA LA GUIDA</span>
          <svg class="lm-modal__submit-icon" width="22" height="22" aria-hidden="true">
            <use href="#icon-diagonal-down-thick" />
          </svg>
          <svg class="lm-modal__submit-spinner" data-lm-spinner width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-dasharray="50 20" stroke-linecap="round" />
          </svg>
        </button>
      </form>
    </div>

    {/* ── SUCCESS ─────────────────────────────────────────────── */}
    <div class="lm-modal__pane lm-modal__pane--success" data-lm-pane="success" aria-hidden="true">
      <div class="lm-modal__success-circle" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 36 36">
          <path d="M8 18.5 L15 25.5 L28 11.5" stroke="#FFFFFF" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <h2 class="lm-modal__success-title">Grazie!</h2>
      <p class="lm-modal__success-body">
        Riceverai il link per scaricare la guida all&rsquo;indirizzo e-mail indicato entro pochi minuti.
      </p>
      <hr class="lm-modal__success-divider" />
      <p class="lm-modal__success-note">Se non trovi il messaggio, controlla la cartella spam.</p>
    </div>
  </div>
</div>

<style>
  .lm-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    visibility: hidden;
    padding: 16px;
    pointer-events: none;
  }

  .lm-modal[data-state="form"],
  .lm-modal[data-state="loading"],
  .lm-modal[data-state="success"],
  .lm-modal[data-state="error"] {
    pointer-events: auto;
  }

  .lm-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(13, 8, 38, 0.85);
  }

  /* ── CARD ─────────────────────────────────────────────── */
  .lm-modal__card {
    position: relative;
    width: min(640px, calc(100vw - 32px));
    max-height: calc(100dvh - 32px);
    overflow-y: auto;
    overscroll-behavior: contain;
    background: var(--color-white-snow);
    color: var(--color-black-almost-900);
    border: 2px solid var(--color-purple-500);
    border-radius: 0;
    padding: clamp(28px, 4vw, 44px);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55);
    -webkit-overflow-scrolling: touch;
    /* Hide the native scrollbar (the content still scrolls via wheel/touch).
       Removing it also kills the blue accent-color tint on macOS. */
    scrollbar-width: none; /* Firefox */
  }

  .lm-modal__card::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }

  /* ── CLOSE X ──────────────────────────────────────────── */
  .lm-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--color-black-almost-900);
    cursor: pointer;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
    z-index: 2;
  }

  /* ── PANES ─────────────────────────────────────────────── */
  .lm-modal__pane {
    visibility: hidden;
    opacity: 0;
  }

  .lm-modal[data-state="form"]  .lm-modal__pane--form,
  .lm-modal[data-state="loading"] .lm-modal__pane--form,
  .lm-modal[data-state="error"] .lm-modal__pane--form {
    visibility: visible;
  }
  .lm-modal[data-state="success"] .lm-modal__pane--success {
    visibility: visible;
  }

  .lm-modal__pane--success {
    position: absolute;
    inset: 0;
    padding: clamp(28px, 4vw, 44px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
  }

  /* ── FORM HEAD ─────────────────────────────────────────── */
  .lm-modal__kicker {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 12px;
    line-height: 16px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-purple-500);
    margin: 0 0 10px;
  }

  .lm-modal__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(30px, 4vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-black-almost-900);
    margin: 0 0 10px;
  }

  .lm-modal__subtitle {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-black-almost-900);
    margin: 0 0 22px;
    opacity: 0.78;
  }

  .lm-modal__subtitle em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    opacity: 1;
  }

  /* ── FORM ──────────────────────────────────────────────── */
  .lm-modal__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .lm-modal__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lm-modal__label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 12px;
    line-height: 1.3;
    color: var(--color-black-almost-900);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .lm-modal__required {
    color: var(--color-purple-500);
  }

  .lm-modal__optional {
    font-weight: 500;
    color: #6B6786;
    letter-spacing: 0.08em;
  }

  .lm-modal__input {
    width: 100%;
    padding: 14px 16px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.4;
    background: transparent;
    color: var(--color-black-almost-900);
    border: 2px solid var(--color-black-almost-900);
    border-radius: 0;
    outline: none;
    -webkit-appearance: none;
  }

  /* Reserve space for password-manager autofill badges on the email field
     (1Password, iCloud Keychain, Bitwarden). Prevents the badge from
     resizing the input on focus and jumping the flex-centered modal up. */
  .lm-modal__input[type="email"] {
    padding-right: 44px;
  }

  .lm-modal__input:focus {
    border-color: var(--color-purple-500);
  }

  .lm-modal__input:-webkit-autofill,
  .lm-modal__input:-webkit-autofill:hover,
  .lm-modal__input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px var(--color-white-snow) inset;
    -webkit-text-fill-color: var(--color-black-almost-900);
  }

  .lm-modal__field--error .lm-modal__input {
    border-color: var(--color-red);
  }

  .lm-modal__error {
    display: none;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-red);
  }

  .lm-modal__field--error .lm-modal__error {
    display: block;
  }

  /* ── CONSENTS ──────────────────────────────────────────── */
  .lm-modal__consents {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 6px;
  }

  .lm-modal__consent {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }

  /* Branded checkbox: flat 2px black border, zero radius, purple fill when checked.
     Matches the input field aesthetic — avoids the native OS widget look. */
  .lm-modal__consent input[type="checkbox"] {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin: 2px 0 0;
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 2px solid var(--color-black-almost-900);
    border-radius: 0;
    cursor: pointer;
    position: relative;
    display: grid;
    place-content: center;
    padding: 0;
  }

  .lm-modal__consent input[type="checkbox"]:checked {
    background: var(--color-purple-500);
    border-color: var(--color-purple-500);
  }

  .lm-modal__consent input[type="checkbox"]:checked::after {
    content: '';
    width: 10px;
    height: 5px;
    border-left: 2px solid var(--color-white-almost);
    border-bottom: 2px solid var(--color-white-almost);
    /* Translate nudge centers the check inside the 16×16 inner area */
    transform: translate(0, -2px) rotate(-45deg);
  }

  .lm-modal__consent input[type="checkbox"]:focus-visible {
    border-color: var(--color-purple-500);
  }

  .lm-modal__consent-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lm-modal__consent-error {
    display: none;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-red);
    padding-left: 32px; /* align with consent text (checkbox 20 + gap 12) */
  }

  .lm-modal__consent-wrap--error .lm-modal__consent input[type="checkbox"] {
    border-color: var(--color-red);
  }

  .lm-modal__consent-wrap--error .lm-modal__consent-error {
    display: block;
  }

  .lm-modal__consent-text {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-black-almost-900);
  }

  .lm-modal__consent-text a {
    color: var(--color-purple-500);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }

  /* ── TURNSTILE ───────────────────────────────────────────
     `appearance: interaction-only` keeps the container empty most of the
     time. When Cloudflare escalates to a visible challenge the iframe
     appears — the transition smooths the resulting height change so the
     submit button does not snap down. */
  .lm-modal__turnstile {
    min-height: 0;
    transition: min-height 0.2s ease;
  }
  .lm-modal__turnstile:empty {
    display: none;
  }
  .lm-modal__turnstile:not(:empty) {
    min-height: 70px;
  }

  /* ── BANNER (error) ───────────────────────────────────── */
  .lm-modal__banner {
    display: none;
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-red);
    background: rgba(242, 23, 99, 0.08);
    border-left: 3px solid var(--color-red);
    padding: 12px 14px;
    margin: 0;
  }

  .lm-modal[data-state="error"] .lm-modal__banner {
    display: block;
  }

  /* ── SUBMIT ────────────────────────────────────────────── */
  .lm-modal__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 18px 25px;
    background: var(--color-purple-500);
    color: var(--color-white-almost);
    border: none;
    border-radius: 0;
    cursor: pointer;
    margin-top: 10px;
    -webkit-tap-highlight-color: transparent;
    align-self: stretch;
  }

  .lm-modal__submit:disabled {
    cursor: not-allowed;
  }

  .lm-modal__submit-spinner {
    display: none;
  }

  .lm-modal[data-state="loading"] .lm-modal__submit-icon {
    display: none;
  }
  .lm-modal[data-state="loading"] .lm-modal__submit-spinner {
    display: block;
  }

  /* ── HONEYPOT ──────────────────────────────────────────── */
  .lm-modal__hp {
    position: absolute;
    left: -9999px;
    height: 0;
    overflow: hidden;
  }

  /* ── SUCCESS ───────────────────────────────────────────── */
  .lm-modal__success-circle {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-purple-500);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .lm-modal__success-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(36px, 4.8vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-black-almost-900);
    margin: 0 0 14px;
  }

  .lm-modal__success-body {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-black-almost-900);
    margin: 0 0 20px;
    max-width: 400px;
    opacity: 0.8;
  }

  .lm-modal__success-divider {
    border: none;
    border-top: 1px solid #D9D6D0;
    width: 180px;
    margin: 0 0 14px;
  }

  .lm-modal__success-note {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.4;
    color: #6B6786;
    margin: 0;
  }

  @media (max-width: 520px) {
    .lm-modal__card {
      padding: 28px 22px 32px;
    }
    .lm-modal__title {
      font-size: 30px;
    }
    .lm-modal__submit {
      padding: 16px 20px;
      gap: 14px;
    }
  }
</style>

<script>
  import { registerInit } from '@utils/init';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initLeadMagnetModal() {
    const root = document.getElementById('leadmagnet-modal');
    if (!root) return;

    const backdrop   = root.querySelector('[data-lm-backdrop]') as HTMLElement;
    const card       = root.querySelector('[data-lm-card]') as HTMLElement;
    const closeBtn   = root.querySelector('[data-lm-close]') as HTMLButtonElement;
    const form       = root.querySelector('[data-lm-form]') as HTMLFormElement;
    const submitBtn  = root.querySelector('[data-lm-submit]') as HTMLButtonElement;
    const submitLabel = root.querySelector('[data-lm-submit-label]') as HTMLElement;
    const spinnerEl  = root.querySelector('[data-lm-spinner]') as SVGElement;
    const banner     = root.querySelector('[data-lm-banner]') as HTMLElement;
    const privacyCb  = root.querySelector('[data-lm-privacy]') as HTMLInputElement;
    const emailInput = root.querySelector('#lm-email') as HTMLInputElement;
    const emailField = emailInput.closest('.lm-modal__field') as HTMLElement;
    const emailError = emailField.querySelector('[data-lm-field-error]') as HTMLElement;
    const privacyLink = root.querySelector('[data-lm-privacy-link]') as HTMLAnchorElement;
    const privacyWrap = root.querySelector('[data-lm-privacy-wrap]') as HTMLElement;
    const privacyError = root.querySelector('[data-lm-privacy-error]') as HTMLElement;
    const formPane    = root.querySelector('[data-lm-pane="form"]') as HTMLElement;
    const successPane = root.querySelector('[data-lm-pane="success"]') as HTMLElement;

    // Initial GSAP state (no CSS transitions — Golden Rule).
    // Root stays hidden via the CSS `visibility: hidden` rule — DO NOT set
    // autoAlpha on it (that would pin opacity: 0 on the container and mask
    // every inner animation forever, since we later toggle only visibility).
    gsap.set(card, { autoAlpha: 0, scale: 0.95 });
    gsap.set(backdrop, { autoAlpha: 0 });
    gsap.set(formPane, { autoAlpha: 0 });
    gsap.set(successPane, { autoAlpha: 0 });

    let isOpen = false;
    let autoCloseTimer: number | null = null;
    let lastFocused: HTMLElement | null = null;
    let previousOverflow = '';
    let spinnerTween: gsap.core.Tween | null = null;

    // ── State management ─────────────────────────────
    type LMState = 'idle' | 'form' | 'loading' | 'success' | 'error';

    function setState(state: LMState, message?: string) {
      root.setAttribute('data-state', state);
      if (state === 'loading') {
        submitBtn.disabled = true;
        submitLabel.textContent = 'INVIO IN CORSO';
        banner.textContent = '';
        startSpinner();
      } else {
        submitBtn.disabled = false;
        stopSpinner();
        if (state === 'error') {
          submitLabel.textContent = 'SCARICA LA GUIDA';
          banner.textContent = message || 'Errore sconosciuto. Riprova.';
        } else if (state === 'form') {
          submitLabel.textContent = 'SCARICA LA GUIDA';
          banner.textContent = '';
        }
      }
    }

    function startSpinner() {
      if (spinnerTween) return;
      gsap.set(spinnerEl, { rotation: 0, transformOrigin: '50% 50%' });
      spinnerTween = gsap.to(spinnerEl, {
        rotation: 360,
        duration: 0.8,
        repeat: -1,
        ease: 'none',
      });
    }
    function stopSpinner() {
      if (spinnerTween) {
        spinnerTween.kill();
        spinnerTween = null;
      }
      gsap.set(spinnerEl, { rotation: 0 });
    }

    // ── Open / close with GSAP ──────────────────────
    function openModal() {
      if (isOpen) return;
      isOpen = true;
      lastFocused = document.activeElement as HTMLElement;
      previousOverflow = document.documentElement.style.overflow;
      document.documentElement.style.overflow = 'hidden';

      setState('form');
      gsap.set(successPane, { autoAlpha: 0 });
      gsap.set(root, { visibility: 'visible' });

      const tl = gsap.timeline();
      tl.to(backdrop,  { autoAlpha: 1, duration: 0.25, ease: 'power2.out' }, 0)
        .to(card,      { autoAlpha: 1, scale: 1, duration: 0.35, ease: 'power2.out' }, 0)
        .to(formPane,  { autoAlpha: 1, duration: 0.3, ease: 'power2.out' }, 0.1);

      // No programmatic email focus: triggering focus on an <input type="email">
      // while the open animation is still running causes password managers
      // (1Password, iCloud Keychain) to inject an autofill badge that resizes
      // the input, which re-centers the flex-centered modal and produces a
      // visible "jump" upward. Let the user focus manually — that keeps the
      // autofill UX intact without the layout shift.

      // Best-effort: ensure Turnstile is already loading when the modal opens,
      // so the widget is ready by the time the user reaches submit.
      (window as any).datycaTurnstile?.load();
    }

    function closeModal() {
      if (!isOpen) return;
      isOpen = false;
      if (autoCloseTimer !== null) {
        clearTimeout(autoCloseTimer);
        autoCloseTimer = null;
      }
      stopSpinner();

      const tl = gsap.timeline({
        onComplete: () => {
          gsap.set(root, { visibility: 'hidden' });
          gsap.set(card, { scale: 0.95 });
          document.documentElement.style.overflow = previousOverflow || '';
          setState('form');
          gsap.set(formPane,    { autoAlpha: 0 });
          gsap.set(successPane, { autoAlpha: 0 });
          form.reset();
          clearFieldError();
          clearPrivacyError();
          if ((window as any).turnstile && turnstileWidgetId !== null) {
            try { (window as any).turnstile.reset(turnstileWidgetId); } catch { /* ignore */ }
          }
          lastFocused?.focus?.();
          // Safety net: force ScrollTrigger to recompute start/end with the
          // scrollbar-gutter-stable viewport restored. Handles edge cases
          // where a spurious refresh during the modal lifetime left some
          // once:true reveal triggers in a stale "already passed" state,
          // so their onEnter never fires when the user resumes scrolling.
          requestAnimationFrame(() => ScrollTrigger.refresh());
        },
      });
      tl.to(card,     { autoAlpha: 0, scale: 0.95, duration: 0.25, ease: 'power2.in' }, 0)
        .to(backdrop, { autoAlpha: 0, duration: 0.25, ease: 'power2.in' }, 0);
    }

    // ── Pane crossfade form → success ────────────
    function showSuccessPane() {
      const tl = gsap.timeline();
      tl.to(formPane,    { autoAlpha: 0, y: -6, duration: 0.25, ease: 'power2.in' }, 0)
        .call(() => setState('success'), [], 0.25)
        .fromTo(successPane, { autoAlpha: 0, y: 6 }, { autoAlpha: 1, y: 0, duration: 0.3, ease: 'power2.out' }, 0.25);
    }

    // ── Validation (click-time, no disabled-until-valid) ────────
    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function showFieldError(msg: string) {
      emailField.classList.add('lm-modal__field--error');
      emailError.textContent = msg;
    }
    function clearFieldError() {
      emailField.classList.remove('lm-modal__field--error');
      emailError.textContent = '';
    }

    function showPrivacyError(msg: string) {
      privacyWrap.classList.add('lm-modal__consent-wrap--error');
      privacyError.textContent = msg;
    }
    function clearPrivacyError() {
      privacyWrap.classList.remove('lm-modal__consent-wrap--error');
      privacyError.textContent = '';
    }

    // Clear privacy error as soon as the user ticks the box
    privacyCb.addEventListener('change', () => {
      if (privacyCb.checked) clearPrivacyError();
    });

    emailInput.addEventListener('input', () => {
      if (!emailField.classList.contains('lm-modal__field--error')) return;
      if (EMAIL_RE.test(emailInput.value.trim())) clearFieldError();
    });
    emailInput.addEventListener('blur', () => {
      const val = emailInput.value.trim();
      if (val.length === 0) return;
      if (!EMAIL_RE.test(val)) showFieldError('Inserisci un\'email valida');
      else clearFieldError();
    });

    // ── Turnstile: use the shared loader declared in Layout.astro ──
    // Script fetch is already scheduled on requestIdleCallback at window.load;
    // openModal() above also calls load() defensively. We only need to render
    // the widget into our local container once the loader reports ready.
    const TURNSTILE_SITE_KEY = '0x4AAAAAAC97pyXgUgHeiHAx';
    let turnstileWidgetId: string | null = null;

    function renderTurnstileWidget() {
      if (turnstileWidgetId !== null) return;
      const container = document.getElementById('leadmagnet-turnstile');
      if (!container || !(window as any).turnstile) return;
      turnstileWidgetId = (window as any).turnstile.render(container, {
        sitekey: TURNSTILE_SITE_KEY,
        appearance: 'interaction-only',
        theme: 'light',
      });
    }

    (window as any).datycaTurnstile?.onReady((ok: boolean) => {
      if (ok) renderTurnstileWidget();
    });

    // ── Hovers ──────────────────────────────────
    privacyLink?.addEventListener('mouseenter', () => {
      gsap.to(privacyLink, { color: '#F21763', duration: 0.2, overwrite: true });
    });
    privacyLink?.addEventListener('mouseleave', () => {
      gsap.to(privacyLink, { color: '#4545F7', duration: 0.2, overwrite: true });
    });

    submitBtn.addEventListener('mouseenter', () => {
      if (submitBtn.disabled) return;
      gsap.to(submitBtn, { backgroundColor: '#6666FF', duration: 0.25, overwrite: true });
    });
    submitBtn.addEventListener('mouseleave', () => {
      gsap.to(submitBtn, { backgroundColor: '#4545F7', duration: 0.25, overwrite: true });
    });

    closeBtn.addEventListener('mouseenter', () => {
      gsap.to(closeBtn, { color: '#F21763', duration: 0.2, overwrite: true });
    });
    closeBtn.addEventListener('mouseleave', () => {
      gsap.to(closeBtn, { color: '#0D0826', duration: 0.2, overwrite: true });
    });

    // ── Close interactions ────────────────────────
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeModal();
      } else if (e.key === 'Tab') {
        const focusables = card.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        );
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last  = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement;
        if (e.shiftKey && active === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // ── Submit flow ──────────────────────────────
    function shakeButton() {
      gsap.to(submitBtn, {
        x: [-8, 8, -6, 6, -3, 3, 0],
        duration: 0.5,
        ease: 'power2.out',
      });
    }

    async function submit() {
      if (submitBtn.disabled) return;

      // Validate at click-time (Contatti pattern — no disabled-until-valid).
      const email = emailInput.value.trim();
      let valid = true;

      if (!EMAIL_RE.test(email)) {
        showFieldError('Inserisci un\'email valida');
        valid = false;
      } else {
        clearFieldError();
      }

      if (!privacyCb.checked) {
        showPrivacyError('Per ricevere la guida è necessario accettare la Privacy Policy.');
        valid = false;
      } else {
        clearPrivacyError();
      }

      if (!valid) {
        shakeButton();
        return;
      }

      // Turnstile gating — same pattern as Contatti: wait for readiness with
      // visible feedback, fall back to a human email if the CDN is down.
      const T = (window as any).datycaTurnstile;
      if (T) {
        T.load();
        if (T.state !== 'ready' && T.state !== 'failed') {
          setState('loading');
        }
        const ready = await new Promise<boolean>((resolve) => T.onReady(resolve));
        if (!ready) {
          setState('error', 'Verifica antispam non disponibile. Scrivici a info@datyca.com per ricevere la guida.');
          return;
        }
        renderTurnstileWidget();
      }

      // Poll the widget for a token — it generates one shortly after render.
      let turnstileToken = '';
      const tokenDeadline = Date.now() + 3000;
      while (Date.now() < tokenDeadline) {
        if ((window as any).turnstile && turnstileWidgetId !== null) {
          turnstileToken = (window as any).turnstile.getResponse(turnstileWidgetId) || '';
          if (turnstileToken) break;
        }
        await new Promise(r => setTimeout(r, 150));
      }
      if (!turnstileToken) {
        setState('error', 'Verifica antispam non completata. Riprova tra qualche secondo.');
        return;
      }

      setState('loading');

      const fd = new FormData(form);
      const payload = {
        email,
        nome:   String(fd.get('nome')  || ''),
        ruolo:  String(fd.get('ruolo') || ''),
        consent_privacy:   !!fd.get('consent_privacy'),
        consent_marketing: !!fd.get('consent_marketing'),
        website: String(fd.get('website') || ''),
        'cf-turnstile-response': turnstileToken,
      };

      try {
        const res = await fetch('/lead-magnet.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        let data: any = {};
        try { data = await res.json(); } catch { /* non-JSON */ }

        if (res.ok && data && data.ok) {
          showSuccessPane();
          autoCloseTimer = window.setTimeout(closeModal, 8000);
        } else {
          const msg = (data && data.message) ? data.message : 'Errore sconosciuto. Riprova.';
          setState('error', msg);
          if ((window as any).turnstile && turnstileWidgetId !== null) {
            try { (window as any).turnstile.reset(turnstileWidgetId); } catch { /* ignore */ }
          }
        }
      } catch {
        setState('error', 'Connessione fallita. Riprova.');
      }
    }

    submitBtn.addEventListener('click', submit);

    // Enter key on single-line inputs triggers submit
    form.querySelectorAll<HTMLInputElement>('input[type="email"], input[type="text"]').forEach(inp => {
      inp.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          submit();
        }
      });
    });

    // ── External open trigger ─────────────────────
    window.addEventListener('datyca:leadmagnet:open', openModal);
  }

  registerInit(initLeadMagnetModal);
</script>
