<header id="header">
  <div class="header-inner">
    <a href="/" class="header-logo">
      <img src="/images/logo-full.svg" alt="Datyca - Legal Design Lab" width="220" height="68" class="header-logo-full" />
      <img src="/images/monogramma-full.svg" alt="Datyca" width="40" height="40" class="header-logo-mono" />
    </a>

    <nav id="header-nav">
      {navItems.map((item) =>
        item.children ? (
          <div class="nav-item">
            <button
              class="nav-link"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <span>{item.label}</span>
              <svg class="nav-chevron" width="10" height="10" aria-hidden="true"><use href="#icon-chevron-down" /></svg>
            </button>
            <div class="nav-dropdown" role="menu">
              {item.children.map((child) => (
                <a href={child.href} class="dropdown-item" role="menuitem">
                  <span>{child.label}</span>
                  <svg class="dropdown-arrow" width="20" height="20" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="nav-item">
            <a href={item.href} class="nav-link">
              <span>{item.label}</span>
              <svg class="nav-chevron nav-chevron--static" width="10" height="10" aria-hidden="true"><use href="#icon-chevron-down" /></svg>
            </a>
          </div>
        )
      )}
    </nav>

    <button id="header-menu-toggle" class="header-hamburger" aria-label="Apri menu">
      <svg width="32" height="22" aria-hidden="true" fill="currentColor"><use href="#icon-hamburger" /></svg>
    </button>
  </div>
</header>

<style>
  #header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 120px;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    height: 100%;
    padding: 0 40px;
  }

  .header-logo {
    display: flex;
    align-items: center;
    height: 100%;
    position: relative;
  }

  .header-logo-full {
    width: 220px;
    height: auto;
  }

  .header-logo-mono {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    margin: auto;
    width: 40px;
    height: 40px;
    visibility: hidden;
  }

  #header-nav {
    display: none;
    align-items: center;
    align-self: stretch;
    padding-top: 60px;
    gap: 8px;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: none;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    line-height: 20px;
    letter-spacing: 0;
    padding: 20px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-chevron {
    visibility: hidden;
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    width: 340px;
    background: var(--color-bg);
    border: 2px solid var(--color-purple-500);
    box-shadow: 0px 4px 40px 0px rgb(from var(--color-purple-500) r g b / 0.3);
    padding: 20px 40px;
    visibility: hidden;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    line-height: 20px;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0;
  }

  .dropdown-arrow {
    visibility: hidden;
    flex-shrink: 0;
  }

  .header-hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 15px;
    margin-right: -15px;
    color: var(--color-purple-600);
  }

  @media (max-width: 767px) {
    #header {
      height: 80px;
    }
    .header-inner {
      padding: 0 20px;
    }
    .header-logo-full {
      width: 160px;
    }
    #header-nav {
      padding-top: 0;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  function initHeader() {
    const header = document.getElementById('header');
    if (!header) return;

    const nav = document.getElementById('header-nav') as HTMLElement;
    const hamburger = document.getElementById('header-menu-toggle') as HTMLElement;
    const logoEl = header.querySelector('.header-logo') as HTMLElement;
    if (!nav || !hamburger || !logoEl) return;

    // ═══ FIT DETECTION: nav vs hamburger ═══
    // Measured before any hiding — init runs before first paint
    let cachedNavWidth = nav.scrollWidth;
    const FIT_GAP = 80;

    function checkNavFit() {
      const fits = (logoEl.offsetWidth + cachedNavWidth + FIT_GAP) <= innerWidth;
      if (fits) {
        nav.style.display = 'flex';
        hamburger.style.display = 'none';
      } else {
        nav.style.display = 'none';
        hamburger.style.display = 'flex';
      }
    }

    checkNavFit();

    // Re-measure after fonts load (widths may change)
    document.fonts.ready.then(() => {
      const wasHidden = nav.style.display === 'none';
      if (wasHidden) {
        nav.style.visibility = 'hidden';
        nav.style.position = 'absolute';
        nav.style.display = 'flex';
      }
      cachedNavWidth = nav.scrollWidth;
      if (wasHidden) {
        nav.style.visibility = '';
        nav.style.position = '';
        nav.style.display = 'none';
      }
      checkNavFit();
    });

    // Debounced resize check
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(checkNavFit, 200);
    });

    // ═══ HAMBURGER HOVER ═══
    const root = getComputedStyle(document.documentElement);
    const colorRed = root.getPropertyValue('--color-red').trim();
    const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();

    hamburger.addEventListener('mouseenter', () => {
      gsap.to(hamburger, { color: colorRed, duration: 0.2, overwrite: true });
    });
    hamburger.addEventListener('mouseleave', () => {
      gsap.to(hamburger, { color: colorPurple600, duration: 0.2, overwrite: true });
    });

    // ═══ NAV INTERACTIONS (desktop hover) ═══
    const mm = gsap.matchMedia();

    mm.add('(min-width: 768px)', () => {
      const colorPurple = root.getPropertyValue('--color-purple-500').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      const ac = new AbortController();
      const { signal } = ac;

      // ═══ INITIAL STATES (gsap.set, not CSS) ═══
      gsap.set(header.querySelectorAll('.nav-chevron'), { autoAlpha: 0 });
      gsap.set(header.querySelectorAll('.nav-dropdown'), { autoAlpha: 0, y: -8, xPercent: -50 });
      gsap.set(header.querySelectorAll('.dropdown-arrow'), { autoAlpha: 0, x: -8 });

      const navItems = header.querySelectorAll<HTMLElement>('.nav-item');
      let activeItem: HTMLElement | null = null;

      navItems.forEach((item) => {
        const link = item.querySelector<HTMLElement>('.nav-link')!;
        const chevron = item.querySelector<SVGElement>('.nav-chevron');
        const dropdown = item.querySelector<HTMLElement>('.nav-dropdown');

        const hasDropdown = !!dropdown;

        item.addEventListener('mouseenter', () => {
          gsap.to(link, { color: colorPurple, duration: 0.25, overwrite: true });
          if (chevron && hasDropdown) gsap.to(chevron, { autoAlpha: 1, duration: 0.25, overwrite: true });
          if (hasDropdown) {
            if (activeItem && activeItem !== item) closeActive();
            openDropdown(item);
          }
        }, { signal });

        item.addEventListener('mouseleave', () => {
          gsap.to(link, { color: colorText, duration: 0.25, overwrite: true });
          if (chevron && hasDropdown) gsap.to(chevron, { autoAlpha: 0, duration: 0.25, overwrite: true });
          if (hasDropdown && activeItem === item) closeActive();
        }, { signal });
      });

      header.querySelectorAll<HTMLElement>('.dropdown-item').forEach((item) => {
        const arrow = item.querySelector<SVGElement>('.dropdown-arrow')!;

        item.addEventListener('mouseenter', () => {
          gsap.to(item, { color: colorPurple, duration: 0.25, overwrite: true });
          gsap.to(arrow, { autoAlpha: 1, x: 0, duration: 0.25, ease: 'power2.out', overwrite: true });
        }, { signal });

        item.addEventListener('mouseleave', () => {
          gsap.to(item, { color: colorText, duration: 0.25, overwrite: true });
          gsap.to(arrow, { autoAlpha: 0, x: -8, duration: 0.2, overwrite: true });
        }, { signal });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && activeItem) closeActive();
      }, { signal });

      function openDropdown(item: HTMLElement) {
        activeItem = item;
        const link = item.querySelector<HTMLElement>('.nav-link')!;
        const chevron = item.querySelector<SVGElement>('.nav-chevron')!;
        const dropdown = item.querySelector<HTMLElement>('.nav-dropdown')!;

        link.setAttribute('aria-expanded', 'true');
        gsap.to(link, { color: colorPurple, duration: 0.25, overwrite: true });
        gsap.to(chevron, { autoAlpha: 1, rotation: 180, duration: 0.3, overwrite: true });
        gsap.to(dropdown, { autoAlpha: 1, y: 0, duration: 0.3, ease: 'power2.out', overwrite: true });
      }

      function closeActive() {
        if (!activeItem) return;
        const item = activeItem;
        const link = item.querySelector<HTMLElement>('.nav-link')!;
        const chevron = item.querySelector<SVGElement>('.nav-chevron')!;
        const dropdown = item.querySelector<HTMLElement>('.nav-dropdown')!;

        link.setAttribute('aria-expanded', 'false');
        gsap.to(link, { color: colorText, duration: 0.25, overwrite: true });
        gsap.to(chevron, { autoAlpha: 0, rotation: 0, duration: 0.25, overwrite: true });
        gsap.to(dropdown, { autoAlpha: 0, y: -8, duration: 0.2, overwrite: true });

        dropdown.querySelectorAll<HTMLElement>('.dropdown-item').forEach((di) => {
          gsap.set(di, { color: colorText });
        });
        dropdown.querySelectorAll<SVGElement>('.dropdown-arrow').forEach((arrow) => {
          gsap.set(arrow, { autoAlpha: 0, x: -8 });
        });

        activeItem = null;
      }

      return () => { ac.abort(); };
    });
  }

  ((window as any).__initQueue ??= []).push(initHeader);
</script>
