---
import Section from './Section.astro';

const cards = [
  {
    title: 'ISO/IEC 42001',
    description: 'Siamo tra le prime società in Italia certificate per i Sistemi di Gestione dell\'Intelligenza Artificiale.',
    icon: '/images/why-datyca/iso-42001.webp',
    alt: 'Certificazione ISO/IEC 42001',
  },
  {
    title: 'AIGP (IAPP)',
    description: 'I nostri professionisti sono certificati AIGP, qualifica di riferimento a livello internazionale per la governance dell\'intelligenza artificiale.',
    icon: '/images/why-datyca/aigp.webp',
    alt: 'Certificazione AIGP IAPP',
  },
  {
    title: 'Alta formazione',
    description: 'Docenti e ideatori di percorsi di alta formazione universitaria in materia di governance dell\'intelligenza artificiale.',
    icon: '/images/why-datyca/alta-formazione.svg',
    alt: 'Alta formazione',
  },
  {
    title: 'Legal Tech',
    description: 'Sviluppiamo piattaforme e strumenti digitali per la gestione integrata della compliance in materia di AI, privacy e cybersecurity.',
    icon: '/images/why-datyca/legal-tech.svg',
    alt: 'Legal Tech',
  },
  {
    title: 'Ricerca applicata',
    description: 'Promotori di TAIG Lab, centro studi indipendente dedicato alla ricerca applicata sulla Technical AI Governance.',
    icon: '/images/why-datyca/ricerca-applicata.svg',
    alt: 'Ricerca applicata',
  },
];
---

<Section id="why-datyca">
  <h2 class="text-h2 why-claim">
    Investiamo in <em>competenze</em>, <em>standard</em> e <em>tecnologie</em><br />
    per garantire ai nostri clienti il massimo livello di affidabilità.
  </h2>

  <div class="why-grid" id="why-grid">
    {cards.map((card) => (
      <div class="why-card">
        <img src={card.icon} alt={card.alt} width="120" height="120" class="why-card__icon" loading="lazy" decoding="async" />
        <h3 class="text-para-title why-card__title">{card.title}</h3>
        <p class="text-regular">{card.description}</p>
      </div>
    ))}
    <div class="why-card why-card--cta">
      <a href="/chi-siamo/metodo" class="text-cta why-cta" id="why-cta">
        <span>SCOPRI COME LAVORIAMO</span>
        <svg width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
      </a>
    </div>
  </div>
</Section>

<style>
  /* ── FOUC gate ── */
  .why-claim {
    font-family: var(--font-serif);
    letter-spacing: -0.04em;
    line-height: 1.15;
    visibility: hidden;
  }

  .why-claim :global(br) {
    display: none;
  }

  @media (min-width: 740px) {
    .why-claim :global(br) {
      display: inline;
    }
  }

  .why-claim em {
    color: var(--color-red);
    font-style: italic;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(40px, 4vw, 60px);
  }

  .why-card {
    padding: var(--card-padding);
    display: flex;
    flex-direction: column;
    border-right: 2px solid var(--grid-border-color);
    border-bottom: 2px solid var(--grid-border-color);
  }

  /* First row: top border */
  .why-card:nth-child(-n+3) {
    border-top: 2px solid var(--grid-border-color);
  }

  /* First column: left border */
  .why-card:nth-child(3n+1) {
    border-left: 2px solid var(--grid-border-color);
  }

  .why-card__icon {
    width: 120px;
    height: 120px;
    margin-bottom: 30px;
    object-fit: contain;
    object-position: left center;
  }

  /* ISO/IEC WebP has slightly larger content than AIGP — scale down to match. */
  .why-card__icon[src*="iso-42001"] {
    transform: scale(0.93);
    transform-origin: left center;
  }

  .why-card__title {
    color: var(--color-red);
    margin-bottom: 30px;
    text-transform: uppercase;
  }

  .why-card--cta {
    justify-content: flex-end;
    align-items: flex-end;
    border: none;
  }

  .why-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    text-decoration: none;
  }

  /* ── Tablet: 2 columns ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Undo 3-column border rules */
    .why-card:nth-child(-n+3) {
      border-top: none;
    }
    .why-card:nth-child(3n+1) {
      border-left: none;
    }

    /* 2-column: first row (first 2) get top border */
    .why-card:nth-child(-n+2) {
      border-top: 2px solid var(--grid-border-color);
    }

    /* 2-column: odd children = left column → left border */
    .why-card:nth-child(odd) {
      border-left: 2px solid var(--grid-border-color);
    }
  }

  /* ── Mobile: 1 column ── */
  @media (max-width: 767px) {
    .why-grid {
      grid-template-columns: 1fr;
    }

    /* All cards get left border */
    .why-card {
      border-left: 2px solid var(--grid-border-color);
    }

    /* Only first card gets top border */
    .why-card:nth-child(-n+3) {
      border-top: none;
    }
    .why-card:first-child {
      border-top: 2px solid var(--grid-border-color);
    }

    .why-card__icon {
      width: 80px;
      height: 80px;
      margin-bottom: 20px;
    }
    .why-card__title {
      margin-bottom: 20px;
    }

    /* CTA: standalone button below the grid (border already none from base) */
    .why-card--cta {
      padding: 0;
      margin-top: 32px;
      align-items: flex-start;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function initWhyDatyca() {
    const section = document.getElementById('why-datyca');
    if (!section) return;

    // Survives matchMedia revert — tracks whether entrance has played
    let hasRevealed = false;

    function setupWhyDatyca() {
      const root = getComputedStyle(document.documentElement);
      const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      const claimEl = section.querySelector('.why-claim') as HTMLElement;
      const cards = section.querySelectorAll<HTMLElement>('.why-card');
      const cta = section.querySelector<HTMLElement>('#why-cta');

      if (hasRevealed) {
        if (claimEl) gsap.set(claimEl, { autoAlpha: 1 });
        gsap.set(cards, { autoAlpha: 1, y: 0 });
      } else {
        gsap.set(cards, { autoAlpha: 0, y: 30 });

        const tl = gsap.timeline({ paused: true });

        if (claimEl) {
          gsap.set(claimEl, { autoAlpha: 1 });
          const wordSplit = SplitText.create(claimEl, { type: 'words', aria: 'none' });
          gsap.set(wordSplit.words, { autoAlpha: 0, y: 25 });

          tl.to(wordSplit.words, {
            autoAlpha: 1, y: 0,
            duration: 0.7, stagger: 0.1,
            ease: 'power3.out',
          }, 0);

          tl.eventCallback('onComplete', () => {
            wordSplit.revert();
          });
        }

        // Cards staggered
        tl.to(cards, {
          autoAlpha: 1, y: 0,
          duration: 0.7, stagger: 0.16,
          ease: 'power2.out',
        }, 0.4);

        ScrollTrigger.create({
          id: 'why-datyca-reveal',
          trigger: section,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            hasRevealed = true;
            tl.play();
          },
        });
      }

      // CTA hover
      const ac = new AbortController();
      if (cta) {
        const ctaArrow = cta.querySelector('svg') as SVGElement;

        cta.addEventListener('mouseenter', () => {
          gsap.to(cta, { borderColor: colorPurple600, color: colorPurple600, duration: 0.25, overwrite: 'auto' });
          if (ctaArrow) gsap.to(ctaArrow, { x: 5, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
        }, { signal: ac.signal });

        cta.addEventListener('mouseleave', () => {
          gsap.to(cta, { borderColor: colorText, color: colorText, duration: 0.25, overwrite: 'auto' });
          if (ctaArrow) gsap.to(ctaArrow, { x: 0, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
        }, { signal: ac.signal });
      }

      return () => { ac.abort(); };
    }

    const mm = gsap.matchMedia();
    mm.add('(min-width: 768px)', setupWhyDatyca);
    mm.add('(max-width: 767px)', setupWhyDatyca);
  }

  ((window as any).__initQueue ??= []).push(initWhyDatyca);
</script>
