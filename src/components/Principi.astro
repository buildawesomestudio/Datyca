---
// Lottie animations loaded at runtime via lottie-web (SVG renderer)
---

<section id="principi">
  <div class="tp-inner">
    <div class="tp-header">
      <h2 class="text-section-title">I nostri principi</h2>
      <p class="text-body">I valori che guidano la nostra idea di innovazione responsabile</p>
    </div>

    <div class="tp-states">
      <div class="tp-state" data-state="0">
        <div class="tp-placeholder">
          <div class="tp-lottie" aria-hidden="true"></div>
        </div>
        <h3 class="text-hero tp-state__title">
          Facilitiamo il <em>cambiamento</em>
        </h3>
        <p class="text-body tp-state__desc">Siamo al fianco delle persone e delle organizzazioni nei momenti di transizione tecnologica. Trasformiamo la complessità in scelte concrete, rendendo l'adozione dell'intelligenza artificiale un percorso sostenibile, comprensibile e umano.</p>
      </div>

      <div class="tp-state" data-state="1">
        <div class="tp-placeholder">
          <div class="tp-lottie" aria-hidden="true"></div>
        </div>
        <h3 class="text-hero tp-state__title">
          Semplifichiamo la <em>complessità</em>
        </h3>
        <p class="text-body tp-state__desc">Applichiamo metodologie tipiche del Legal Design per rendere la compliance accessibile. Traduciamo la complessità normativa e i processi tecnologici in esperienze chiare e inclusive, capaci di generare la fiducia degli stakeholder.</p>
      </div>

      <div class="tp-state" data-state="2">
        <div class="tp-placeholder">
          <div class="tp-lottie" aria-hidden="true"></div>
        </div>
        <h3 class="text-hero tp-state__title">
          Progettiamo la <em>fiducia</em>
        </h3>
        <p class="text-body tp-state__desc">Rendiamo la fiducia un elemento concreto di governance e di design. La integriamo nei modelli organizzativi e nelle interfacce dei sistemi di intelligenza artificiale per creare interazioni trasparenti, sicure e responsabili tra persone e tecnologia.</p>
      </div>

      <div class="tp-state" data-state="3">
        <div class="tp-placeholder">
          <div class="tp-lottie" aria-hidden="true"></div>
        </div>
        <h3 class="text-hero tp-state__title">
          Mescoliamo <em>competenze</em>
        </h3>
        <p class="text-body tp-state__desc">Integriamo diritto, strategia e tecnologia in un linguaggio comune. Creiamo soluzioni che siano insieme conformi alla cornice normativa di riferimento, etiche e orientate al futuro.</p>
      </div>
    </div>
  </div>
</section>

<style>
  #principi {
    height: 100vh;
    height: 100dvh;
    position: relative;
    overflow: hidden;
    background: var(--color-white-snow);
    color: var(--color-black-almost-900);
  }

  .tp-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 70px) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }

  .tp-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--section-gap);
  }

  .tp-states {
    display: grid;
    grid-template-columns: 1fr;
    align-content: center;
    flex: 1;
    margin-top: clamp(20px, 2vw, 40px);
    width: 100%;
    text-align: center;
  }

  .tp-state {
    grid-row: 1 / -1;
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(24px, 3vw, 40px);
  }

  .tp-placeholder {
    width: clamp(160px, 30vw, 260px);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tp-lottie {
    width: 100%;
    height: 100%;
  }

  .tp-state__title {
    color: var(--color-black-almost-900);
  }

  .tp-state__title em {
    font-style: italic;
    color: var(--color-red);
  }

  .tp-state__desc {
    max-width: 540px;
  }

  /* ═══ MOBILE: no pin, all states visible in normal scroll ═══ */
  @media (max-width: 767px) {
    #principi {
      height: auto;
      overflow: visible;
    }

    .tp-inner {
      height: auto;
      padding: 100px var(--section-padding-x) clamp(48px, 8vw, 80px);
    }

    .tp-states {
      flex: initial;
      margin-top: clamp(40px, 8vw, 64px);
      gap: clamp(64px, 14vw, 100px);
    }

    .tp-state {
      grid-row: auto;
      grid-column: auto;
      gap: clamp(16px, 4vw, 28px);
      min-width: 0;
    }

    .tp-placeholder {
      width: clamp(160px, 45vw, 260px);
    }

    .tp-state__title,
    .tp-state__desc {
      width: 100%;
    }
  }
</style>

<style is:global>
  .pin-spacer:has(> #principi) {
    background-color: var(--color-white-snow) !important;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import lottie from 'lottie-web';

  const ANIM_PATHS = [
    '/animations/principio-1.json',
    '/animations/principio-2.json',
    '/animations/principio-3.json',
    '/animations/principio-4.json',
  ];

  function initPrincipi() {
    const section = document.getElementById('principi');
    if (!section) return;

    const containers = Array.from(section.querySelectorAll<HTMLElement>('.tp-lottie'));
    let anims: ReturnType<typeof lottie.loadAnimation>[] = [];

    /** Create ALL 4 lotties at once — identical pattern to the working test page */
    function createAll() {
      destroyAll();
      containers.forEach((container, i) => {
        anims.push(lottie.loadAnimation({
          container,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: ANIM_PATHS[i],
          rendererSettings: {
            hideOnTransparent: false,
          },
        }));
      });
    }

    function destroyAll() {
      anims.forEach(a => a.destroy());
      anims = [];
    }

    const mm = gsap.matchMedia();

    /* ═══ DESKTOP: pinned scrub with state transitions ═══ */
    mm.add('(min-width: 768px)', () => {
      const states = section.querySelectorAll<HTMLElement>('.tp-state');

      // 1. Create ALL lotties BEFORE hiding — containers are fully visible at this point
      createAll();

      // 2. THEN hide states 1-3
      gsap.set(states[0], { autoAlpha: 1 });
      gsap.set(Array.from(states).slice(1), { autoAlpha: 0, yPercent: 8 });

      states.forEach(state => {
        const children = state.querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
        gsap.set(children, { y: 0 });
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          id: 'principi-anim',
          trigger: section,
          start: 'top top',
          end: '+=300%',
          pin: true,
          scrub: 0.5,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          refreshPriority: 900,
          snap: {
            snapTo: 'labels',
            duration: { min: 0.2, max: 0.6 },
            delay: 0.1,
            ease: 'power1.inOut',
          },
          onRefresh: (self) => {
            const t = self.getTween();
            if (t) t.progress(self.progress);
          },
        },
      });

      tl.addLabel('state0', 0);

      states.forEach((state, i) => {
        if (i < states.length - 1) {
          // Phase 1: Children stagger OUT (desc → title → placeholder)
          const currChildren = state.querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
          const reversed = Array.from(currChildren).reverse();
          reversed.forEach((child, ci) => {
            tl.fromTo(child,
              { y: 0, autoAlpha: 1 },
              { y: -20, autoAlpha: 0, ease: 'none', duration: 0.12 },
              i + 0.15 + ci * 0.05,
            );
          });

          // Hide the whole state after children are gone
          const hidePos = i + 0.15 + reversed.length * 0.05 + 0.12;
          tl.fromTo(state,
            { autoAlpha: 1 },
            { autoAlpha: 0, duration: 0.001 },
            hidePos,
          );

          // Phase 2: Next state — container fades in
          tl.fromTo(states[i + 1],
            { autoAlpha: 0 },
            { autoAlpha: 1, ease: 'none', duration: 0.1 },
            hidePos + 0.03,
          );

          // Phase 3: Children stagger in from below
          const nextChildren = states[i + 1].querySelectorAll<HTMLElement>('.tp-placeholder, .tp-state__title, .tp-state__desc');
          const enterStart = hidePos + 0.05;
          nextChildren.forEach((child, ci) => {
            tl.fromTo(child,
              { y: 20, autoAlpha: 0 },
              { y: 0, autoAlpha: 1, ease: 'none', duration: 0.15 },
              enterStart + ci * 0.06,
            );
          });

          tl.addLabel(`state${i + 1}`, i + 1);
        }
      });

      // Final dwell so last state has hold time
      tl.to({}, { duration: 0.5 });

      // Force re-render when each state becomes visible.
      // Browser skips SVG rasterization for visibility:hidden containers.
      // Without this, animations show stale frame 0 when the container
      // becomes visible via GSAP autoAlpha transition.
      let activeAnim = 0;
      tl.eventCallback('onUpdate', () => {
        const idx = Math.min(Math.round(tl.time()), states.length - 1);
        if (idx !== activeAnim) {
          activeAnim = idx;
          const a = anims[idx];
          if (a && a.isLoaded) {
            // Force SVG re-paint from the current frame
            a.goToAndStop(a.currentFrame, true);
            a.play();
          }
        }
      });

      // Section visibility gate — pause ALL when off-screen
      const visTrigger = ScrollTrigger.create({
        id: 'principi-anim-visibility',
        trigger: section,
        start: 'top bottom',
        end: 'bottom top',
        onEnter: () => anims.forEach(a => a.play()),
        onLeave: () => anims.forEach(a => a.pause()),
        onEnterBack: () => {
          anims.forEach(a => {
            if (a.isLoaded) { a.goToAndStop(a.currentFrame, true); a.play(); }
          });
        },
        onLeaveBack: () => anims.forEach(a => a.pause()),
      });

      return () => {
        visTrigger.kill();
        destroyAll();
      };
    });

    /* ═══ MOBILE: no pin, all visible in flow ═══ */
    mm.add('(max-width: 767px)', () => {
      createAll();

      // Section visibility gate — pause all when section is off-screen
      const visTrigger = ScrollTrigger.create({
        id: 'principi-mob-visibility',
        trigger: section,
        start: 'top bottom',
        end: 'bottom top',
        onEnter: () => anims.forEach(a => a.play()),
        onLeave: () => anims.forEach(a => a.pause()),
        onEnterBack: () => anims.forEach(a => a.play()),
        onLeaveBack: () => anims.forEach(a => a.pause()),
      });

      return () => {
        visTrigger.kill();
        destroyAll();
      };
    });
  }

  ((window as any).__initQueue ??= []).push(initPrincipi);
</script>
