<section id="hero">
  <div id="hero-video-frame">
    {/* LCP element: poster image shown immediately while the video loads.
        Fades out via GSAP on video 'playing'. If autoplay never kicks in
        (Low Power Mode, data-saver, codec unsupported), the poster stays. */}
    <img
      id="hero-poster"
      src="/images/hero-poster.webp"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1080"
    />
    <video
      id="hero-video"
      poster="/images/hero-poster.webp"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="/video/hero-vp9.webm" type="video/webm" />
      <source src="/video/hero-h265.mp4" type='video/mp4; codecs="hvc1"' />
    </video>
  </div>

  <div id="hero-content">
    <h1 id="hero-title">
      Empowering <span class="hero-accent">trust</span>, creating opportunities
    </h1>

    <div id="hero-details">
      <p>Siamo una società di consulenza legale specializzata in AI Governance, Data Protection e Cybersecurity.</p>
      <p>Progettiamo modelli di governance e compliance evoluti capaci di assicurare conformità normativa e generare fiducia, valore e competitività</p>
      <a href="#cosa-facciamo" id="hero-cta">
        <span>SCOPRI COSA FACCIAMO</span>
        <svg width="18" height="18" aria-hidden="true"><use href="#icon-arrow-forward" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  #hero {
    height: 100vh;
    height: 100dvh;
    position: relative;
    overflow: hidden;
    background: var(--color-bg);
  }

  #hero-video-frame {
    position: absolute;
    overflow: hidden;
  }

  #hero-video,
  #hero-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #hero-poster {
    position: absolute;
    inset: 0;
    z-index: 1;
    will-change: opacity;
  }

  #hero-content {
    position: absolute;
    top: 50%;
    right: clamp(20px, 5.6vw, 80px);
    max-width: clamp(320px, 37.7vw, 543px);
    visibility: hidden;
  }

  #hero-title {
    font-family: var(--font-serif);
    font-size: clamp(45px, calc(45px + 15 * (100vw - 375px) / 1065), 60px);
    font-weight: 400;
    line-height: clamp(50px, calc(50px + 10 * (100vw - 375px) / 1065), 60px);
    letter-spacing: -0.04em;
  }

  .hero-accent {
    color: var(--color-pink);
  }

  #hero-details {
    max-width: clamp(300px, 34.7vw, 500px);
  }

  #hero-details p {
    font-size: clamp(17px, calc(17px + 3 * (100vw - 375px) / 1065), 20px);
    line-height: clamp(24px, calc(24px + 4 * (100vw - 375px) / 1065), 28px);
    margin-bottom: clamp(12px, 1.4vw, 20px);
  }

  #hero-cta {
    display: inline-flex;
    margin-top: 20px;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid var(--color-text);
    color: var(--color-text);
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    line-height: 20px;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  @media (max-width: 1023px) {
    #hero {
      height: auto;
    }
    #hero-video-frame {
      position: relative;
      height: 50dvh;
    }
    #hero-content {
      position: relative;
      top: auto;
      right: auto;
      left: auto;
      max-width: none;
      padding: 24px var(--section-padding-x) 40px;
      visibility: visible;
    }
    #hero-details {
      max-width: none;
      margin-top: 20px;
    }
    #hero-title,
    #hero-details {
      visibility: hidden;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';

  // Module-scoped: survives across initHero calls (ClientRouter navigations)
  // so we can disconnect a stale observer before creating a new one.
  let videoGateObserver: IntersectionObserver | null = null;

  function initHero() {
    const hero = document.getElementById('hero');
    if (!hero) {
      // Defensive: if we navigate to a page without #hero, drop any stale
      // observer still holding a reference to a detached node.
      if (videoGateObserver) { videoGateObserver.disconnect(); videoGateObserver = null; }
      return;
    }

    // Poster → video crossfade. The <img> is the LCP element (served
    // immediately), the video loads and plays underneath. When the video
    // actually starts playing (not just buffers), fade the poster out.
    // If autoplay is blocked (iOS Low Power Mode, data-saver) or the codec
    // is unsupported, 'playing' never fires and the poster stays visible —
    // graceful fallback, no broken state.
    const video = hero.querySelector<HTMLVideoElement>('#hero-video');
    const poster = hero.querySelector<HTMLImageElement>('#hero-poster');
    if (video && poster) {
      const fadePoster = () => {
        gsap.to(poster, { autoAlpha: 0, duration: 0.4, ease: 'power2.out' });
      };
      if (!video.paused && video.readyState >= 3 && video.currentTime > 0) {
        fadePoster();
      } else {
        video.addEventListener('playing', fadePoster, { once: true });
      }
    }

    // Visibility gate for the background video. Not using ScrollTrigger
    // because the desktop pin (end: '+=200%') makes position-based math
    // unreliable — the trigger would see hero.bottom cross viewport.top
    // at scroll=100vh while the element is still visually pinned for
    // another 200vh. IntersectionObserver tracks actual visual visibility,
    // independent of pin/scroll math, and works identically on both
    // breakpoints with no duplication in matchMedia.
    if (video) {
      if (videoGateObserver) videoGateObserver.disconnect();
      videoGateObserver = new IntersectionObserver(
        (entries) => {
          const entry = entries[0];
          if (entry.isIntersecting) {
            // Resume on re-enter. Catches autoplay-blocked rejection
            // (iOS Low Power Mode) silently — poster fallback stays.
            video.play().catch(() => { /* autoplay blocked, poster stays */ });
          } else if (!video.paused) {
            video.pause();
          }
        },
        { threshold: 0 }
      );
      videoGateObserver.observe(hero);
    }

    let heroTl: gsap.core.Timeline | null = null;

    function setupHero() {
      const getHeaderH = () => {
        if (document.documentElement.clientWidth >= 768) {
          return document.getElementById('header')?.offsetHeight ?? 140;
        }
        return document.getElementById('header-compact')?.offsetHeight ?? 80;
      };
      const getInset = () => document.documentElement.clientWidth * 0.028;
      const root = getComputedStyle(document.documentElement);
      const colorPurple600 = root.getPropertyValue('--color-purple-600').trim();
      const colorText = root.getPropertyValue('--color-text').trim();

      // Hard-reset every Hero descendant before desktop setup (symmetric with
      // setupHeroMobile). clearProps clears GSAP's internal transform cache
      // (xPercent/yPercent/etc.), then removeAttribute clears DOM inline.
      // Exclude #hero-poster: its opacity is driven by a top-level tween
      // (poster→video crossfade) that lives OUTSIDE matchMedia. Clearing
      // its inline style would re-reveal the poster after a breakpoint
      // crossing, covering the playing video.
      const allHeroEls = [hero, ...Array.from(hero.querySelectorAll<HTMLElement>('*'))]
        .filter(el => el.id !== 'hero-poster');
      gsap.set(allHeroEls, { clearProps: 'all' });
      allHeroEls.forEach(el => el.removeAttribute('style'));

      // SplitText must run before collapsing height — needs natural layout
      const paragraphs = hero.querySelectorAll<HTMLElement>('#hero-details p');
      const splits = Array.from(paragraphs).map(p =>
        SplitText.create(p, { type: 'lines', aria: 'none' })
      );
      const allLines = splits.flatMap(s => s.lines);

      // Initial states
      gsap.set('#hero-video-frame', { top: 0, left: 0, right: 0, bottom: 0 });
      gsap.set('#hero-content', { yPercent: -50, autoAlpha: 1 });
      gsap.set(allLines, { autoAlpha: 0, y: 20 });
      gsap.set('#hero-cta', { autoAlpha: 0, y: 20 });
      gsap.set('#hero-details', { height: 0, marginTop: 0 });

      const tl = heroTl = gsap.timeline({
        scrollTrigger: {
          id: 'hero-anim',
          trigger: hero,
          start: 'top top',
          end: '+=200%',
          pin: true,
          scrub: 0.8,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          refreshPriority: 1000,
          onRefresh: (self) => {
            const t = self.getTween();
            if (t) t.progress(self.progress);
          },
        },
      });

      // Phase 1: video shrinks + content recenters (0 → 1)
      tl.fromTo('#hero-video-frame', {
        top: 0, left: 0, right: 0, bottom: 0,
      }, {
        top: () => getHeaderH(), left: () => getInset(), right: () => getInset(), bottom: 0,
        ease: 'none', duration: 1,
      }, 0);

      tl.fromTo('#hero-content', { y: 0 }, {
        y: () => getHeaderH() / 2, ease: 'none', duration: 1,
      }, 0);

      // Phase 2: details expand + lines reveal (1 → 2)
      tl.fromTo('#hero-details', { height: 0, marginTop: 0 }, {
        height: 'auto', marginTop: () => document.documentElement.clientWidth * 0.022,
        ease: 'none', duration: 1,
      }, 1);

      tl.fromTo(allLines, { autoAlpha: 0, y: 20 }, {
        autoAlpha: 1, y: 0, ease: 'none',
        duration: 0.15, stagger: 0.08,
      }, 1.1);

      tl.fromTo('#hero-cta', { autoAlpha: 0, y: 20 }, {
        autoAlpha: 1, y: 0, ease: 'none', duration: 0.15,
      }, '>');

      // CTA hover
      const cta = hero.querySelector<HTMLElement>('#hero-cta')!;
      const ac = new AbortController();

      const ctaArrow = cta.querySelector('svg') as SVGElement;

      cta.addEventListener('mouseenter', () => {
        gsap.to(cta, { borderColor: colorPurple600, color: colorPurple600, duration: 0.25, overwrite: true });
        if (ctaArrow) gsap.to(ctaArrow, { x: 5, duration: 0.3, ease: 'power2.out', overwrite: true });
      }, { signal: ac.signal });

      cta.addEventListener('mouseleave', () => {
        gsap.to(cta, { borderColor: colorText, color: colorText, duration: 0.25, overwrite: true });
        if (ctaArrow) gsap.to(ctaArrow, { x: 0, duration: 0.3, ease: 'power2.out', overwrite: true });
      }, { signal: ac.signal });

      return () => { heroTl = null; ac.abort(); };
    }

    function setupHeroMobile() {
      const video = hero.querySelector('#hero-video') as HTMLElement;
      const posterEl = hero.querySelector('#hero-poster') as HTMLElement;
      const content = hero.querySelector('#hero-content') as HTMLElement;
      const titleEl = hero.querySelector('#hero-title') as HTMLElement;
      const paragraphs = hero.querySelectorAll<HTMLElement>('#hero-details p');
      const cta = hero.querySelector('#hero-cta') as HTMLElement;

      // Hard-reset every Hero descendant before mobile setup. Two-step:
      //   1) gsap.set clearProps: 'all' — clears GSAP's INTERNAL transform cache
      //      (xPercent/yPercent/x/y/rotation/scale that GSAP keeps on el._gsap),
      //      otherwise the next gsap.set() would re-apply leftover values from
      //      the desktop callback (e.g. yPercent:-50 → translate(0,-50%) bleeds
      //      back as transform: matrix(1,0,0,1,0,-85px) on #hero-content).
      //   2) removeAttribute('style') — defensive DOM cleanup for any non-GSAP
      //      inline that might remain.
      // Exclude #hero-poster: its opacity is driven by a top-level tween
      // (poster→video crossfade) that lives OUTSIDE matchMedia. Clearing
      // its inline style would re-reveal the poster after a breakpoint
      // crossing, covering the playing video.
      const allHeroEls = [hero, ...Array.from(hero.querySelectorAll<HTMLElement>('*'))]
        .filter(el => el.id !== 'hero-poster');
      gsap.set(allHeroEls, { clearProps: 'all' });
      allHeroEls.forEach(el => el.removeAttribute('style'));

      // SplitText for title — needs natural layout before hiding
      const titleSplit = SplitText.create(titleEl, { type: 'words', aria: 'none' });

      // Initial states — reveal containers (CSS hides them to prevent FOUC),
      // then hide children for entrance animation
      gsap.set(content, { autoAlpha: 1 });
      gsap.set(titleEl, { visibility: 'visible' });
      gsap.set('#hero-details', { visibility: 'visible' });
      gsap.set(titleSplit.words, { autoAlpha: 0, y: 20 });
      gsap.set(paragraphs, { autoAlpha: 0, y: 15 });
      gsap.set(cta, { autoAlpha: 0, y: 15 });
      // Entrance timeline — plays on page load
      const tl = gsap.timeline({ delay: 0.3 });

      tl.to(titleSplit.words, {
        autoAlpha: 1, y: 0,
        duration: 0.6, stagger: 0.1,
        ease: 'power3.out',
      }, 0);

      tl.to(paragraphs, {
        autoAlpha: 1, y: 0,
        duration: 0.5, stagger: 0.12,
        ease: 'power2.out',
      }, 0.4);

      tl.to(cta, {
        autoAlpha: 1, y: 0,
        duration: 0.5, ease: 'power2.out',
      }, 0.65);

      const videoFrame = hero.querySelector('#hero-video-frame') as HTMLElement;

      // Shared ScrollTrigger for both effects
      const scrollTl = gsap.timeline({
        scrollTrigger: {
          id: 'hero-parallax',
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: 0.5,
          refreshPriority: 1000,
        },
      });

      // Parallax: video (and poster, while still visible) scroll slower than
      // content. Both must translate together — otherwise during the brief
      // window before fadePoster completes, the poster would stay put while
      // the video slides, revealing a seam.
      scrollTl.fromTo([video, posterEl].filter(Boolean),
        { y: 0 },
        { y: () => document.documentElement.clientHeight * 0.15, ease: 'none', duration: 1 },
        0
      );

      // Card effect: frame gains inset + border-radius
      scrollTl.fromTo(videoFrame,
        { clipPath: 'inset(0px round 0px)', },
        { clipPath: () => `inset(0px ${document.documentElement.clientWidth * 0.1}px ${document.documentElement.clientHeight * 0.15}px round 28px)`, ease: 'none', duration: 1 },
        0
      );

      return () => { heroTl = null; };
    }

    // Gate SplitText creation on fonts being loaded. SplitText measures text
    // geometry via canvas — if called before the real font swaps in, it splits
    // based on the fallback's metrics and the split is wrong (GSAP warns
    // "SplitText called before fonts loaded"). The poster→video crossfade above
    // stays synchronous; only matchMedia setup waits.
    const runMatchMedia = () => {
      const mm = gsap.matchMedia();
      mm.add('(min-width: 1024px)', setupHero);
      mm.add('(max-width: 1023px)', setupHeroMobile);
    };

    if (document.fonts && document.fonts.status !== 'loaded') {
      document.fonts.ready.then(runMatchMedia);
    } else {
      runMatchMedia();
    }
  }

  ((window as any).__initQueue ??= []).push(initHero);
</script>
