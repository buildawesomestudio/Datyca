<header id="header-compact">
  <div class="header-compact-inner">
    <a href="/" class="header-compact-logo" id="header-compact-logo">
      <img src="/images/monogramma-full.svg" alt="Datyca" width="60" height="60" class="logo-full" />
      <img src="/images/monogramma-stroke.svg" alt="" width="60" height="60" class="logo-stroke" aria-hidden="true" />
    </a>
    <button id="menu-toggle" class="header-compact-menu" aria-label="Apri menu">
      <svg width="32" height="22" aria-hidden="true" fill="currentColor"><use href="#icon-hamburger" /></svg>
    </button>
  </div>
</header>

<style>
  #header-compact {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    visibility: hidden;
  }

  .header-compact-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 40px;
  }

  .header-compact-logo {
    display: flex;
    align-items: center;
    position: relative;
  }

  .logo-stroke {
    position: absolute;
    top: 0;
    left: 0;
  }

  .header-compact-logo img {
    width: 50px;
    height: 50px;
  }

  .header-compact-menu {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 15px;
    margin-right: -15px;
    color: var(--color-purple-600);
  }
</style>

<script>
  import { MQ } from '@utils/breakpoints';
  import { registerInit } from '@utils/init';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHeaderCompact() {
    const compact = document.getElementById('header-compact');
    const full = document.getElementById('header');
    const logo = document.getElementById('header-compact-logo');
    const menuBtn = document.getElementById('menu-toggle');
    if (!compact || !full || !logo || !menuBtn) return;

    const logoFull = logo.querySelector('.logo-full') as HTMLElement;
    const logoStroke = logo.querySelector('.logo-stroke') as HTMLElement;

    const root = getComputedStyle(document.documentElement);
    const colorRed = root.getPropertyValue('--color-red').trim();
    const colorPurple = root.getPropertyValue('--color-purple-600').trim();

    // Initial state: stroke hidden
    gsap.set(logoStroke, { autoAlpha: 0 });

    // Logo hover
    logo.addEventListener('mouseenter', () => {
      gsap.to(logoFull, { autoAlpha: 0, duration: 0.2, overwrite: true });
      gsap.to(logoStroke, { autoAlpha: 1, duration: 0.2, overwrite: true });
    });

    logo.addEventListener('mouseleave', () => {
      gsap.to(logoFull, { autoAlpha: 1, duration: 0.2, overwrite: true });
      gsap.to(logoStroke, { autoAlpha: 0, duration: 0.2, overwrite: true });
    });

    // Hamburger hover
    menuBtn.addEventListener('mouseenter', () => {
      gsap.to(menuBtn, { color: colorRed, duration: 0.2, overwrite: true });
    });

    menuBtn.addEventListener('mouseleave', () => {
      gsap.to(menuBtn, { color: colorPurple, duration: 0.2, overwrite: true });
    });

    // State that survives breakpoint crossing
    let hasSwapped = false;

    // ── Shared: compute content-top of the first element inside <main>
    //    Used as fallback on pages without hero-anim (sub-pages).
    //    Returns the document-y where the first visible content actually starts,
    //    so the swap can coincide with that content physically pushing the header.
    function firstContentTopY(): number | null {
      const firstEl = document.querySelector('main > *:first-child') as HTMLElement | null;
      if (!firstEl) return null;
      const pt = parseFloat(getComputedStyle(firstEl).paddingTop) || 0;
      return firstEl.offsetTop + pt;
    }

    // Desktop: full header swap (both headers slide)
    function setupHeaderSwap() {
      gsap.set(compact, { visibility: 'visible' });

      const headerH = full.offsetHeight;

      const swapTl = gsap.timeline({
        scrollTrigger: {
          id: 'header-swap',
          start: () => {
            const heroST = ScrollTrigger.getById('hero-anim');
            if (heroST) return heroST.end;
            // Sub-page: swap starts when first content top reaches header bottom
            const y = firstContentTopY();
            return y == null ? 0 : Math.max(0, y - headerH);
          },
          end: () => {
            const heroST = ScrollTrigger.getById('hero-anim');
            if (heroST) return heroST.end + headerH;
            // Sub-page: swap ends when first content top reaches viewport top
            const y = firstContentTopY();
            return y == null ? headerH : Math.max(headerH, y);
          },
          scrub: 0.5,
          invalidateOnRefresh: true,
          onEnter: () => { full.style.overflow = 'hidden'; },
          onLeaveBack: () => { full.style.overflow = ''; },
          onLeave: () => { hasSwapped = true; },
          onEnterBack: () => { hasSwapped = false; },
        },
      });

      swapTl.fromTo(full, { yPercent: 0 }, { yPercent: -100, ease: 'none' }, 0);
      swapTl.fromTo(compact, { yPercent: -100 }, { yPercent: 0, ease: 'none' }, 0.5);

      return () => { full.style.overflow = ''; };
    }

    // Mobile: crossfade logo only, hamburger stays in place
    function setupMobileLogoSwap() {
      const logoFullImg = full.querySelector('.header-logo-full') as HTMLElement;
      const logoMono = full.querySelector('.header-logo-mono') as HTMLElement;
      if (!logoFullImg || !logoMono) return;

      gsap.set(logoMono, { autoAlpha: 0 });

      const headerH = full.offsetHeight;

      const swapTl = gsap.timeline({
        scrollTrigger: {
          id: 'header-swap',
          start: () => {
            const videoFrame = document.getElementById('hero-video-frame');
            if (videoFrame) return videoFrame.offsetHeight - headerH;
            // Sub-page: swap starts when first content top reaches header bottom
            const y = firstContentTopY();
            return y == null ? 0 : Math.max(0, y - headerH);
          },
          end: () => {
            const videoFrame = document.getElementById('hero-video-frame');
            if (videoFrame) return videoFrame.offsetHeight;
            // Sub-page: swap ends when first content top reaches viewport top
            const y = firstContentTopY();
            return y == null ? headerH : Math.max(headerH, y);
          },
          scrub: 0.5,
          invalidateOnRefresh: true,
          onLeave: () => { hasSwapped = true; },
          onEnterBack: () => { hasSwapped = false; },
        },
      });

      swapTl.fromTo(logoFullImg, { autoAlpha: 1 }, { autoAlpha: 0, ease: 'none' }, 0);
      swapTl.fromTo(logoMono, { autoAlpha: 0 }, { autoAlpha: 1, ease: 'none' }, 0);

      return () => {};
    }

    const mm = gsap.matchMedia();
    mm.add(MQ.tabletUp, setupHeaderSwap);
    mm.add(MQ.belowTablet, setupMobileLogoSwap);
  }

  registerInit(initHeaderCompact);
</script>
